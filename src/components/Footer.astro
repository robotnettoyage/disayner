---
const currentYear = new Date().getFullYear();

const navCol = [
  { label: "Accueil",      href: "/" },
  { label: "Services",     href: "/#services" },
  { label: "Méthode",      href: "/#methode" },
  { label: "Réalisations", href: "/realisations" },
  { label: "Blog",         href: "/blog" },
];

const servicesCol = [
  { label: "Création de sites web", href: "/creation-site" },
  { label: "Référencement SEO",     href: "/seo" },
  { label: "Maintenance web",       href: "/maintenance" },
  { label: "Audit & Conseil",       href: "/contact" },
  { label: "Outils SEO gratuits",   href: "/outils" },
];

const contactCol = [
  { label: "contact@disayner.com", href: "mailto:contact@disayner.com" },
  { label: "Réserver un appel",    href: "/contact" },
  { label: "Devis gratuit",        href: "/contact" },
];
---

<footer class="footer" aria-label="Pied de page">
  <div class="footer-inner">
    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="DISAYNER">DISAYNER</a>
      <p class="footer-tagline">Création de sites web premium<br />& Référencement SEO</p>
      <p class="footer-location">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Haute-Savoie, France
      </p>
    </div>

    <!-- Navigation column -->
    <div class="footer-col">
      <h3 class="footer-col-title">Navigation</h3>
      <ul class="footer-links" role="list">
        {navCol.map((link) => (
          <li>
            <a href={link.href} class="footer-link hover-underline">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Services column -->
    <div class="footer-col">
      <h3 class="footer-col-title">Services</h3>
      <ul class="footer-links" role="list">
        {servicesCol.map((link) => (
          <li>
            <a href={link.href} class="footer-link hover-underline">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact column -->
    <div class="footer-col">
      <h3 class="footer-col-title">Contact</h3>
      <ul class="footer-links" role="list">
        {contactCol.map((link) => (
          <li>
            <a href={link.href} class="footer-link hover-underline">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copyright">
        © {currentYear} DISAYNER. Tous droits réservés.
      </p>
      <div class="footer-legal">
        <a href="/mentions-legales" class="footer-link hover-underline">Mentions légales</a>
        <span aria-hidden="true">·</span>
        <a href="/confidentialite" class="footer-link hover-underline">Politique de confidentialité</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-logo {
    display: block;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: opacity 0.2s ease;
  }

  .footer-logo:hover { opacity: 0.7; }

  .footer-tagline {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .footer-location {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-col-title {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover { color: var(--color-text-primary); }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      padding: 3rem 1.25rem 2rem;
      gap: 2rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem 1.25rem;
    }
  }
</style>
