---
const services = [
  { label: "Création de sites web", href: "/creation-site", desc: "Sites vitrines, e-commerce & landing pages sur-mesure", icon: `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>` },
  { label: "Référencement SEO", href: "/seo", desc: "Audit, contenus, technique & visibilité IA (GEO)", icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>` },
  { label: "Maintenance web", href: "/maintenance", desc: "Sécurité, mises à jour & monitoring 24/7", icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/>` },
];

const tools = [
  { label: "Compresseur WebP", href: "/outils/compresseur-webp", icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>` },
  { label: "Analyseur meta tags", href: "/outils/analyseur-meta-tags", icon: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>` },
  { label: "Compteur de mots SEO", href: "/outils/compteur-mots-seo", icon: `<path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/>` },
  { label: "Générateur meta tags", href: "/outils/generateur-meta-tags", icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>` },
  { label: "Générateur robots.txt", href: "/outils/generateur-robots-txt", icon: `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>` },
  { label: "Vérificateur structure Hn", href: "/outils/verificateur-structure-hn", icon: `<path d="M6 12h12"/><path d="M6 4h12"/><path d="M9 20h6"/>` },
];
---

<header id="navbar" aria-label="Navigation principale">
  <nav class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo logo-shimmer" aria-label="DISAYNER — Accueil">
      DISAYNER
    </a>

    <!-- Desktop links -->
    <div class="nav-links">
      <div class="nav-item-dropdown" id="servicesTrigger">
        <button type="button" class="nav-link nav-link-dropdown" aria-expanded="false" aria-controls="megaDropdown">
          Services
          <svg class="chevron-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div class="mega-dropdown" id="megaDropdown" role="menu" aria-label="Menu services">
          <div class="mega-grid">
            <!-- Col 1: Services -->
            <div class="mega-col">
              <span class="mega-col-title">Nos services</span>
              {services.map((s) => (
                <a href={s.href} class="mega-link" role="menuitem">
                  <div class="mega-item-icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
                  </div>
                  <div class="mega-item-content">
                    <span class="mega-link-label">{s.label}</span>
                    <span class="mega-link-desc">{s.desc}</span>
                  </div>
                </a>
              ))}
            </div>
            <!-- Col 2: Outils SEO -->
            <div class="mega-col">
              <span class="mega-col-title">Outils SEO gratuits</span>
              {tools.map((t) => (
                <a href={t.href} class="mega-link mega-link-compact" role="menuitem">
                  <div class="mega-item-icon-sm" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={t.icon} />
                  </div>
                  <span>{t.label}</span>
                </a>
              ))}
              <a href="/outils" class="mega-link-all">Voir tous les outils &rarr;</a>
            </div>
            <!-- Col 3: Ressources -->
            <div class="mega-col mega-col-tinted">
              <span class="mega-col-title">Ressources</span>
              <a href="/realisations" class="mega-resource" role="menuitem">
                <div class="mega-resource-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <div><span class="mega-resource-title">Études de cas</span><span class="mega-resource-desc">Nos réalisations et résultats clients</span></div>
              </a>
              <a href="/contact" class="mega-resource" role="menuitem">
                <div class="mega-resource-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div><span class="mega-resource-title">Discutons de votre projet</span><span class="mega-resource-desc">Appel découverte gratuit, réponse sous 24h</span></div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <a href="/realisations" class="nav-link hover-underline">Réalisations</a>
      <a href="/blog" class="nav-link hover-underline">Blog</a>
      <a href="/contact" class="nav-link hover-underline">Contact</a>
    </div>

    <!-- Desktop CTA -->
    <a href="/contact" class="btn-primary nav-cta">
      Démarrer un projet
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Hamburger (mobile) -->
    <button class="burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </nav>

  <!-- Mobile overlay menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu navigation mobile">
    <button class="mobile-close" aria-label="Fermer le menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <nav class="mobile-nav-content" aria-label="Menu mobile">
      <div class="mobile-section">
        <span class="mobile-section-title">Services</span>
        {services.map((s) => (
          <a href={s.href} class="mobile-link">{s.label}</a>
        ))}
      </div>
      <div class="mobile-section">
        <span class="mobile-section-title">Outils SEO</span>
        {tools.map((t) => (
          <a href={t.href} class="mobile-link">{t.label}</a>
        ))}
        <a href="/outils" class="mobile-link mobile-link-accent">Voir tous les outils &rarr;</a>
      </div>
      <hr class="mobile-divider" />
      <a href="/realisations" class="mobile-link">Réalisations</a>
      <a href="/#methode" class="mobile-link">Notre méthode</a>
      <a href="/blog" class="mobile-link">Blog</a>
      <a href="/contact" class="mobile-link">Contact</a>
      <a href="/contact" class="btn-primary mobile-cta">Démarrer un projet &rarr;</a>
    </nav>
  </div>
</header>

<style>
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.4s ease, backdrop-filter 0.4s ease, border-color 0.4s ease;
    border-bottom: 1px solid transparent;
  }

  #navbar.nav--scrolled {
    background: rgba(250, 250, 249, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
    will-change: backdrop-filter;
  }

  .nav-inner {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: 0.12em;
    color: var(--color-text-primary);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .nav-logo:hover { opacity: 0.7; }

  .logo-shimmer {
    background: linear-gradient(
      90deg,
      #1A1A19 0%,
      #1A1A19 30%,
      #2563EB 50%,
      #1A1A19 70%,
      #1A1A19 100%
    );
    background-size: 250% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: logoShimmer 5s ease-in-out infinite;
  }

  @keyframes logoShimmer {
    0%, 20%   { background-position: 200% center; }
    80%, 100% { background-position: -200% center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-shimmer {
      animation: none;
      background: none;
      -webkit-text-fill-color: currentColor;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-left: auto;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    padding-bottom: 2px;
  }

  .nav-link:hover { color: var(--color-text-primary); }

  /* ─── Dropdown trigger ─── */
  .nav-link-dropdown {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    color: inherit;
    padding: 0;
    padding-bottom: 2px;
  }

  .chevron-icon { transition: transform 0.3s ease; }

  .nav-item-dropdown.is-open .chevron-icon { transform: rotate(180deg); }

  /* ─── Mega-dropdown panel ─── */
  .nav-item-dropdown { position: static; }

  .mega-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    width: min(920px, calc(100vw - 3rem));
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
    padding: 1.75rem 2rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease;
    pointer-events: none;
    z-index: 100;
  }

  .nav-item-dropdown.is-open .mega-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .mega-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 0.85fr;
    gap: 2rem;
  }

  .mega-col { display: flex; flex-direction: column; gap: 0.25rem; }

  .mega-col-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .mega-link {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 12px;
    padding: 0.625rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background 0.15s ease;
  }

  .mega-link:hover { background: var(--color-surface); }

  .mega-item-icon {
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: var(--color-accent-soft);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .mega-link:hover .mega-item-icon { background: var(--color-accent); }
  .mega-link:hover .mega-item-icon svg { stroke: white; }

  .mega-item-content { display: flex; flex-direction: column; gap: 2px; }

  .mega-link-label { font-size: 0.9375rem; font-weight: 600; }

  .mega-link-desc { font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.4; }

  .mega-link-compact {
    align-items: center;
    gap: 10px;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
  }

  .mega-item-icon-sm {
    width: 28px;
    height: 28px;
    min-width: 28px;
    background: var(--color-accent-soft);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .mega-link-compact:hover .mega-item-icon-sm { background: var(--color-accent); }
  .mega-link-compact:hover .mega-item-icon-sm svg { stroke: white; }

  .mega-link-all {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    margin-top: 0.25rem;
    transition: padding-left 0.2s ease;
  }

  .mega-link-all:hover { padding-left: 1rem; }

  .mega-col-tinted {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.25rem;
    margin: -1.75rem -2rem -1.75rem 0;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }

  .mega-resource {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, box-shadow 0.15s ease;
    margin-bottom: 0.5rem;
  }

  .mega-resource:hover { background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }

  .mega-resource-icon {
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: var(--color-accent-soft);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mega-resource-title { display: block; font-size: 0.875rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 2px; }

  .mega-resource-desc { display: block; font-size: 0.75rem; color: var(--color-text-secondary); line-height: 1.4; }

  .nav-cta {
    flex-shrink: 0;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
  }

  /* Burger */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }

  .burger-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--color-text-primary);
    transition: transform 0.3s ease, opacity 0.3s ease;
    border-radius: 2px;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-background);
    z-index: 200;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 3rem 2.5rem;
    transform: translateX(100%);
    transition: none;
  }

  .mobile-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-primary);
    padding: 8px;
  }

  .mobile-nav-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    overflow-y: auto;
    max-height: calc(100svh - 6rem);
    padding-right: 0.5rem;
  }

  .mobile-section { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1rem; }

  .mobile-section-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: 0.375rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-link {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }

  .mobile-link:hover { color: var(--color-accent); }

  .mobile-link-accent { font-weight: 600; color: var(--color-accent); font-size: 0.9375rem; }

  .mobile-divider { border: none; border-top: 1px solid var(--color-border); margin: 0.75rem 0; }

  .mobile-cta { margin-top: 1rem; text-align: center; }

  @media (max-width: 900px) {
    .nav-links      { display: none; }
    .nav-cta        { display: none; }
    .mega-dropdown  { display: none !important; }
    .burger         { display: flex; }
  }

  @media (max-width: 768px) {
    .nav-inner { padding: 0 1.25rem; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const navbar  = document.getElementById("navbar")!;
  const burger  = document.querySelector(".burger") as HTMLButtonElement;
  const closeBtn = document.querySelector(".mobile-close") as HTMLButtonElement;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const mobileLinks = document.querySelectorAll(".mobile-link, .mobile-cta");

  // Glassmorphism on scroll
  ScrollTrigger.create({
    start: "top -60px",
    onEnter: () => navbar.classList.add("nav--scrolled"),
    onLeaveBack: () => navbar.classList.remove("nav--scrolled"),
  });

  // ── Mega-dropdown hover logic ──
  const ddTrigger = document.getElementById("servicesTrigger");
  const ddPanel = document.getElementById("megaDropdown");
  const ddBtn = ddTrigger?.querySelector(".nav-link-dropdown") as HTMLButtonElement | null;
  let closeTimeout: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
    ddTrigger?.classList.add("is-open");
    ddBtn?.setAttribute("aria-expanded", "true");
  }

  function closeDropdown() {
    ddTrigger?.classList.remove("is-open");
    ddBtn?.setAttribute("aria-expanded", "false");
  }

  function scheduleClose() {
    closeTimeout = setTimeout(closeDropdown, 200);
  }

  ddTrigger?.addEventListener("mouseenter", openDropdown);
  ddTrigger?.addEventListener("mouseleave", scheduleClose);
  ddPanel?.addEventListener("mouseenter", openDropdown);
  ddPanel?.addEventListener("mouseleave", scheduleClose);

  ddBtn?.addEventListener("click", () => {
    ddBtn.getAttribute("aria-expanded") === "true" ? closeDropdown() : openDropdown();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && ddTrigger?.classList.contains("is-open")) {
      closeDropdown();
      ddBtn?.focus();
    }
  });

  document.addEventListener("click", (e) => {
    if (ddTrigger && !ddTrigger.contains(e.target as Node)) closeDropdown();
  });

  // Mobile menu
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    burger.setAttribute("aria-expanded", "true");
    mobileMenu.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    gsap.set(mobileMenu, { x: "100%" });
    gsap.to(mobileMenu, { x: "0%", duration: 0.5, ease: "power3.out" });
    gsap.from(mobileLinks, {
      x: 50,
      opacity: 0,
      stagger: 0.04,
      delay: 0.25,
      duration: 0.5,
      ease: "power2.out",
    });
  }

  function closeMenu() {
    isOpen = false;
    burger.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    gsap.to(mobileMenu, { x: "100%", duration: 0.4, ease: "power3.in" });
  }

  burger.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));
  closeBtn.addEventListener("click", closeMenu);
  mobileLinks.forEach((link) => {
    if (link.tagName === "A") link.addEventListener("click", closeMenu);
  });
</script>
