---
const clients = [
  "VITOR",
  "LOVE AT ME",
  "RÉVÉLIÆNCE",
  "JM SERVICES",
  "GRIFFE EVENT",
  "BOOSTHOR",
  "CILS AND CO",
  "FÉLIN NOIR",
];
---

<section class="logo-banner" aria-label="Clients et références">
  <div class="banner-label-wrapper">
    <p class="banner-label">Projets réalisés pour</p>
  </div>

  <div class="marquee-wrapper" aria-hidden="true">
    <div class="marquee-track">
      {clients.map((client, i) => (
        <>
          <div class="logo-pill">
            <span>{client}</span>
          </div>
          <span class="marquee-sep" aria-hidden="true">◆</span>
        </>
      ))}
      {/* Duplicate for seamless loop */}
      {clients.map((client, i) => (
        <>
          <div class="logo-pill" aria-hidden="true">
            <span>{client}</span>
          </div>
          <span class="marquee-sep" aria-hidden="true">◆</span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .logo-banner {
    padding: 3.5rem 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .banner-label-wrapper {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .banner-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .marquee-wrapper {
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    width: max-content;
    animation: marquee 32s linear infinite;
  }

  .marquee-wrapper:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .logo-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: var(--color-background);
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }

  .logo-pill:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(37,99,235,0.1);
  }

  .logo-pill span {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .logo-pill:hover span {
    color: var(--color-accent);
  }

  .marquee-sep {
    font-size: 0.375rem;
    color: var(--color-accent);
    opacity: 0.25;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
