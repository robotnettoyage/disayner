---
import BgDots from './BgDots.astro';
const steps = [
  {
    number: "01",
    title: "Découverte & Stratégie",
    description: "On analyse votre marché, vos concurrents, vos objectifs. On définit la stratégie avant de toucher au design.",
    tags: ["Audit digital", "Analyse concurrentielle", "Objectifs", "Arborescence"],
    iconPath: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
  },
  {
    number: "02",
    title: "Conception & Design",
    description: "Architecture, wireframes, direction artistique. Chaque page est pensée pour convertir et pour refléter votre marque.",
    tags: ["Wireframes", "Moodboard", "UI Design", "Prototypage"],
    iconPath: `<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>`,
  },
  {
    number: "03",
    title: "Développement & SEO",
    description: "Code propre, performance optimale, SEO intégré nativement dès la première ligne. Pas de compromis technique.",
    tags: ["Développement", "SEO on-page", "Tests", "Lighthouse 95+"],
    iconPath: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  },
  {
    number: "04",
    title: "Lancement & Croissance",
    description: "Mise en ligne, tracking, optimisations continues. Votre site est un actif vivant qui progresse avec vous.",
    tags: ["Mise en ligne", "Analytics", "Suivi SEO", "Maintenance"],
    iconPath: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  },
];
---

<section class="method-section" id="methode" aria-label="Notre méthode de travail">
  <BgDots pulseCount={7} />
  <!-- Header -->
  <div class="method-header">
    <p class="section-label">Notre méthode</p>
    <h2>Un process éprouvé<br /><em class="font-serif">pour des résultats.</em></h2>
    <p class="method-sub">Pas d'improvisation. Chaque projet suit une méthodologie rigoureuse qui garantit qualité et efficacité.</p>
  </div>

  <!-- Timeline -->
  <div class="timeline-wrapper">
    <div class="timeline-line" aria-hidden="true"></div>

    {steps.map((step, i) => (
      <div class={`timeline-item ${i % 2 === 0 ? "item-left" : "item-right"}`} data-aos>
        <!-- Dot on the line -->
        <div class="timeline-dot" aria-hidden="true">
          <div class="dot-inner"></div>
        </div>

        <!-- Card -->
        <article class="method-card" aria-label={`Étape ${step.number} : ${step.title}`}>
          <!-- Watermark number -->
          <span class="card-watermark" aria-hidden="true">{step.number}</span>

          <!-- Icon -->
          <div class="card-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
              set:html={step.iconPath} />
          </div>

          <!-- Step counter -->
          <span class="card-step-label">{step.number} / 04</span>

          <!-- Content -->
          <h3 class="card-title">{step.title}</h3>
          <p class="card-desc">{step.description}</p>

          <!-- Tags -->
          <div class="card-tags">
            {step.tags.map((tag) => (
              <span class="card-tag">{tag}</span>
            ))}
          </div>
        </article>
      </div>
    ))}
  </div>
</section>

<style>
  .method-section {
    position: relative;
    padding: 7rem 2rem;
    background: var(--color-background);
    overflow: hidden;
  }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .method-header {
    position: relative;
    z-index: 1;
    max-width: 580px;
    margin: 0 auto 5rem;
    text-align: center;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
  }

  .method-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .method-header em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
  }

  .method-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* ── Timeline ────────────────────────────────────────────────────────────── */
  .timeline-wrapper {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Center vertical line */
  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
    transform: translateX(-50%);
    border-radius: 1px;
  }

  /* Timeline items */
  .timeline-item {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 4rem;
    opacity: 0;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .timeline-item.item-left {
    justify-content: flex-start;
    transform: translateX(-32px);
  }

  .timeline-item.item-right {
    justify-content: flex-end;
    transform: translateX(32px);
  }

  .timeline-item.aos-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .timeline-item:last-child { margin-bottom: 0; }

  /* Dot */
  .timeline-dot {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-background);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: border-color 0.4s ease, background 0.4s ease;
  }

  .dot-inner {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.4s ease;
  }

  .timeline-item.aos-visible .timeline-dot {
    border-color: var(--color-accent);
  }

  .timeline-item.aos-visible .dot-inner {
    background: var(--color-accent);
  }

  /* Cards */
  .method-card {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.25rem 2.5rem;
    width: calc(50% - 3rem);
    overflow: hidden;
    transition: box-shadow 0.4s ease, transform 0.4s ease, border-color 0.3s ease;
    cursor: default;
  }

  .method-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.07);
    transform: translateY(-4px);
    border-color: rgba(37, 99, 235, 0.3);
  }

  /* Alternating backgrounds */
  .item-right .method-card {
    background: var(--color-surface);
  }

  /* Watermark */
  .card-watermark {
    position: absolute;
    top: -0.5rem;
    right: 1.25rem;
    font-size: clamp(4rem, 8vw, 6rem);
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.07;
    line-height: 1;
    letter-spacing: -0.04em;
    pointer-events: none;
    user-select: none;
  }

  /* Icon */
  .card-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  /* Step counter */
  .card-step-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.625rem;
  }

  /* Title */
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  /* Desc */
  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* Tags */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    background: rgba(37, 99, 235, 0.07);
    color: var(--color-accent);
    border-radius: 100px;
    border: 1px solid rgba(37, 99, 235, 0.15);
    letter-spacing: 0.01em;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .method-section { padding: 4rem 1.25rem; }

    .timeline-line {
      left: 20px;
      transform: none;
    }

    .timeline-item {
      justify-content: flex-end !important;
      transform: translateX(24px) !important;
      padding-left: 3rem;
    }

    .timeline-item.aos-visible {
      transform: translateX(0) !important;
    }

    .timeline-dot {
      left: 20px;
      transform: translateX(-50%);
    }

    .method-card {
      width: 100%;
    }

    .method-header { margin-bottom: 3rem; }
  }

  @media (max-width: 480px) {
    .method-card { padding: 1.5rem; }
    .card-watermark { font-size: 3.5rem; }
  }
</style>

<script>
  // IntersectionObserver — no GSAP dependency, 100% reliable
  const items = document.querySelectorAll(".timeline-item");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("aos-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2, rootMargin: "0px 0px -60px 0px" }
  );

  items.forEach((el) => observer.observe(el));
</script>
