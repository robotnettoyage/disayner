---
---

<section class="hero" id="accueil" aria-label="Présentation DISAYNER">
  <!-- Decorative orbs (CSS-only) -->
  <div class="hero-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <!-- Content -->
  <div class="hero-content">
    <!-- Badge -->
    <div class="hero-badge gsap-hidden">
      <span class="badge-dot" aria-hidden="true"></span>
      <span>Agence web indépendante · Haute-Savoie, France</span>
    </div>

    <!-- Main headline -->
    <h1 class="hero-title" aria-label="Nous créons des sites exceptionnels qui génèrent des résultats.">
      <span class="hero-line hero-line-1">Nous créons des</span>
      <span class="hero-line hero-line-2">
        sites <em class="hero-em font-serif">exceptionnels</em>
      </span>
      <span class="hero-line hero-line-3">qui génèrent des résultats.</span>
    </h1>

    <!-- Subtext -->
    <p class="hero-sub gsap-hidden">
      Design premium, SEO intégré, performance maximale.<br class="hidden-sm" />
      Pour les marques qui refusent l'ordinaire.
    </p>

    <!-- CTA buttons -->
    <div class="hero-ctas gsap-hidden">
      <a href="#contact" class="btn-primary hero-cta-primary">
        Démarrer un projet
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#realisations" class="btn-outline hero-cta-secondary">
        Voir nos réalisations
      </a>
    </div>

    <!-- Social proof -->
    <div class="hero-proof gsap-hidden">
      <div class="proof-stats">
        <div class="proof-stat">
          <span class="proof-num">+50</span>
          <span class="proof-lbl">projets livrés</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat">
          <span class="proof-num">95+</span>
          <span class="proof-lbl">Lighthouse score</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-stat">
          <span class="proof-num">4.9<span style="font-size:0.6em;opacity:0.6">/5</span></span>
          <span class="proof-lbl">satisfaction</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator gsap-hidden" aria-label="Défiler vers le bas">
    <span class="scroll-label">Défiler</span>
    <div class="scroll-line" aria-hidden="true">
      <div class="scroll-thumb"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 7rem;
    overflow: hidden;
  }

  /* ── Orbs ── */
  .hero-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .orb-1 {
    width: min(700px, 80vw);
    height: min(700px, 80vw);
    background: radial-gradient(circle, rgba(37, 99, 235, 0.12) 0%, transparent 70%);
    top: -200px;
    right: -200px;
    animation: orb-float 18s ease-in-out infinite;
    filter: blur(2px);
  }

  .orb-2 {
    width: min(500px, 60vw);
    height: min(500px, 60vw);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
    bottom: -100px;
    left: -150px;
    animation: orb-float 22s ease-in-out infinite 4s reverse;
    filter: blur(2px);
  }

  .orb-3 {
    width: min(300px, 40vw);
    height: min(300px, 40vw);
    background: radial-gradient(circle, rgba(37, 99, 235, 0.06) 0%, transparent 70%);
    top: 50%;
    left: 30%;
    animation: orb-float 28s ease-in-out infinite 8s;
    filter: blur(4px);
  }

  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(30px, -40px) scale(1.04); }
    66%       { transform: translate(-20px, 20px) scale(0.97); }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: rgba(37, 99, 235, 0.05);
    border: 1px solid rgba(37, 99, 235, 0.15);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    letter-spacing: 0.01em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: badge-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.8); }
  }

  /* Headline */
  .hero-title {
    font-size: clamp(2.75rem, 7vw, 6.5rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
  }

  .hero-line {
    display: block;
    overflow: hidden;
  }

  .hero-em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
    font-size: 1.05em;
    letter-spacing: -0.02em;
  }

  /* Subtext */
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.1875rem);
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 520px;
  }

  .hidden-sm { display: none; }

  @media (min-width: 640px) {
    .hidden-sm { display: block; }
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta-primary  { padding: 1rem 2rem; font-size: 1rem; }
  .hero-cta-secondary { padding: 1rem 2rem; font-size: 1rem; }

  /* Social proof */
  .hero-proof {
    display: flex;
    align-items: center;
  }

  .proof-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.625rem 1.5rem;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .proof-num {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .proof-lbl {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    white-space: nowrap;
  }

  .proof-divider {
    width: 1px;
    height: 28px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .scroll-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    border-radius: 1px;
    overflow: hidden;
    position: relative;
  }

  .scroll-thumb {
    width: 100%;
    height: 50%;
    background: var(--color-accent);
    border-radius: 1px;
    animation: scroll-thumb 1.8s ease-in-out infinite;
  }

  @keyframes scroll-thumb {
    0%   { transform: translateY(-100%); opacity: 0; }
    10%  { opacity: 1; }
    50%  { transform: translateY(100%);  opacity: 1; }
    60%  { transform: translateY(100%);  opacity: 0; }
    61%  { transform: translateY(-100%); opacity: 0; }
    100% { transform: translateY(-100%); opacity: 0; }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 1.25rem 5rem;
      align-items: center;
    }

    .hero-content {
      padding-bottom: 1rem;
    }

    .scroll-indicator { display: none; }
    .orb-3 { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb-1, .orb-2, .orb-3, .badge-dot, .scroll-thumb { animation: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(SplitText, ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced) {
    // ─── Hero entrance timeline ───────────────────────────────────────────
    const tl = gsap.timeline({ delay: 0.2 });

    // Badge
    tl.to(".hero-badge", {
      opacity: 1,
      visibility: "visible",
      y: 0,
      duration: 0.5,
      ease: "power2.out",
    });

    // Headline: split & animate word by word
    const heroLines = document.querySelectorAll<HTMLElement>(".hero-line");

    heroLines.forEach((line, lineIndex) => {
      const split = new SplitText(line, { type: "words" });

      tl.from(
        split.words,
        {
          y: 60,
          opacity: 0,
          rotationX: -25,
          transformOrigin: "0% 50% -30px",
          stagger: 0.07,
          duration: 0.75,
          ease: "power3.out",
        },
        lineIndex === 0 ? "-=0.2" : "-=0.5"
      );
    });

    // Subtext
    tl.to(".hero-sub", {
      opacity: 1,
      visibility: "visible",
      y: 0,
      duration: 0.6,
      ease: "power2.out",
    }, "-=0.3");

    // CTAs
    tl.to(".hero-ctas", {
      opacity: 1,
      visibility: "visible",
      y: 0,
      duration: 0.5,
      ease: "power2.out",
    }, "-=0.3");

    // Proof
    tl.to(".hero-proof", {
      opacity: 1,
      visibility: "visible",
      y: 0,
      duration: 0.45,
      ease: "power2.out",
    }, "-=0.2");

    // Scroll indicator
    tl.to(".scroll-indicator", {
      opacity: 1,
      visibility: "visible",
      duration: 0.4,
    }, "-=0.1");

    // ─── Subtle parallax on orbs ─────────────────────────────────────────
    gsap.to(".orb-1", {
      y: -80,
      ease: "none",
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: 1.5,
      },
    });

    gsap.to(".orb-2", {
      y: -50,
      ease: "none",
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: 2,
      },
    });

  } else {
    // No animation: just show everything
    document.querySelectorAll<HTMLElement>(".gsap-hidden").forEach((el) => {
      el.style.opacity = "1";
      el.style.visibility = "visible";
    });
  }
</script>
