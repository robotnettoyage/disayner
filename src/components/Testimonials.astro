---
import BgOrbs from './BgOrbs.astro';
const testimonials = [
  {
    quote: "Structure claire, parcours logique, très pro. Le site reflète enfin notre positionnement. On a reçu des retours très positifs de nos clients dès la semaine du lancement.",
    author: "Sophie B.",
    role: "Gérante, Agence Lumen",
    initial: "S",
  },
  {
    quote: "Un grand merci à Celio pour le superbe travail réalisé sur le site vitrine de ma société. Celio a été à l'écoute du début à la fin, toujours disponible, sérieux et impliqué. Je recommande Celio les yeux fermés.",
    author: "Yannis Torre",
    role: "Fondateur, Miroiterie VITOR",
    initial: "Y",
  },
  {
    quote: "Réactivité, professionnalisme et résultats. Nos fiches produits sont maintenant bien référencées sur les 3 langues. Je recommande sans hésitation.",
    author: "Emma D.",
    role: "E-commerce Manager, Love at Me",
    initial: "E",
  },
];
---

<section class="testimonials-section" id="temoignages" aria-label="Témoignages clients">
  <BgOrbs orbs={[
    { type: 'filled', x: '80%', y: '15%', size: '150px', dur: '10s' },
    { type: 'ring',   x: '15%', y: '75%', size: '100px', dur: '13s' },
  ]} />
  <div class="testimonials-inner">
    <div class="testimonials-header section-header-anim">
      <p class="section-label">Témoignages</p>
      <h2>Ce que disent<br /><em class="font-serif">nos clients.</em></h2>
    </div>

    <div class="carousel-wrapper">
      <!-- Decorative guillemets -->
      <div class="guillemets" aria-hidden="true">«</div>

      <div class="slides-container" role="region" aria-label="Témoignages" aria-live="polite">
        {testimonials.map((t, i) => (
          <div
            class={`testimonial-slide ${i === 0 ? "slide-active" : ""}`}
            aria-hidden={i !== 0 ? "true" : "false"}
            role="group"
            aria-roledescription="slide"
            aria-label={`Témoignage ${i + 1} sur ${testimonials.length}`}
          >
            <div class="testimonial-stars" aria-label="5 étoiles sur 5">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="testimonial-quote">
              <p>{t.quote}</p>
            </blockquote>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true">{t.initial}</div>
              <div class="testimonial-author-info">
                <cite class="testimonial-author">{t.author}</cite>
                <span class="testimonial-role">{t.role}</span>
              </div>
            </footer>
          </div>
        ))}
      </div>

      <!-- Progress bar -->
      <div class="carousel-progress" aria-hidden="true">
        <div class="carousel-progress-bar"></div>
      </div>

      <!-- Navigation row -->
      <div class="carousel-controls">
        <button class="carousel-arrow arrow-prev" aria-label="Témoignage précédent">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>

        <nav class="carousel-nav" aria-label="Navigation témoignages">
          {testimonials.map((_, i) => (
            <button
              class={`carousel-dot ${i === 0 ? "dot-active" : ""}`}
              aria-label={`Aller au témoignage ${i + 1}`}
              aria-current={i === 0 ? "true" : "false"}
              data-index={i}
            ></button>
          ))}
        </nav>

        <button class="carousel-arrow arrow-next" aria-label="Témoignage suivant">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    position: relative;
    padding: 7rem 2rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .testimonials-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .testimonials-header { text-align: center; }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .testimonials-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .testimonials-header em {
    font-style: italic;
    color: var(--color-text-secondary);
  }

  /* Carousel */
  .carousel-wrapper {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .guillemets {
    position: absolute;
    top: -2rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10rem;
    line-height: 1;
    font-family: var(--font-serif);
    color: var(--color-accent);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .slides-container {
    position: relative;
  }

  /* Slides */
  .testimonial-slide {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1rem 0;
    /* Hidden by default */
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: none;
  }

  .testimonial-slide.slide-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .testimonial-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-text-primary);
    line-height: 1.55;
    max-width: 720px;
    text-align: center;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .testimonial-author-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .testimonial-author {
    font-style: normal;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
  }

  .testimonial-role {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  /* Stars */
  .testimonial-stars {
    display: flex;
    gap: 3px;
    justify-content: center;
    margin-bottom: 0.25rem;
  }

  /* Progress bar */
  .carousel-progress {
    width: 100%;
    max-width: 480px;
    margin: 2rem auto 0;
    height: 2px;
    background: var(--color-border);
    border-radius: 1px;
    overflow: hidden;
  }

  .carousel-progress-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 1px;
    width: 0%;
    transition: none;
  }

  /* Controls row */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  /* Navigation dots */
  .carousel-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, width 0.3s ease;
  }

  .carousel-dot.dot-active {
    background: var(--color-accent);
    width: 22px;
    border-radius: 4px;
  }

  .carousel-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .carousel-arrow:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .testimonials-section { padding: 4rem 1.25rem; }
    .guillemets { font-size: 6rem; }
    .carousel-controls { gap: 1rem; }
  }
</style>

<script>
  import { gsap } from "gsap";

  // Carousel logic
  const slides = Array.from(document.querySelectorAll<HTMLElement>(".testimonial-slide"));
  const dots   = Array.from(document.querySelectorAll<HTMLElement>(".carousel-dot"));
  const prevBtn = document.querySelector<HTMLButtonElement>(".arrow-prev");
  const nextBtn = document.querySelector<HTMLButtonElement>(".arrow-next");

  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;
  const AUTOPLAY_MS = 6000;
  const progressBar = document.querySelector<HTMLElement>(".carousel-progress-bar");
  let progressAnim: ReturnType<typeof gsap.to> | null = null;

  function animateProgress() {
    if (!progressBar) return;
    if (progressAnim) progressAnim.kill();
    gsap.set(progressBar, { width: "0%" });
    progressAnim = gsap.to(progressBar, {
      width: "100%",
      duration: AUTOPLAY_MS / 1000,
      ease: "none",
    });
  }

  function goTo(index: number) {
    const prev = slides[current];
    const prevDot = dots[current];

    current = (index + slides.length) % slides.length;
    const next = slides[current];
    const nextDot = dots[current];

    prevDot.classList.remove("dot-active");
    prevDot.setAttribute("aria-current", "false");
    nextDot.classList.add("dot-active");
    nextDot.setAttribute("aria-current", "true");

    gsap.to(prev, {
      opacity: 0,
      y: -14,
      duration: 0.32,
      ease: "power2.in",
      onComplete: () => {
        prev.classList.remove("slide-active");
        prev.setAttribute("aria-hidden", "true");
        prev.style.position = "absolute";
        prev.style.visibility = "hidden";

        next.classList.add("slide-active");
        next.setAttribute("aria-hidden", "false");
        next.style.position = "relative";
        next.style.visibility = "visible";
        gsap.fromTo(next,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.42, ease: "power2.out" }
        );
      },
    });
  }

  function startAutoplay() {
    animateProgress();
    autoplayTimer = setInterval(() => {
      goTo(current + 1);
      animateProgress();
    }, AUTOPLAY_MS);
  }

  function resetAutoplay() {
    clearInterval(autoplayTimer);
    startAutoplay();
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => { goTo(i); resetAutoplay(); });
  });

  prevBtn?.addEventListener("click", () => { goTo(current - 1); resetAutoplay(); });
  nextBtn?.addEventListener("click", () => { goTo(current + 1); resetAutoplay(); });

  const carouselWrapper = document.querySelector(".carousel-wrapper");
  carouselWrapper?.addEventListener("mouseenter", () => {
    clearInterval(autoplayTimer);
    if (progressAnim) progressAnim.pause();
  });
  carouselWrapper?.addEventListener("mouseleave", () => {
    resetAutoplay();
  });

  startAutoplay();
</script>
