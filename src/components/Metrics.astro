---
import BgDots from './BgDots.astro';
const metrics = [
  { value: 50,    suffix: "+",   label: "Projets livrés",          sublabel: "depuis 2021" },
  { value: 200,   suffix: "%",   label: "Trafic moyen généré",     sublabel: "sur nos projets SEO" },
  { value: 98,    suffix: "",    label: "Lighthouse Performance",   sublabel: "score moyen" },
  { value: 4.9,   suffix: "/5",  label: "Satisfaction clients",    sublabel: "avis certifiés" },
];
---

<section class="metrics-section" id="chiffres" aria-label="Nos chiffres clés">
  <BgDots pulseCount={5} variant="accent" />
  <div class="metrics-inner">
    <div class="metrics-header section-header-anim">
      <p class="section-label">En chiffres</p>
      <h2>Des résultats <em class="font-serif">mesurables</em></h2>
    </div>

    <div class="metrics-grid" role="list">
      {metrics.map((metric, i) => (
        <div class="metric-item" role="listitem">
          <div class="metric-number-wrapper">
            <span
              class="metric-number"
              data-value={metric.value}
              data-suffix={metric.suffix}
              aria-label={`${metric.value}${metric.suffix} ${metric.label}`}
            >
              0{metric.suffix}
            </span>
          </div>
          <p class="metric-label">{metric.label}</p>
          <p class="metric-sublabel">{metric.sublabel}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metrics-section {
    position: relative;
    padding: 7rem 2rem;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-accent-soft) 50%, var(--color-surface) 100%);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  /* Decorative background circle */
  .metrics-section::before {
    content: "";
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(37,99,235,0.07) 0%, transparent 70%);
    top: -100px;
    right: 8%;
    pointer-events: none;
    border-radius: 50%;
  }

  .metrics-inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .metrics-header {
    text-align: center;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .metrics-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .metrics-header em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    overflow: hidden;
  }

  .metric-item {
    padding: 3rem 2rem;
    text-align: center;
    border-right: 1px solid var(--color-border);
    transition: background 0.3s ease;
  }

  .metric-item:hover {
    background: rgba(37,99,235,0.03);
  }

  .metric-item:last-child {
    border-right: none;
  }

  .metric-number-wrapper {
    margin-bottom: 0.75rem;
  }

  .metric-number {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.04em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.35rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .metric-sublabel {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .metrics-section { padding: 5rem 1.5rem; }

    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      border-radius: 16px;
    }

    .metric-item:nth-child(2) { border-right: none; }
    .metric-item:nth-child(1),
    .metric-item:nth-child(2) {
      border-bottom: 1px solid var(--color-border);
    }
  }

  @media (max-width: 480px) {
    .metrics-grid { grid-template-columns: 1fr; }

    .metric-item {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .metric-item:last-child { border-bottom: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Counter animation
  const counters = document.querySelectorAll<HTMLElement>(".metric-number");

  counters.forEach((el) => {
    const target = parseFloat(el.dataset.value ?? "0");
    const suffix = el.dataset.suffix ?? "";
    const isDecimal = !Number.isInteger(target);

    const obj = { val: 0 };

    gsap.to(obj, {
      val: target,
      duration: 2,
      ease: "power2.out",
      onUpdate() {
        el.textContent = isDecimal
          ? obj.val.toFixed(1) + suffix
          : Math.round(obj.val) + suffix;
      },
      scrollTrigger: {
        trigger: el,
        start: "top 85%",
        once: true,
      },
    });
  });

  // Stagger metric items
  gsap.from(".metric-item", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.1,
    ease: "power2.out",
    clearProps: "transform",
    scrollTrigger: {
      trigger: ".metrics-grid",
      start: "top 80%",
    },
  });
</script>
