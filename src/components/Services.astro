---
---

<section class="services-section" id="services" aria-label="Nos services">
  <div class="services-inner">
    <div class="services-header will-animate">
      <p class="section-label">Ce que nous faisons</p>
      <h2>Trois expertises,<br /><em class="font-serif">un seul objectif.</em></h2>
      <p class="services-sub">Des solutions web sur-mesure qui combinent design, performance et visibilité.</p>
    </div>

    <div class="services-grid" role="list">

      <!-- Grande carte : Création web -->
      <article class="service-card service-card--large" role="listitem" aria-label="Service : Création de sites web">
        <!-- Browser mockup -->
        <div class="browser-mockup" aria-hidden="true">
          <div class="browser-chrome">
            <span class="browser-dot dot-red"></span>
            <span class="browser-dot dot-yellow"></span>
            <span class="browser-dot dot-green"></span>
            <div class="browser-url">
              <span>disayner.com</span>
            </div>
          </div>
          <div class="browser-content">
            <div class="mock-header">
              <div class="mock-logo"></div>
              <div class="mock-nav">
                <div class="mock-line w-8"></div>
                <div class="mock-line w-6"></div>
                <div class="mock-line w-10"></div>
              </div>
            </div>
            <div class="mock-hero">
              <div class="mock-title"></div>
              <div class="mock-title w-3/4"></div>
              <div class="mock-subtitle"></div>
              <div class="mock-btn"></div>
            </div>
            <div class="mock-cards">
              <div class="mock-card"></div>
              <div class="mock-card"></div>
              <div class="mock-card"></div>
            </div>
          </div>
        </div>

        <div class="card-content">
          <div class="card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="m9 9 3 3-3 3"/>
              <path d="M13 15h3"/>
            </svg>
          </div>
          <h3>Création de sites web</h3>
          <p class="card-desc">Sites vitrines, e-commerce et landing pages sur-mesure. Du design à la mise en ligne, chaque projet est pensé pour convertir.</p>
          <div class="card-tags">
            <span class="tag">WordPress</span>
            <span class="tag">Shopify</span>
            <span class="tag">Webflow</span>
            <span class="tag">Sur-mesure</span>
          </div>
          <a href="#contact" class="card-cta hover-underline">En savoir plus →</a>
        </div>
      </article>

      <!-- Carte SEO -->
      <article class="service-card service-card--seo" role="listitem" aria-label="Service : Référencement SEO">
        <div class="card-content">
          <!-- Mini chart SVG -->
          <div class="seo-chart" aria-hidden="true">
            <svg viewBox="0 0 120 60" xmlns="http://www.w3.org/2000/svg" class="chart-svg">
              <defs>
                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#2563EB" stop-opacity="0.15"/>
                  <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path class="chart-area" d="M0,55 L15,48 L30,42 L45,35 L60,28 L75,18 L90,12 L105,7 L120,4 L120,60 L0,60 Z" fill="url(#chartGrad)"/>
              <path class="chart-line" d="M0,55 L15,48 L30,42 L45,35 L60,28 L75,18 L90,12 L105,7 L120,4" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="120" cy="4" r="4" fill="#2563EB"/>
            </svg>
            <div class="chart-labels">
              <span class="chart-label">Jan</span>
              <span class="chart-label">Avr</span>
              <span class="chart-label">Juil</span>
            </div>
          </div>

          <div class="card-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            En partenariat avec SoRank
          </div>

          <div class="card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <h3>Référencement SEO</h3>
          <p class="card-desc">Stratégie SEO, contenus optimisés, résultats mesurables. Visibilité maximale sur Google.</p>
          <div class="card-tags">
            <span class="tag">Audit</span>
            <span class="tag">Contenus</span>
            <span class="tag">Technique</span>
            <span class="tag">Suivi</span>
          </div>
          <a href="#contact" class="card-cta hover-underline">En savoir plus →</a>
        </div>
      </article>

      <!-- Carte Maintenance -->
      <article class="service-card service-card--maintenance" role="listitem" aria-label="Service : Maintenance web">
        <div class="card-content">
          <div class="maintenance-icon-wrapper" aria-hidden="true">
            <svg class="shield-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path class="check-path" d="m9 12 2 2 4-4"/>
            </svg>
          </div>

          <div class="card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Maintenance web</h3>
          <p class="card-desc">Mises à jour, sécurité renforcée et performance continue. Votre site reste au top, sans effort de votre part.</p>
          <div class="card-tags">
            <span class="tag">Sécurité</span>
            <span class="tag">Updates</span>
            <span class="tag">Monitoring</span>
          </div>
          <a href="#contact" class="card-cta hover-underline">En savoir plus →</a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 7rem 2rem;
    background: var(--color-background);
  }

  .services-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .services-header { max-width: 600px; }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .services-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .services-header em {
    font-style: italic;
    color: var(--color-accent);
  }

  .services-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* Bento Grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
  }

  /* Cards base */
  .service-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
    cursor: default;
  }

  .service-card:hover {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  /* Large card */
  .service-card--large {
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
  }

  /* Browser mockup */
  .browser-mockup {
    flex-shrink: 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .browser-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: #fff;
  }

  .browser-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-red    { background: #FF5F57; }
  .dot-yellow { background: #FEBC2E; }
  .dot-green  { background: #28C840; }

  .browser-url {
    flex: 1;
    background: var(--color-surface);
    border-radius: 6px;
    padding: 0.3rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .browser-url span {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .browser-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 200px;
  }

  .mock-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mock-logo {
    width: 60px;
    height: 10px;
    background: var(--color-border);
    border-radius: 4px;
  }

  .mock-nav {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .mock-line {
    height: 8px;
    background: var(--color-border);
    border-radius: 3px;
  }

  .w-6  { width: 24px; }
  .w-8  { width: 32px; }
  .w-10 { width: 40px; }

  .mock-hero {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0.5rem 0;
  }

  .mock-title {
    height: 14px;
    background: var(--color-text-primary);
    border-radius: 4px;
    opacity: 0.15;
    width: 100%;
  }

  .mock-title.w-3\/4 { width: 75%; }

  .mock-subtitle {
    height: 8px;
    background: var(--color-border);
    border-radius: 3px;
    width: 85%;
  }

  .mock-btn {
    width: 80px;
    height: 28px;
    background: var(--color-accent);
    border-radius: 100px;
    margin-top: 4px;
    opacity: 0.8;
  }

  .mock-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .mock-card {
    height: 48px;
    background: var(--color-border);
    border-radius: 8px;
    opacity: 0.6;
  }

  /* Card content */
  .card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .card-icon {
    width: 44px;
    height: 44px;
    background: var(--color-accent-soft);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .service-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  .card-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    padding-bottom: 1px;
    align-self: flex-start;
    margin-top: auto;
  }

  /* SEO card specifics */
  .seo-chart {
    background: var(--color-accent-soft);
    border-radius: 12px;
    padding: 1rem 1rem 0.5rem;
    margin-bottom: 0.25rem;
  }

  .chart-svg { width: 100%; height: auto; }

  .chart-area {
    opacity: 0;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.8s ease, opacity 0.5s ease;
  }

  .chart-line {
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    padding: 0 0.25rem;
  }

  .chart-label {
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .card-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37, 99, 235, 0.15);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    align-self: flex-start;
  }

  /* Maintenance card specifics */
  .maintenance-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: var(--color-accent-soft);
    border-radius: 50%;
    margin-bottom: 0.25rem;
  }

  .shield-icon { filter: drop-shadow(0 4px 12px rgba(37, 99, 235, 0.2)); }

  .check-path {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card--large { grid-row: auto; }
  }

  @media (max-width: 480px) {
    .services-section { padding: 4rem 1.25rem; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Header
  gsap.from(".services-header", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
    scrollTrigger: { trigger: ".services-section", start: "top 75%" },
  });

  // Cards stagger
  gsap.from(".service-card", {
    y: 60,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: { trigger: ".services-grid", start: "top 75%" },
  });

  // SEO chart line animation
  if (!prefersReduced) {
    const chartLine = document.querySelector<SVGPathElement>(".chart-line");
    const chartArea = document.querySelector<SVGPathElement>(".chart-area");

    if (chartLine && chartArea) {
      gsap.to(chartLine, {
        strokeDashoffset: 0,
        duration: 1.5,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".service-card--seo",
          start: "top 70%",
        },
      });

      gsap.to(chartArea, {
        opacity: 1,
        duration: 0.5,
        delay: 0.3,
        scrollTrigger: {
          trigger: ".service-card--seo",
          start: "top 70%",
        },
      });

      gsap.to(chartArea, {
        scaleY: 1,
        duration: 1.2,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".service-card--seo",
          start: "top 70%",
        },
      });
    }

    // Shield check animation
    const checkPath = document.querySelector<SVGPathElement>(".check-path");
    if (checkPath) {
      gsap.to(checkPath, {
        strokeDashoffset: 0,
        duration: 0.8,
        ease: "power2.out",
        delay: 0.3,
        scrollTrigger: {
          trigger: ".service-card--maintenance",
          start: "top 70%",
        },
      });
    }
  }
</script>
