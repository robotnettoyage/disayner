---
---

<section class="services-section" id="services" aria-label="Nos services">
  <div class="services-inner">

    <!-- Header — visible by default, no will-animate -->
    <div class="services-header">
      <p class="section-label">Ce que nous faisons</p>
      <h2>Trois expertises,<br /><em class="font-serif">un seul objectif.</em></h2>
      <p class="services-sub">Des solutions web sur-mesure qui combinent design, performance et visibilité.</p>
    </div>

    <div class="services-grid">

      <!-- ── Card 1: Création web ── -->
      <article class="service-card card-creation service-card-main" aria-label="Service : Création de sites web">
        <div class="card-body">

          <!-- Icon + eyebrow -->
          <div class="card-icon-row">
            <div class="card-icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="m9 9 3 3-3 3"/><path d="M13 15h3"/>
              </svg>
            </div>
            <span class="card-eyebrow">Service principal</span>
          </div>

          <h3>Création de sites web</h3>
          <p class="card-desc">Sites vitrines, e-commerce &amp; landing pages. Chaque projet est conçu pour convertir.</p>

          <!-- Stacked screens visual -->
          <div class="screens-stack" aria-hidden="true" style="position:relative; height:220px; margin:20px 0;">

            <!-- Screen 3 (BACK) — Landing page -->
            <div class="screen screen-back" style="position:absolute; width:80%; left:58%; bottom:35px; transform:translateX(-50%) scale(0.85); opacity:0.6; z-index:1; background:white; border-radius:10px; border:1px solid rgba(0,0,0,0.08); box-shadow:0 4px 15px rgba(0,0,0,0.05); overflow:hidden; transition:all 0.6s cubic-bezier(0.25,0.46,0.45,0.94);">
              <div style="height:24px; background:#F5F5F0; border-bottom:1px solid #EEEEEA; display:flex; align-items:center; padding:0 8px; gap:4px;">
                <span style="width:7px;height:7px;border-radius:50%;background:#FF5F57;display:block;"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#FEBC2E;display:block;"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#28C840;display:block;"></span>
              </div>
              <div style="padding:8px;">
                <div style="height:55px; background:linear-gradient(160deg,#1E3A5F,#2563EB); border-radius:5px; display:flex; align-items:center; justify-content:center;">
                  <div style="width:45px;height:10px;background:rgba(255,255,255,0.8);border-radius:4px;"></div>
                </div>
              </div>
            </div>

            <!-- Screen 2 (MIDDLE) — E-commerce -->
            <div class="screen screen-mid" style="position:absolute; width:80%; left:54%; bottom:18px; transform:translateX(-50%) scale(0.92); opacity:0.8; z-index:2; background:white; border-radius:10px; border:1px solid rgba(0,0,0,0.08); box-shadow:0 4px 15px rgba(0,0,0,0.05); overflow:hidden; transition:all 0.6s cubic-bezier(0.25,0.46,0.45,0.94);">
              <div style="height:24px; background:#F5F5F0; border-bottom:1px solid #EEEEEA; display:flex; align-items:center; padding:0 8px; gap:4px;">
                <span style="width:7px;height:7px;border-radius:50%;background:#FF5F57;display:block;"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#FEBC2E;display:block;"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#28C840;display:block;"></span>
              </div>
              <div style="padding:8px;">
                <div style="height:6px;width:35%;background:#E8E8E3;border-radius:3px;margin-bottom:8px;"></div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:5px;">
                  <div style="border-radius:4px;overflow:hidden;border:1px solid #F0F0EB;"><div style="height:28px;background:#EFF6FF;"></div><div style="padding:4px;"><div style="height:3px;width:60%;background:#E0E0E0;border-radius:2px;"></div></div></div>
                  <div style="border-radius:4px;overflow:hidden;border:1px solid #F0F0EB;"><div style="height:28px;background:#FEF3E2;"></div><div style="padding:4px;"><div style="height:3px;width:50%;background:#E0E0E0;border-radius:2px;"></div></div></div>
                  <div style="border-radius:4px;overflow:hidden;border:1px solid #F0F0EB;"><div style="height:28px;background:#F0FDF4;"></div><div style="padding:4px;"><div style="height:3px;width:55%;background:#E0E0E0;border-radius:2px;"></div></div></div>
                  <div style="border-radius:4px;overflow:hidden;border:1px solid #F0F0EB;"><div style="height:28px;background:#FDF2F8;"></div><div style="padding:4px;"><div style="height:3px;width:45%;background:#E0E0E0;border-radius:2px;"></div></div></div>
                </div>
              </div>
            </div>

            <!-- Screen 1 (FRONT) — Showcase site -->
            <div class="screen screen-front" style="position:absolute; width:80%; left:50%; bottom:0; transform:translateX(-50%); z-index:3; background:white; border-radius:10px; border:1px solid rgba(0,0,0,0.08); box-shadow:0 6px 20px rgba(0,0,0,0.07); overflow:hidden; transition:all 0.6s cubic-bezier(0.25,0.46,0.45,0.94);">
              <div style="height:28px; background:#F5F5F0; border-bottom:1px solid #EEEEEA; display:flex; align-items:center; padding:0 10px; gap:5px;">
                <span style="width:8px;height:8px;border-radius:50%;background:#FF5F57;display:block;"></span>
                <span style="width:8px;height:8px;border-radius:50%;background:#FEBC2E;display:block;"></span>
                <span style="width:8px;height:8px;border-radius:50%;background:#28C840;display:block;"></span>
                <div style="background:white;border-radius:4px;padding:2px 10px;font-size:9px;color:#999;margin-left:8px;flex:1;max-width:140px;">disayner.com</div>
              </div>
              <div style="padding:8px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                  <div style="width:18px;height:5px;background:#E0E0E0;border-radius:2px;"></div>
                  <div style="display:flex;gap:6px;">
                    <div style="width:14px;height:3px;background:#E8E8E3;border-radius:2px;"></div>
                    <div style="width:14px;height:3px;background:#E8E8E3;border-radius:2px;"></div>
                    <div style="width:14px;height:3px;background:#E8E8E3;border-radius:2px;"></div>
                  </div>
                </div>
                <div style="height:40px;background:linear-gradient(135deg,#2563EB,#3B82F6);border-radius:5px;padding:8px 10px;margin-bottom:6px;">
                  <div style="height:4px;width:55%;background:rgba(255,255,255,0.5);border-radius:2px;margin-bottom:4px;"></div>
                  <div style="height:3px;width:35%;background:rgba(255,255,255,0.3);border-radius:2px;margin-bottom:5px;"></div>
                  <div style="width:30px;height:8px;background:rgba(255,255,255,0.85);border-radius:3px;"></div>
                </div>
                <div style="display:flex;gap:4px;">
                  <div style="flex:1;height:30px;background:#FAFAF9;border:1px solid #F0F0EB;border-radius:3px;padding:5px;"><div style="width:8px;height:8px;background:#EFF6FF;border-radius:2px;margin-bottom:3px;"></div><div style="height:2px;width:70%;background:#E8E8E3;border-radius:1px;"></div></div>
                  <div style="flex:1;height:30px;background:#FAFAF9;border:1px solid #F0F0EB;border-radius:3px;padding:5px;"><div style="width:8px;height:8px;background:#EFF6FF;border-radius:2px;margin-bottom:3px;"></div><div style="height:2px;width:60%;background:#E8E8E3;border-radius:1px;"></div></div>
                  <div style="flex:1;height:30px;background:#FAFAF9;border:1px solid #F0F0EB;border-radius:3px;padding:5px;"><div style="width:8px;height:8px;background:#EFF6FF;border-radius:2px;margin-bottom:3px;"></div><div style="height:2px;width:65%;background:#E8E8E3;border-radius:1px;"></div></div>
                </div>
              </div>
            </div>

            <!-- Floating labels (visible on hover) -->
            <span class="screen-label" style="position:absolute;bottom:-8px;left:12%;font-size:10px;font-weight:600;color:#2563EB;background:#EFF6FF;padding:3px 10px;border-radius:5px;opacity:0;transform:translateY(4px);transition:all 0.4s ease;pointer-events:none;z-index:10;">Site vitrine</span>
            <span class="screen-label" style="position:absolute;bottom:16px;right:2%;font-size:10px;font-weight:600;color:#2563EB;background:#EFF6FF;padding:3px 10px;border-radius:5px;opacity:0;transform:translateY(4px);transition:all 0.4s ease 0.1s;pointer-events:none;z-index:10;">E-commerce</span>
            <span class="screen-label" style="position:absolute;top:8px;right:0%;font-size:10px;font-weight:600;color:#2563EB;background:#EFF6FF;padding:3px 10px;border-radius:5px;opacity:0;transform:translateY(4px);transition:all 0.4s ease 0.2s;pointer-events:none;z-index:10;">Landing page</span>
          </div>

          <div class="card-tags">
            <span class="tag">WordPress</span>
            <span class="tag">Shopify</span>
            <span class="tag">Webflow</span>
            <span class="tag">Sur-mesure</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 2: SEO ── -->
      <article class="service-card card-seo service-card-small" aria-label="Service : Référencement SEO">
        <div class="card-body">

          <!-- Badge first -->
          <div class="sorank-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            En partenariat avec SoRank
          </div>

          <h3>Référencement SEO</h3>
          <p class="card-desc">Stratégie de visibilité, contenus optimisés et résultats mesurables sur Google.</p>

          <!-- Chart -->
          <div class="seo-chart-container" aria-hidden="true">
            <div class="chart-badge">+200% trafic</div>
            <svg viewBox="0 0 280 100" class="chart-svg seo-chart-svg">
              <defs>
                <linearGradient id="seoGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#2563EB" stop-opacity="0.12"/>
                  <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <line x1="0" y1="25" x2="280" y2="25" stroke="#EEEEEA" stroke-width="0.5"/>
              <line x1="0" y1="50" x2="280" y2="50" stroke="#EEEEEA" stroke-width="0.5"/>
              <line x1="0" y1="75" x2="280" y2="75" stroke="#EEEEEA" stroke-width="0.5"/>
              <path d="M0,88 C30,85 50,78 90,65 S150,40 190,28 S250,12 280,8 V100 H0 Z" fill="url(#seoGrad)"/>
              <path d="M0,88 C30,85 50,78 90,65 S150,40 190,28 S250,12 280,8" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" class="chart-line"/>
              <circle cx="90"  cy="65" r="4" fill="#2563EB"/>
              <circle cx="90"  cy="65" r="2" fill="white"/>
              <circle cx="190" cy="28" r="4" fill="#2563EB"/>
              <circle cx="190" cy="28" r="2" fill="white"/>
              <circle cx="280" cy="8"  r="5" fill="#2563EB" class="pulse-dot"/>
              <circle cx="280" cy="8"  r="2.5" fill="white"/>
            </svg>
            <div class="chart-labels" aria-hidden="true">
              <span>Jan</span><span>Avr</span><span>Juil</span><span>Oct</span>
            </div>
          </div>

          <div class="card-tags">
            <span class="tag">Audit</span>
            <span class="tag">Contenus</span>
            <span class="tag">Technique</span>
            <span class="tag">Suivi</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 3: Maintenance ── -->
      <article class="service-card card-maintenance service-card-small" aria-label="Service : Maintenance web">
        <div class="card-body">

          <div class="shield-wrap icon-pulse" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path class="check-path" d="m9 12 2 2 4-4"/>
            </svg>
          </div>

          <h3>Maintenance web</h3>
          <p class="card-desc">Votre site reste rapide, sécurisé et à jour. Zéro stress.</p>

          <!-- Feature rows with checkmark circles -->
          <div class="feature-rows">
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Mises à jour de sécurité</span>
            </div>
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Monitoring 24/7</span>
            </div>
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Sauvegardes quotidiennes</span>
            </div>
          </div>

          <div class="card-tags">
            <span class="tag">Sécurité</span>
            <span class="tag">Updates</span>
            <span class="tag">Monitoring</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 7rem 2rem;
    background: var(--color-background);
    position: relative;
    overflow: hidden;
  }

  .services-section::before {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.03), transparent 70%);
    top: -100px;
    left: -100px;
    pointer-events: none;
    border-radius: 50%;
  }

  .services-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .services-header { max-width: 600px; }

  .section-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .services-header h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .services-header em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
    font-weight: 400;
  }

  .services-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* ── Grid ────────────────────────────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 20px;
  }

  .card-creation { grid-row: 1 / 3; }

  /* ── Card base ───────────────────────────────────────────────────────────── */
  .service-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.3s ease;
    cursor: default;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #2563EB, #60A5FA);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 60px rgba(37, 99, 235, 0.08), 0 8px 20px rgba(0, 0, 0, 0.04);
    border-color: rgba(37, 99, 235, 0.15);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .card-body {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  /* ── Icon row + eyebrow ──────────────────────────────────────────────────── */
  .card-icon-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card-icon-wrap {
    width: 36px;
    height: 36px;
    background: var(--color-accent-soft);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* ── Typography ──────────────────────────────────────────────────────────── */
  .service-card h3 {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.68;
  }

  /* ── Tags ────────────────────────────────────────────────────────────────── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    background: #F5F5F0;
    color: #6B6B67;
    border-radius: 100px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .service-card:hover .tag {
    background: #EFF6FF;
    color: #2563EB;
  }

  .card-cta {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .card-cta:hover { gap: 12px; }

  /* ── Stacked Screens (Card 1) ────────────────────────────────────────────── */
  /* Screens use inline styles for position/opacity (avoids Astro CSS scoping issues).
     These rules handle hover effects only. */

  .service-card-main:hover .screen-front {
    transform: translateX(-55%) rotate(-2deg) !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
  }

  .service-card-main:hover .screen-mid {
    transform: translateX(-45%) scale(0.92) translateY(-8px) !important;
    opacity: 1 !important;
  }

  .service-card-main:hover .screen-back {
    transform: translateX(-35%) scale(0.85) rotate(2deg) translateY(-16px) !important;
    opacity: 0.9 !important;
  }

  .service-card-main:hover .screen-label {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ── Chart (Card 2) ──────────────────────────────────────────────────────── */
  .seo-chart-container {
    background: #FAFAF9;
    border-radius: 12px;
    padding: 16px 14px 6px;
    position: relative;
    border: 1px solid var(--color-border);
    margin: 4px 0;
  }

  .chart-svg {
    width: 100%;
    display: block;
  }

  .chart-line {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: drawChart 2s ease-out forwards;
    animation-play-state: paused;
  }

  .chart-line.animate {
    animation-play-state: running;
  }

  @keyframes drawChart {
    to { stroke-dashoffset: 0; }
  }

  .pulse-dot {
    animation: pulseDot 2.5s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; r: 5; }
    50%       { opacity: 0.6; r: 7; }
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    padding: 4px 2px 0;
  }

  .chart-labels span {
    font-size: 10px;
    color: var(--color-text-secondary);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .chart-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: white;
    border-radius: 7px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 700;
    color: #2563EB;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  /* ── SoRank badge ────────────────────────────────────────────────────────── */
  .sorank-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37,99,235,0.2);
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    align-self: flex-start;
  }

  /* ── Shield (Card 3) ─────────────────────────────────────────────────────── */
  .shield-wrap {
    width: 64px;
    height: 64px;
    background: var(--color-accent-soft);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-pulse {
    animation: pulse-soft 3s ease-in-out infinite;
  }

  @keyframes pulse-soft {
    0%, 100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.1); }
    50%       { box-shadow: 0 0 0 12px rgba(37, 99, 235, 0); }
  }

  .check-path {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    transition: stroke-dashoffset 0.6s ease 0.3s;
  }

  .card-maintenance:hover .check-path {
    stroke-dashoffset: 0;
  }

  /* ── Feature rows (Card 3) ───────────────────────────────────────────────── */
  .feature-rows {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }

  .feature-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    background: #EFF6FF;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transform: scale(1);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .service-card:hover .feature-row:nth-child(1) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0s; }
  .service-card:hover .feature-row:nth-child(2) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0.12s; }
  .service-card:hover .feature-row:nth-child(3) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0.24s; }

  @keyframes checkPop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.25); background: #DBEAFE; }
    100% { transform: scale(1); background: #EFF6FF; }
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */

  /* Tablet: card-creation full width top, SEO + Maintenance side by side below */
  @media (min-width: 768px) and (max-width: 1023px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .card-creation {
      grid-column: 1 / 3;
      grid-row: 1;
    }

    .card-seo    { grid-row: 2; grid-column: 1; }
    .card-maintenance { grid-row: 2; grid-column: 2; }
  }

  /* Mobile: all stacked */
  @media (max-width: 767px) {
    .services-section { padding: 4rem 1.25rem; }

    .services-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 16px;
    }

    .card-creation { grid-row: auto; }
    .card-body { padding: 28px 24px; }

    /* Screens: default to fanned-out state on mobile (no hover available) */
    .screen-front { transform: translateX(-55%) rotate(-2deg) !important; }
    .screen-mid   { bottom: 12px !important; transform: translateX(-45%) scale(0.92) translateY(-8px) !important; opacity: 1 !important; }
    .screen-back  { bottom: 24px !important; transform: translateX(-35%) scale(0.85) rotate(2deg) translateY(-16px) !important; opacity: 0.9 !important; }
    .screen-label { opacity: 1 !important; transform: translateY(0) !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-pulse, .pulse-dot, .chart-line { animation: none; }
    .service-card, .check-icon { transition: none; }
    .screen-front, .screen-mid, .screen-back { transition: none !important; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Card 1 enters first
  if (!prefersReduced) {
    gsap.fromTo(".service-card-main",
      { y: 40, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
        scrollTrigger: { trigger: ".services-grid", start: "top 80%" },
      }
    );

    // Cards 2 and 3 staggered, 0.2s after card 1
    gsap.fromTo(".service-card-small",
      { y: 40, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
        stagger: 0.15, delay: 0.2,
        scrollTrigger: { trigger: ".services-grid", start: "top 80%" },
      }
    );
  }

  // Animate chart line when it enters the viewport
  const chartLine = document.querySelector('.chart-line');
  if (chartLine) {
    const chartObs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        chartLine.classList.add('animate');
        chartObs.disconnect();
      }
    }, { threshold: 0.3 });
    chartObs.observe(chartLine.closest('svg'));
  }
</script>
