---
---

<section class="services-section" id="services" aria-label="Nos services">
  <div class="services-inner">

    <!-- Header — visible by default, no will-animate -->
    <div class="services-header">
      <p class="section-label">Ce que nous faisons</p>
      <h2>Trois expertises,<br /><em class="font-serif">un seul objectif.</em></h2>
      <p class="services-sub">Des solutions web sur-mesure qui combinent design, performance et visibilité.</p>
    </div>

    <div class="services-grid">

      <!-- ── Card 1: Création web ── -->
      <article class="service-card card-creation service-card-main" aria-label="Service : Création de sites web">
        <div class="card-body">

          <!-- Icon + eyebrow -->
          <div class="card-icon-row">
            <div class="card-icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="m9 9 3 3-3 3"/><path d="M13 15h3"/>
              </svg>
            </div>
            <span class="card-eyebrow">Service principal</span>
          </div>

          <h3>Création de sites web</h3>
          <p class="card-desc">Sites vitrines, e-commerce &amp; landing pages. Chaque projet est conçu pour convertir.</p>

          <!-- Stacked screens visual -->
          <div class="screens-stack" aria-hidden="true">

            <!-- Screen 3 (back) — Landing page -->
            <div class="screen screen-3">
              <div class="screen-bar"><span></span><span></span><span></span></div>
              <div class="screen-body">
                <div class="s-hero-gradient"><div class="s-cta-btn"></div></div>
              </div>
            </div>

            <!-- Screen 2 (middle) — E-commerce -->
            <div class="screen screen-2">
              <div class="screen-bar"><span></span><span></span><span></span></div>
              <div class="screen-body">
                <div class="s-nav"></div>
                <div class="s-grid-products">
                  <div class="s-product"></div>
                  <div class="s-product"></div>
                  <div class="s-product"></div>
                  <div class="s-product"></div>
                </div>
              </div>
            </div>

            <!-- Screen 1 (front) — Showcase site -->
            <div class="screen screen-1">
              <div class="screen-bar">
                <div class="dots"><span></span><span></span><span></span></div>
                <div class="url-bar">disayner.com</div>
              </div>
              <div class="screen-body">
                <div class="s-nav-full">
                  <div class="s-logo"></div>
                  <div class="s-nav-links"><span></span><span></span><span></span></div>
                </div>
                <div class="s-hero-section">
                  <div class="s-hero-title"></div>
                  <div class="s-hero-subtitle"></div>
                  <div class="s-hero-btn"></div>
                </div>
                <div class="s-cards-row">
                  <div class="s-feature-card"><div class="s-icon"></div><div class="s-lines"><span></span><span></span></div></div>
                  <div class="s-feature-card"><div class="s-icon"></div><div class="s-lines"><span></span><span></span></div></div>
                  <div class="s-feature-card"><div class="s-icon"></div><div class="s-lines"><span></span><span></span></div></div>
                </div>
              </div>
            </div>

            <!-- Floating labels -->
            <div class="screen-label label-1">Site vitrine</div>
            <div class="screen-label label-2">E-commerce</div>
            <div class="screen-label label-3">Landing page</div>
          </div>

          <div class="card-tags">
            <span class="tag">WordPress</span>
            <span class="tag">Shopify</span>
            <span class="tag">Webflow</span>
            <span class="tag">Sur-mesure</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 2: SEO ── -->
      <article class="service-card card-seo service-card-small" aria-label="Service : Référencement SEO">
        <div class="card-body">

          <!-- Badge first -->
          <div class="sorank-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            En partenariat avec SoRank
          </div>

          <h3>Référencement SEO</h3>
          <p class="card-desc">Stratégie de visibilité, contenus optimisés et résultats mesurables sur Google.</p>

          <!-- Chart -->
          <div class="seo-chart-container" aria-hidden="true">
            <svg class="chart-svg" viewBox="0 0 280 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <defs>
                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#2563EB" stop-opacity="0.15"/>
                  <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <line x1="0" y1="30" x2="280" y2="30" stroke="#F0F0EB" stroke-width="1"/>
              <line x1="0" y1="60" x2="280" y2="60" stroke="#F0F0EB" stroke-width="1"/>
              <line x1="0" y1="90" x2="280" y2="90" stroke="#F0F0EB" stroke-width="1"/>
              <path class="chart-area"
                d="M0,100 Q40,95 70,85 T140,60 T210,30 T280,10 V120 H0 Z"
                fill="url(#chartGrad)"/>
              <path class="chart-line"
                d="M0,100 Q40,95 70,85 T140,60 T210,30 T280,10"
                fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="70"  cy="85"  r="4"   fill="#2563EB" class="data-dot" style="--delay:0.3s"/>
              <circle cx="70"  cy="85"  r="2"   fill="white"   class="data-dot-inner"/>
              <circle cx="140" cy="60"  r="4"   fill="#2563EB" class="data-dot" style="--delay:0.5s"/>
              <circle cx="140" cy="60"  r="2"   fill="white"   class="data-dot-inner"/>
              <circle cx="210" cy="30"  r="4"   fill="#2563EB" class="data-dot" style="--delay:0.7s"/>
              <circle cx="210" cy="30"  r="2"   fill="white"   class="data-dot-inner"/>
              <circle cx="280" cy="10"  r="5"   fill="#2563EB" class="data-dot pulse-dot" style="--delay:0.9s"/>
              <circle cx="280" cy="10"  r="2.5" fill="white"   class="data-dot-inner"/>
            </svg>
            <div class="chart-labels" aria-hidden="true">
              <span>Jan</span><span>Avr</span><span>Juil</span><span>Oct</span>
            </div>
            <div class="chart-badge" aria-hidden="true">+200% trafic</div>
          </div>

          <div class="card-tags">
            <span class="tag">Audit</span>
            <span class="tag">Contenus</span>
            <span class="tag">Technique</span>
            <span class="tag">Suivi</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 3: Maintenance ── -->
      <article class="service-card card-maintenance service-card-small" aria-label="Service : Maintenance web">
        <div class="card-body">

          <div class="shield-wrap icon-pulse" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path class="check-path" d="m9 12 2 2 4-4"/>
            </svg>
          </div>

          <h3>Maintenance web</h3>
          <p class="card-desc">Votre site reste rapide, sécurisé et à jour. Zéro stress.</p>

          <!-- Feature rows with checkmark circles -->
          <div class="feature-rows">
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Mises à jour de sécurité</span>
            </div>
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Monitoring 24/7</span>
            </div>
            <div class="feature-row">
              <div class="check-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Sauvegardes quotidiennes</span>
            </div>
          </div>

          <div class="card-tags">
            <span class="tag">Sécurité</span>
            <span class="tag">Updates</span>
            <span class="tag">Monitoring</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 7rem 2rem;
    background: var(--color-background);
    position: relative;
    overflow: hidden;
  }

  .services-section::before {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.03), transparent 70%);
    top: -100px;
    left: -100px;
    pointer-events: none;
    border-radius: 50%;
  }

  .services-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .services-header { max-width: 600px; }

  .section-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .services-header h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .services-header em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
    font-weight: 400;
  }

  .services-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* ── Grid ────────────────────────────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 20px;
  }

  .card-creation { grid-row: 1 / 3; }

  /* ── Card base ───────────────────────────────────────────────────────────── */
  .service-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.3s ease;
    cursor: default;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #2563EB, #60A5FA);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 60px rgba(37, 99, 235, 0.08), 0 8px 20px rgba(0, 0, 0, 0.04);
    border-color: rgba(37, 99, 235, 0.15);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .card-body {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  /* ── Icon row + eyebrow ──────────────────────────────────────────────────── */
  .card-icon-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card-icon-wrap {
    width: 36px;
    height: 36px;
    background: var(--color-accent-soft);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* ── Typography ──────────────────────────────────────────────────────────── */
  .service-card h3 {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.68;
  }

  /* ── Tags ────────────────────────────────────────────────────────────────── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    background: #F5F5F0;
    color: #6B6B67;
    border-radius: 100px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .service-card:hover .tag {
    background: #EFF6FF;
    color: #2563EB;
  }

  .card-cta {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .card-cta:hover { gap: 12px; }

  /* ── Stacked Screens (Card 1) ────────────────────────────────────────────── */
  .screens-stack {
    position: relative;
    height: 240px;
    margin: 20px 0;
    flex: 1;
  }

  .screen {
    position: absolute;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.08);
    background: white;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    overflow: hidden;
    width: 85%;
    transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .screen-bar {
    height: 28px;
    background: #F8F8F6;
    border-bottom: 1px solid #EEEEEA;
    display: flex;
    align-items: center;
    padding: 0 10px;
    gap: 5px;
  }

  /* Dots on screens 2 & 3 (direct children of screen-bar) */
  .screen-bar > span {
    width: 8px; height: 8px; border-radius: 50%; display: block; flex-shrink: 0;
  }
  .screen-bar > span:nth-child(1) { background: #FF5F57; }
  .screen-bar > span:nth-child(2) { background: #FEBC2E; }
  .screen-bar > span:nth-child(3) { background: #28C840; }

  /* Dots on screen 1 (inside .dots wrapper) */
  .dots { display: flex; gap: 5px; flex-shrink: 0; }
  .dots > span {
    width: 8px; height: 8px; border-radius: 50%; display: block; flex-shrink: 0;
  }
  .dots > span:nth-child(1) { background: #FF5F57; }
  .dots > span:nth-child(2) { background: #FEBC2E; }
  .dots > span:nth-child(3) { background: #28C840; }

  .url-bar {
    background: white;
    border-radius: 4px;
    padding: 2px 10px;
    font-size: 10px;
    color: #999;
    margin-left: 8px;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .screen-body { padding: 10px; }

  /* — Screen 1 (front) — Showcase site — */
  .screen-1 {
    z-index: 3;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .s-nav-full {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .s-logo { width: 20px; height: 6px; background: #E0E0E0; border-radius: 2px; }

  .s-nav-links { display: flex; gap: 6px; }
  .s-nav-links span { width: 12px; height: 3px; background: #E8E8E3; border-radius: 2px; display: block; }

  .s-hero-section {
    height: 45px;
    background: linear-gradient(135deg, #2563EB, #3B82F6);
    border-radius: 6px;
    margin: 0 0 8px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }

  .s-hero-title { width: 60%; height: 4px; background: rgba(255,255,255,0.5); border-radius: 2px; }
  .s-hero-subtitle { width: 40%; height: 4px; background: rgba(255,255,255,0.35); border-radius: 2px; }
  .s-hero-btn { width: 40px; height: 10px; background: rgba(255,255,255,0.85); border-radius: 4px; margin-top: 4px; }

  .s-cards-row { display: flex; gap: 6px; }

  .s-feature-card {
    flex: 1;
    height: 35px;
    background: #F8F8F6;
    border: 1px solid #F0F0EB;
    border-radius: 4px;
    padding: 5px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .s-icon { width: 8px; height: 8px; background: #EFF6FF; border-radius: 2px; flex-shrink: 0; }

  .s-lines { display: flex; flex-direction: column; gap: 2px; }
  .s-lines span { height: 2px; background: #E8E8E3; border-radius: 1px; display: block; }
  .s-lines span:first-child { width: 80%; }
  .s-lines span:last-child  { width: 55%; }

  /* — Screen 2 (middle) — E-commerce — */
  .screen-2 {
    z-index: 2;
    bottom: 20px;
    left: 55%;
    transform: translateX(-50%) scale(0.93);
    opacity: 0.85;
  }

  .s-nav { height: 6px; background: #EEEEEA; border-radius: 3px; margin-bottom: 8px; }

  .s-grid-products { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }

  .s-product {
    height: 40px;
    background: #FAFAF9;
    border: 1px solid #F0F0EB;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .s-product:nth-child(1)::before { content: ''; display: block; height: 25px; background: #EFF6FF; }
  .s-product:nth-child(2)::before { content: ''; display: block; height: 25px; background: #FEF3E2; }
  .s-product:nth-child(3)::before { content: ''; display: block; height: 25px; background: #F0FDF4; }
  .s-product:nth-child(4)::before { content: ''; display: block; height: 25px; background: #FDF2F8; }

  .s-product::after {
    content: '';
    display: block;
    width: 40%;
    height: 3px;
    background: #E0E0E0;
    border-radius: 1px;
    margin: 3px 5px;
  }

  /* — Screen 3 (back) — Landing page — */
  .screen-3 {
    z-index: 1;
    bottom: 40px;
    left: 60%;
    transform: translateX(-50%) scale(0.86);
    opacity: 0.65;
  }

  .s-hero-gradient {
    height: 70px;
    background: linear-gradient(160deg, #1E3A5F, #2563EB);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .s-cta-btn {
    width: 50px;
    height: 12px;
    background: rgba(255,255,255,0.85);
    border-radius: 6px;
  }

  /* — Hover: fan out — */
  .service-card-main:hover .screen-1 {
    transform: translateX(-55%) rotate(-2deg);
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  .service-card-main:hover .screen-2 {
    transform: translateX(-45%) scale(0.93) rotate(0deg) translateY(-10px);
    opacity: 1;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .service-card-main:hover .screen-3 {
    transform: translateX(-35%) scale(0.86) rotate(2deg) translateY(-20px);
    opacity: 0.9;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  }

  /* — Floating labels — */
  .screen-label {
    position: absolute;
    font-size: 11px;
    font-weight: 600;
    color: #2563EB;
    background: #EFF6FF;
    padding: 4px 10px;
    border-radius: 6px;
    opacity: 0;
    transform: translateY(5px);
    transition: all 0.4s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .label-1 { bottom: -16px; left: 15%; }
  .label-2 { bottom: 10px; right: 5%; }
  .label-3 { top: 0; right: -5%; }

  .service-card-main:hover .screen-label { opacity: 1; transform: translateY(0); }
  .service-card-main:hover .label-1 { transition-delay: 0.1s; }
  .service-card-main:hover .label-2 { transition-delay: 0.2s; }
  .service-card-main:hover .label-3 { transition-delay: 0.3s; }

  /* ── Chart (Card 2) ──────────────────────────────────────────────────────── */
  .seo-chart-container {
    background: #FAFAF9;
    border-radius: 12px;
    padding: 20px 16px 8px;
    position: relative;
    border: 1px solid var(--color-border);
    margin: 4px 0;
  }

  .chart-svg {
    width: 100%;
    height: 80px;
    display: block;
    overflow: visible;
  }

  .chart-line {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    transition: stroke-dashoffset 1.5s ease-out;
  }

  .chart-area {
    opacity: 0;
    transition: opacity 0.6s ease 0.8s;
  }

  .seo-chart-container.chart-animated .chart-line {
    stroke-dashoffset: 0;
  }

  .seo-chart-container.chart-animated .chart-area {
    opacity: 1;
  }

  .data-dot {
    opacity: 0;
    transform-origin: center;
    transform: scale(0);
  }

  .data-dot-inner {
    opacity: 0;
  }

  .seo-chart-container.chart-animated .data-dot {
    animation: popIn 0.3s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  .seo-chart-container.chart-animated .data-dot-inner {
    animation: popIn 0.3s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0); }
    to   { opacity: 1; transform: scale(1); }
  }

  .pulse-dot {
    /* pulsing only after chart is animated */
  }

  .seo-chart-container.chart-animated .pulse-dot {
    animation: popIn 0.3s ease-out forwards var(--delay, 0s),
               dotPulse 2s ease-in-out 1.5s infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    padding: 4px 2px 0;
  }

  .chart-labels span {
    font-size: 10px;
    color: var(--color-text-secondary);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .chart-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: white;
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 12px;
    font-weight: 700;
    color: #2563EB;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.4s ease 1.2s, transform 0.4s ease 1.2s;
  }

  .seo-chart-container.chart-animated .chart-badge {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── SoRank badge ────────────────────────────────────────────────────────── */
  .sorank-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37,99,235,0.2);
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    align-self: flex-start;
  }

  /* ── Shield (Card 3) ─────────────────────────────────────────────────────── */
  .shield-wrap {
    width: 64px;
    height: 64px;
    background: var(--color-accent-soft);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-pulse {
    animation: pulse-soft 3s ease-in-out infinite;
  }

  @keyframes pulse-soft {
    0%, 100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.1); }
    50%       { box-shadow: 0 0 0 12px rgba(37, 99, 235, 0); }
  }

  .check-path {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    transition: stroke-dashoffset 0.6s ease 0.3s;
  }

  .card-maintenance:hover .check-path {
    stroke-dashoffset: 0;
  }

  /* ── Feature rows (Card 3) ───────────────────────────────────────────────── */
  .feature-rows {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }

  .feature-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    background: #EFF6FF;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transform: scale(1);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .service-card:hover .feature-row:nth-child(1) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0s; }
  .service-card:hover .feature-row:nth-child(2) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0.12s; }
  .service-card:hover .feature-row:nth-child(3) .check-icon { animation: checkPop 0.3s ease-out forwards; animation-delay: 0.24s; }

  @keyframes checkPop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.25); background: #DBEAFE; }
    100% { transform: scale(1); background: #EFF6FF; }
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */

  /* Tablet: card-creation full width top, SEO + Maintenance side by side below */
  @media (min-width: 768px) and (max-width: 1023px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .card-creation {
      grid-column: 1 / 3;
      grid-row: 1;
    }

    .card-seo    { grid-row: 2; grid-column: 1; }
    .card-maintenance { grid-row: 2; grid-column: 2; }
  }

  /* Mobile: all stacked */
  @media (max-width: 767px) {
    .services-section { padding: 4rem 1.25rem; }

    .services-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 16px;
    }

    .card-creation { grid-row: auto; }
    .card-body { padding: 28px 24px; }

    /* Screens: default to fanned-out state (no hover on mobile) */
    .screens-stack { height: 200px; }
    .screen-1 { transform: translateX(-55%) rotate(-2deg); }
    .screen-2 { bottom: 12px; transform: translateX(-45%) scale(0.93) translateY(-10px); opacity: 1; }
    .screen-3 { bottom: 24px; transform: translateX(-35%) scale(0.86) rotate(2deg) translateY(-20px); opacity: 0.9; }
    .screen-label { opacity: 1; transform: translateY(0); }
    .label-1 { transition-delay: 0s; }
    .label-2 { transition-delay: 0s; }
    .label-3 { transition-delay: 0s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-pulse { animation: none; }
    .service-card,
    .screen,
    .screen-label,
    .check-icon { transition: none; animation: none; }
    .chart-line { transition: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Card 1 enters first
  if (!prefersReduced) {
    gsap.fromTo(".service-card-main",
      { y: 40, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
        scrollTrigger: { trigger: ".services-grid", start: "top 80%" },
      }
    );

    // Cards 2 and 3 staggered, 0.2s after card 1
    gsap.fromTo(".service-card-small",
      { y: 40, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
        stagger: 0.15, delay: 0.2,
        scrollTrigger: { trigger: ".services-grid", start: "top 80%" },
      }
    );
  }

  // Stacked screens entrance animation
  if (!prefersReduced) {
    gsap.from('.screen', {
      y: 20,
      opacity: 0,
      scale: 0.9,
      stagger: 0.12,
      duration: 0.7,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '.services-grid',
        start: 'top 80%',
      }
    });
  }

  // Animate chart when container enters viewport
  const chartContainer = document.querySelector(".seo-chart-container");
  if (chartContainer) {
    const chartObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          chartContainer.classList.add("chart-animated");
          chartObserver.disconnect();
        }
      },
      { threshold: 0.4 }
    );
    chartObserver.observe(chartContainer);
  }
</script>
