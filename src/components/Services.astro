---
---

<section class="services-section" id="services" aria-label="Nos services">
  <div class="services-inner">

    <!-- Header — visible by default, no will-animate -->
    <div class="services-header">
      <p class="section-label">Ce que nous faisons</p>
      <h2>Trois expertises,<br /><em class="font-serif">un seul objectif.</em></h2>
      <p class="services-sub">Des solutions web sur-mesure qui combinent design, performance et visibilité.</p>
    </div>

    <div class="services-grid">

      <!-- ── Card 1: Création web ── -->
      <article class="service-card card-creation" aria-label="Service : Création de sites web">
        <div class="card-accent-strip" aria-hidden="true"></div>

        <!-- Browser mockup -->
        <div class="browser-mockup" aria-hidden="true">
          <div class="browser-bar">
            <div class="browser-dots">
              <span class="b-dot" style="background:#FF5F57"></span>
              <span class="b-dot" style="background:#FEBC2E"></span>
              <span class="b-dot" style="background:#28C840"></span>
            </div>
            <div class="browser-url-bar"></div>
          </div>
          <div class="browser-body">
            <div class="mock-hero-banner"></div>
            <div class="mock-lines">
              <div class="mock-line" style="width:90%"></div>
              <div class="mock-line" style="width:70%"></div>
              <div class="mock-line" style="width:80%"></div>
            </div>
            <div class="mock-cards-row">
              <div class="mock-mini-card"></div>
              <div class="mock-mini-card"></div>
            </div>
          </div>
        </div>

        <div class="card-body">
          <div class="card-icon-wrap" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="m9 9 3 3-3 3"/><path d="M13 15h3"/>
            </svg>
          </div>
          <h3>Création de sites web</h3>
          <p class="card-desc">Du concept à la mise en ligne, chaque pixel est pensé pour convertir. Sites vitrines, e-commerce et landing pages sur-mesure.</p>
          <div class="card-tags">
            <span class="tag">WordPress</span>
            <span class="tag">Shopify</span>
            <span class="tag">Webflow</span>
            <span class="tag">Sur-mesure</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 2: SEO ── -->
      <article class="service-card card-seo" aria-label="Service : Référencement SEO">
        <div class="card-accent-strip" aria-hidden="true"></div>

        <div class="card-body">
          <!-- Chart -->
          <div class="seo-chart-wrap" aria-hidden="true">
            <svg class="chart-svg" viewBox="0 0 200 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <defs>
                <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#2563EB" stop-opacity="0.15"/>
                  <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <!-- Area fill -->
              <path class="chart-area"
                d="M0,75 C30,68 60,55 90,42 C120,30 150,18 200,8 L200,90 L0,90 Z"
                fill="url(#areaGrad)" opacity="0"/>
              <!-- Main line -->
              <path class="chart-line"
                d="M0,75 C30,68 60,55 90,42 C120,30 150,18 200,8"
                fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Data points -->
              <circle class="chart-dot" cx="0"   cy="75" r="4" fill="#2563EB"/>
              <circle class="chart-dot" cx="0"   cy="75" r="2" fill="white"/>
              <circle class="chart-dot" cx="90"  cy="42" r="4" fill="#2563EB"/>
              <circle class="chart-dot" cx="90"  cy="42" r="2" fill="white"/>
              <circle class="chart-dot" cx="200" cy="8"  r="4" fill="#2563EB"/>
              <circle class="chart-dot" cx="200" cy="8"  r="2" fill="white"/>
            </svg>
            <div class="chart-x-labels" aria-hidden="true">
              <span>Jan</span><span>Avr</span><span>Juil</span><span>Oct</span>
            </div>
          </div>

          <!-- Badge -->
          <div class="sorank-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            En partenariat avec SoRank
          </div>

          <div class="card-icon-wrap" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <h3>Référencement SEO</h3>
          <p class="card-desc">Visibilité qui progresse mois après mois. Stratégie SEO, contenus optimisés, résultats mesurables.</p>
          <div class="card-tags">
            <span class="tag">Audit</span>
            <span class="tag">Contenus</span>
            <span class="tag">Technique</span>
            <span class="tag">Suivi mensuel</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>

      <!-- ── Card 3: Maintenance ── -->
      <article class="service-card card-maintenance" aria-label="Service : Maintenance web">
        <div class="card-accent-strip" aria-hidden="true"></div>

        <div class="card-body">
          <div class="shield-wrap icon-pulse" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path class="check-path" d="m9 12 2 2 4-4"/>
            </svg>
          </div>

          <h3>Maintenance web</h3>
          <p class="card-desc">Sécurité, mises à jour et monitoring en continu. Votre site reste performant, sans que vous ayez à vous en préoccuper.</p>

          <!-- Feature rows -->
          <div class="feature-rows">
            <div class="feature-row">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Mises à jour de sécurité automatiques</span>
            </div>
            <div class="feature-row">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <span>Monitoring de performance 24/7</span>
            </div>
            <div class="feature-row">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>Sauvegardes quotidiennes</span>
            </div>
          </div>

          <div class="card-tags" style="margin-top:1rem">
            <span class="tag">Sécurité</span>
            <span class="tag">Updates</span>
            <span class="tag">Monitoring</span>
          </div>
          <a href="#contact" class="card-cta">En savoir plus →</a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 7rem 2rem;
    background: var(--color-background);
  }

  .services-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .services-header { max-width: 600px; }

  .section-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .services-header h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .services-header em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
    font-weight: 400;
  }

  .services-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* ── Grid ────────────────────────────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .card-creation { grid-row: 1 / 3; }

  /* ── Card base ───────────────────────────────────────────────────────────── */
  .service-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.3s ease;
    cursor: default;
  }

  .service-card:hover {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    transform: translateY(-8px);
    border-color: rgba(37,99,235,0.35);
  }

  /* Accent gradient strip at top */
  .card-accent-strip {
    height: 3px;
    background: linear-gradient(90deg, #2563EB, #3B82F6, #93C5FD);
    flex-shrink: 0;
  }

  .card-body {
    padding: 2rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  /* ── Icon ────────────────────────────────────────────────────────────────── */
  .card-icon-wrap {
    width: 48px;
    height: 48px;
    background: var(--color-accent-soft);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  /* ── Typography ──────────────────────────────────────────────────────────── */
  .service-card h3 {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.68;
  }

  /* ── Tags ────────────────────────────────────────────────────────────────── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border-radius: 100px;
    border: 1px solid var(--color-border);
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    position: relative;
    align-self: flex-start;
    padding-bottom: 1px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .card-cta:hover { border-bottom-color: var(--color-accent); }

  /* ── Browser mockup (Card 1) ─────────────────────────────────────────────── */
  .browser-mockup {
    border-bottom: 1px solid var(--color-border);
    border-radius: 0;
    overflow: hidden;
    flex-shrink: 0;
    transition: transform 0.6s ease;
  }

  .service-card:hover .browser-mockup {
    transform: perspective(800px) rotateY(1.5deg) rotateX(-0.8deg);
  }

  .browser-bar {
    height: 32px;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    padding: 0 0.875rem;
    gap: 0.625rem;
  }

  .browser-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .b-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: block;
  }

  .browser-url-bar {
    flex: 1;
    max-width: 60%;
    height: 16px;
    background: rgba(255,255,255,0.9);
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .browser-body {
    padding: 1rem;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .mock-hero-banner {
    height: 52px;
    background: linear-gradient(135deg, #2563EB, #3B82F6);
    border-radius: 6px;
  }

  .mock-lines {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .mock-line {
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
  }

  .mock-cards-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .mock-mini-card {
    height: 40px;
    background: var(--color-surface);
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }

  /* ── Chart (Card 2) ──────────────────────────────────────────────────────── */
  .seo-chart-wrap {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.125rem 1rem 0.5rem;
    border: 1px solid var(--color-border);
  }

  .chart-svg {
    width: 100%;
    height: 70px;
    display: block;
    overflow: visible;
  }

  .chart-line {
    stroke-dasharray: 350;
    stroke-dashoffset: 350;
    transition: stroke-dashoffset 1.4s ease-out;
  }

  .chart-area {
    transition: opacity 0.5s ease 0.6s;
  }

  .seo-chart-wrap.chart-animated .chart-line {
    stroke-dashoffset: 0;
  }

  .seo-chart-wrap.chart-animated .chart-area {
    opacity: 1;
  }

  .chart-x-labels {
    display: flex;
    justify-content: space-between;
    padding: 0.375rem 0.25rem 0;
  }

  .chart-x-labels span {
    font-size: 0.625rem;
    color: var(--color-text-secondary);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* ── SoRank badge ────────────────────────────────────────────────────────── */
  .sorank-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37,99,235,0.2);
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    align-self: flex-start;
  }

  /* ── Shield (Card 3) ─────────────────────────────────────────────────────── */
  .shield-wrap {
    width: 64px;
    height: 64px;
    background: var(--color-accent-soft);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-pulse {
    animation: pulse-soft 3s ease-in-out infinite;
  }

  @keyframes pulse-soft {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.06); }
  }

  .check-path {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    transition: stroke-dashoffset 0.6s ease 0.3s;
  }

  .card-maintenance:hover .check-path {
    stroke-dashoffset: 0;
  }

  /* ── Feature rows (Card 3) ───────────────────────────────────────────────── */
  .feature-rows {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }

  .feature-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .feature-row svg { flex-shrink: 0; }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .card-creation { grid-row: auto; }
  }

  @media (max-width: 480px) {
    .services-section { padding: 4rem 1.25rem; }
    .card-body { padding: 1.5rem 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-pulse, .service-card { animation: none; transition: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Stagger cards in on scroll
  if (!prefersReduced) {
    gsap.from(".service-card", {
      y: 50,
      opacity: 0,
      duration: 0.7,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: { trigger: ".services-grid", start: "top 80%" },
    });
  }

  // Animate chart line when card enters viewport
  const chartWrap = document.querySelector(".seo-chart-wrap");
  if (chartWrap) {
    const chartObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          chartWrap.classList.add("chart-animated");
          chartObserver.disconnect();
        }
      },
      { threshold: 0.4 }
    );
    chartObserver.observe(chartWrap);
  }
</script>
