---
interface Word {
  text: string;
  x: string;
  y: string;
  rot: string;
  size: string;
}

interface Props {
  words: Word[];
  variant?: 'dark' | 'light';
}

const { words, variant = 'dark' } = Astro.props;
---

<div class="bg-words" aria-hidden="true">
  {words.map((word) => (
    <span
      class={`bg-word${variant === 'light' ? ' bg-word--light' : ''}`}
      style={`--x:${word.x}; --y:${word.y}; --rot:${word.rot}; --size:${word.size};`}
    >
      {word.text}
    </span>
  ))}
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!prefersReduced) {
    // One ScrollTrigger per .bg-words container instead of per word
    (gsap.utils.toArray('.bg-words') as HTMLElement[]).forEach((container) => {
      const section = container.closest('section') ?? container.parentElement;
      const words = container.querySelectorAll('.bg-word');
      if (!section || !words.length) return;
      gsap.to(words, {
        y: -50,
        ease: "none",
        scrollTrigger: {
          trigger: section,
          start: "top bottom",
          end: "bottom top",
          scrub: 1.5,
        },
      });
    });
  }
</script>
