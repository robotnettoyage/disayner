---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BgOrbs from '../../components/BgOrbs.astro';

const faqItems = [
  { q: "Est-ce que mes images sont envoyées sur un serveur ?", a: "Non. La compression se fait intégralement dans votre navigateur grâce au Canvas API. Vos images ne quittent jamais votre appareil. Aucune donnée n'est collectée ni stockée.", open: true },
  { q: "Quelle qualité de compression choisir ?", a: "80% offre le meilleur rapport qualité/poids pour la majorité des usages web. Pour des photos de portfolio, montez à 90%. Pour des thumbnails, 60-70% suffit." },
  { q: "Quels formats d'entrée sont acceptés ?", a: "PNG, JPG/JPEG, GIF, BMP, TIFF et même WebP (pour re-compresser). Jusqu'à 20 images simultanément, 50 Mo max par fichier." },
  { q: "Le WebP est-il compatible avec tous les navigateurs ?", a: "Oui. Depuis 2020, tous les navigateurs majeurs supportent le WebP : Chrome, Firefox, Safari (14+), Edge et Opera. La part de marché des navigateurs compatibles dépasse 97%." },
  { q: "Puis-je utiliser cet outil pour mon site professionnel ?", a: "Absolument. L'outil est gratuit et sans limitation. Si vous avez besoin d'un accompagnement complet pour optimiser les performances de votre site, découvrez nos prestations SEO." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Compresseur WebP — DISAYNER",
  "description": "Outil gratuit de compression et conversion d'images en format WebP. 100% côté client, sans upload serveur.",
  "url": "https://disayner.com/outils/compresseur-webp",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  },
  "provider": {
    "@type": "ProfessionalService",
    "name": "DISAYNER",
    "url": "https://disayner.com"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://disayner.com/" },
    { "@type": "ListItem", "position": 2, "name": "Outils SEO", "item": "https://disayner.com/outils" },
    { "@type": "ListItem", "position": 3, "name": "Compresseur WebP", "item": "https://disayner.com/outils/compresseur-webp" },
  ]
};

const howSteps = [
  { num: '01', title: 'Déposez vos images', desc: "Glissez-déposez ou sélectionnez vos fichiers PNG, JPG, GIF. Jusqu'à 20 images à la fois." },
  { num: '02', title: 'Réglez la qualité', desc: "Choisissez le niveau de compression (80% recommandé) et la taille maximale optionnelle." },
  { num: '03', title: 'Téléchargez en WebP', desc: "Vos images sont compressées instantanément. Téléchargez-les une par une ou toutes en .zip." },
];

const benefits = [
  { iconPath: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`, title: 'Performance', desc: "Des pages qui se chargent plus vite. Google recommande le WebP pour améliorer les Core Web Vitals." },
  { iconPath: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`, title: 'SEO', desc: "Un site rapide est mieux classé sur Google. Le poids des images est le premier facteur de lenteur." },
  { iconPath: `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`, title: 'Qualité', desc: "Compression avec perte quasi-invisible. À qualité égale, le WebP est 25-34% plus léger que le JPEG." },
  { iconPath: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`, title: 'Compatibilité', desc: "Supporté par tous les navigateurs modernes (Chrome, Firefox, Safari, Edge) depuis 2020." },
];
---

<Layout
  title="Compresseur WebP gratuit en ligne — Convertir PNG/JPG en WebP | DISAYNER"
  description="Compressez et convertissez vos images en WebP gratuitement, directement dans votre navigateur. Aucun upload serveur, 100% privé. Jusqu'à 20 images à la fois."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S1 — BREADCRUMB + HERO                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-hero" aria-label="Compresseur WebP gratuit">
      <BgOrbs orbs={[
        { type: 'filled', x: '85%', y: '25%', size: '220px', dur: '14s' },
        { type: 'ring',   x: '8%',  y: '70%', size: '160px', dur: '18s' },
      ]} />

      <div class="wc-hero-inner">
        <nav class="wc-breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a>
          <span aria-hidden="true">/</span>
          <a href="/outils">Outils SEO</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Compresseur WebP</span>
        </nav>

        <p class="wc-eyebrow">Outil gratuit</p>
        <h1 class="wc-hero-title">
          Compresseur d'images <em class="font-serif">WebP</em>
        </h1>
        <p class="wc-hero-sub">
          Convertissez et compressez vos images en WebP directement dans votre navigateur. Aucun upload serveur — vos fichiers restent 100% privés.
        </p>
        <div class="wc-badges" role="list" aria-label="Garanties">
          <span class="wc-badge" role="listitem">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            100% côté client
          </span>
          <span class="wc-badge-dot" aria-hidden="true">&middot;</span>
          <span class="wc-badge" role="listitem">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Aucun upload
          </span>
          <span class="wc-badge-dot" aria-hidden="true">&middot;</span>
          <span class="wc-badge" role="listitem">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Gratuit &amp; sans inscription
          </span>
          <span class="wc-badge-dot" aria-hidden="true">&middot;</span>
          <span class="wc-badge" role="listitem">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Données privées
          </span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S2 — TOOL INTERFACE                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-section wc-tool-section" aria-label="Outil de compression">
      <div class="wc-container">
        <div class="wc-app" id="wcApp">

          <!-- STATE 1: Drop Zone -->
          <div class="wc-dropzone" id="wcDropzone">
            <div class="wc-dropzone-content">
              <svg class="wc-drop-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              <h3>Glissez vos images ici</h3>
              <p>ou <button type="button" class="wc-browse-btn" id="wcBrowseBtn">parcourez vos fichiers</button></p>
              <p class="wc-drop-info">PNG, JPG, JPEG, GIF, BMP, TIFF — Max 50 Mo par fichier — Jusqu'à 20 images</p>
            </div>
            <input type="file" id="wcFileInput" multiple accept="image/png,image/jpeg,image/gif,image/bmp,image/tiff,image/webp" hidden />
          </div>

          <!-- STATE 2: Settings + Preview -->
          <div class="wc-settings" id="wcSettings" style="display:none">
            <div class="wc-setting-row">
              <label for="wcQuality">Qualité de compression</label>
              <div class="wc-slider-container">
                <input type="range" id="wcQuality" min="1" max="100" value="80" />
                <span class="wc-quality-value" id="wcQualityValue">80%</span>
              </div>
              <p class="wc-setting-hint">80% offre le meilleur rapport qualité/poids. En dessous de 60%, la perte de qualité devient visible.</p>
            </div>

            <div class="wc-setting-row">
              <label>Largeur maximale (optionnel)</label>
              <div class="wc-resize-options" id="wcResizeOptions">
                <button type="button" class="wc-resize-btn active" data-width="0">Original</button>
                <button type="button" class="wc-resize-btn" data-width="1920">1920px</button>
                <button type="button" class="wc-resize-btn" data-width="1200">1200px</button>
                <button type="button" class="wc-resize-btn" data-width="800">800px</button>
              </div>
              <p class="wc-setting-hint">Redimensionne les images plus larges que la valeur choisie. Hauteur ajustée proportionnellement.</p>
            </div>
          </div>

          <!-- Image list -->
          <div class="wc-image-list" id="wcImageList" style="display:none">
            <div class="wc-list-header">
              <span class="wc-list-count" id="wcListCount">0 images</span>
              <button type="button" class="wc-btn-clear-all" id="wcClearAll">Tout supprimer</button>
            </div>
            <div class="wc-image-table">
              <div class="wc-table-head">
                <span class="wc-col-name">Fichier</span>
                <span class="wc-col-format">Format</span>
                <span class="wc-col-size">Taille</span>
                <span class="wc-col-action"></span>
              </div>
              <div class="wc-table-body" id="wcImageTableBody"></div>
            </div>
          </div>

          <!-- Action buttons (settings state) -->
          <div class="wc-actions" id="wcActions" style="display:none">
            <button type="button" class="wc-btn-compress" id="wcCompressBtn">
              Compresser en WebP
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
            <button type="button" class="wc-btn-reset" id="wcResetBtn">Recommencer</button>
          </div>

          <!-- STATE 3: Results -->
          <div class="wc-results" id="wcResults" style="display:none">
            <div class="wc-results-summary">
              <div class="wc-result-stat">
                <span class="wc-stat-number" id="wcTotalSaved">0%</span>
                <span class="wc-stat-label">Réduction moyenne</span>
              </div>
              <div class="wc-result-stat">
                <span class="wc-stat-number" id="wcTotalBefore">0 Mo</span>
                <span class="wc-stat-label">Taille originale</span>
              </div>
              <div class="wc-result-stat">
                <span class="wc-stat-number" id="wcTotalAfter">0 Mo</span>
                <span class="wc-stat-label">Après compression</span>
              </div>
            </div>

            <div class="wc-results-list" id="wcResultsList">
              <div class="wc-list-header">
                <span class="wc-list-count" id="wcResultsCount">0 images compressées</span>
              </div>
              <div class="wc-results-table">
                <div class="wc-table-head wc-table-head--results">
                  <span class="wc-col-name">Fichier</span>
                  <span class="wc-col-before">Avant</span>
                  <span class="wc-col-after">Après</span>
                  <span class="wc-col-saved">Réduit</span>
                  <span class="wc-col-action"></span>
                </div>
                <div class="wc-table-body" id="wcResultsTableBody"></div>
              </div>
            </div>

            <div class="wc-actions">
              <button type="button" class="wc-btn-compress" id="wcDownloadAllBtn">
                Télécharger tout (.zip)
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </button>
              <button type="button" class="wc-btn-reset" id="wcNewBatchBtn">Compresser d'autres images</button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S3 — HOW IT WORKS                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-section wc-howto" aria-label="Comment ça marche">
      <div class="wc-container">
        <div class="wc-section-header section-header-anim">
          <p class="wc-eyebrow">Comment ça marche</p>
          <h2>3 étapes, <em class="font-serif">zéro friction</em>.</h2>
        </div>

        <div class="wc-steps-grid">
          {howSteps.map((step, i) => (
            <div class="wc-step wc-fade-in" style={`transition-delay:${i * 0.1}s`}>
              <span class="wc-step-num" aria-hidden="true">{step.num}</span>
              <h3 class="wc-step-title">{step.title}</h3>
              <p class="wc-step-desc">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S4 — WHY WEBP                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-section wc-benefits" aria-label="Pourquoi le WebP">
      <div class="wc-container">
        <div class="wc-section-header section-header-anim">
          <p class="wc-eyebrow">Pourquoi le WebP ?</p>
          <h2>Le format WebP réduit le poids de vos images de <em class="font-serif">70% en moyenne</em>.</h2>
        </div>

        <div class="wc-benefits-grid">
          {benefits.map((b, i) => (
            <article class="wc-benefit-card wc-fade-in" style={`transition-delay:${i * 0.08}s`}>
              <div class="wc-benefit-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={b.iconPath} />
              </div>
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S5 — FAQ                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-section wc-faq" aria-label="Questions fréquentes">
      <div class="wc-container wc-faq-inner">
        <div class="wc-section-header section-header-anim">
          <p class="wc-eyebrow">FAQ</p>
          <h2>Questions fréquentes sur le <em class="font-serif">compresseur WebP</em>.</h2>
        </div>

        <div class="wc-faq-list" role="list">
          {faqItems.map((item, i) => (
            <details class="wc-faq-item wc-fade-in" open={item.open} style={`transition-delay:${i * 0.04}s`} role="listitem">
              <summary class="wc-faq-question">
                <span>{item.q}</span>
                <span class="wc-faq-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </span>
              </summary>
              <div class="wc-faq-answer"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S6 — CTA                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="wc-cta-section" aria-label="Optimiser tout votre site">
      <div class="wc-cta-dotgrid" aria-hidden="true"></div>
      <div class="wc-cta-shape wc-cta-shape-1" aria-hidden="true"></div>
      <div class="wc-cta-shape wc-cta-shape-2" aria-hidden="true"></div>

      <div class="wc-cta-inner">
        <p class="wc-cta-tag">Optimisation complète</p>
        <h2 class="wc-cta-title">
          Besoin d'optimiser <em class="font-serif">tout votre site</em>&nbsp;?
        </h2>
        <p class="wc-cta-sub">Nos prestations SEO incluent l'optimisation complète de vos images, votre performance et votre référencement.</p>
        <div class="wc-cta-actions">
          <a href="/seo" class="wc-btn-white">
            Découvrir nos prestations SEO
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="wc-btn-ghost">Nous contacter</a>
        </div>
        <p class="wc-cta-reassurance">Réponse sous 24h · Audit offert · Basé en Haute-Savoie</p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ─── Layout helpers ──────────────────────────────────────────────────── */
  .wc-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .wc-section {
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .wc-eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .wc-section-header {
    max-width: 680px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .wc-section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .wc-section-header h2 em { font-style: italic; color: var(--color-accent); }

  .wc-section-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .wc-fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .wc-fade-in.visible { opacity: 1; transform: none; }

  /* ─── S1: HERO ────────────────────────────────────────────────────────── */
  .wc-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 9rem 2rem 4rem;
    overflow: hidden;
    background: var(--color-background);
    text-align: center;
  }

  .wc-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .wc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .wc-breadcrumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .wc-breadcrumb a:hover { color: var(--color-accent); }

  .wc-breadcrumb span[aria-current] {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .wc-hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  .wc-hero-title em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
    font-size: 1.05em;
    letter-spacing: -0.02em;
  }

  .wc-hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 600px;
  }

  .wc-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .wc-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .wc-badge svg { color: var(--color-accent); }
  .wc-badge-dot { color: var(--color-border); font-size: 1.25rem; line-height: 1; }

  /* ─── S2: TOOL INTERFACE ──────────────────────────────────────────────── */
  .wc-tool-section { padding-top: 2rem; background: var(--color-background); }

  .wc-app {
    max-width: 800px;
    margin: 0 auto;
  }

  /* Drop zone */
  .wc-dropzone {
    border: 2px dashed var(--color-border);
    border-radius: 20px;
    padding: 60px 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background: var(--color-background);
  }

  .wc-dropzone:hover,
  .wc-dropzone.drag-over {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .wc-dropzone h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 16px 0 8px;
  }

  .wc-dropzone p {
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .wc-browse-btn {
    background: none;
    border: none;
    color: var(--color-accent);
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    font-size: inherit;
    font-family: inherit;
  }

  .wc-drop-info {
    font-size: 12px !important;
    color: #B0B0A8 !important;
    margin-top: 12px;
  }

  /* Settings */
