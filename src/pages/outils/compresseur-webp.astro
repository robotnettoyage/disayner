</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ── DOM references ──────────────────────────────────────────────────
    const dropzone = document.getElementById('wcDropzone');
    const fileInput = document.getElementById('wcFileInput') as HTMLInputElement;
    const browseBtn = document.getElementById('wcBrowseBtn');
    const settingsPanel = document.getElementById('wcSettings');
    const imageList = document.getElementById('wcImageList');
    const actionsPanel = document.getElementById('wcActions');
    const resultsPanel = document.getElementById('wcResults');
    const qualitySlider = document.getElementById('wcQuality') as HTMLInputElement;
    const qualityValue = document.getElementById('wcQualityValue');
    const resizeOptions = document.getElementById('wcResizeOptions');
    const compressBtn = document.getElementById('wcCompressBtn');
    const resetBtn = document.getElementById('wcResetBtn');
    const downloadAllBtn = document.getElementById('wcDownloadAllBtn');
    const newBatchBtn = document.getElementById('wcNewBatchBtn');
    const clearAllBtn = document.getElementById('wcClearAll');
    const imageTableBody = document.getElementById('wcImageTableBody');
    const resultsTableBody = document.getElementById('wcResultsTableBody');

    if (!dropzone || !fileInput) return;

    // ── State ───────────────────────────────────────────────────────────
    let files: File[] = [];
    let quality = 80;
    let maxWidth = 0;
    let compressionResults: { originalName: string; newName: string; originalSize: number; newSize: number; blob: Blob; thumb: string; savings: number }[] = [];

    // ── Helpers ─────────────────────────────────────────────────────────
    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' o';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' Ko';
      return (bytes / (1024 * 1024)).toFixed(1) + ' Mo';
    }

    function showState(state: 'drop' | 'settings' | 'results') {
      dropzone!.style.display = state === 'drop' ? 'block' : 'none';
      settingsPanel!.style.display = state === 'settings' ? 'block' : 'none';
      imageList!.style.display = state === 'settings' ? 'block' : 'none';
      actionsPanel!.style.display = state === 'settings' ? 'flex' : 'none';
      resultsPanel!.style.display = state === 'results' ? 'block' : 'none';
    }

    // ── Drag & drop ─────────────────────────────────────────────────────
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(evt => {
      dropzone!.addEventListener(evt, (e) => { e.preventDefault(); e.stopPropagation(); });
    });

    dropzone!.addEventListener('dragenter', () => dropzone!.classList.add('drag-over'));
    dropzone!.addEventListener('dragleave', (e) => {
      const relTarget = (e as DragEvent).relatedTarget as Node | null;
      if (!dropzone!.contains(relTarget)) dropzone!.classList.remove('drag-over');
    });
    dropzone!.addEventListener('drop', (e) => {
      dropzone!.classList.remove('drag-over');
      handleFiles((e as DragEvent).dataTransfer?.files);
    });

    dropzone!.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.wc-browse-btn')) return;
      fileInput!.click();
    });
    browseBtn?.addEventListener('click', () => fileInput!.click());
    fileInput!.addEventListener('change', () => {
      handleFiles(fileInput!.files);
      fileInput!.value = '';
    });

    // ── Quality slider ──────────────────────────────────────────────────
    qualitySlider?.addEventListener('input', () => {
      quality = parseInt(qualitySlider.value);
      if (qualityValue) qualityValue.textContent = quality + '%';
    });

    // ── Resize buttons ──────────────────────────────────────────────────
    resizeOptions?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.wc-resize-btn') as HTMLElement | null;
      if (!btn) return;
      resizeOptions.querySelectorAll('.wc-resize-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      maxWidth = parseInt(btn.dataset.width || '0');
    });

    // ── File handling ───────────────────────────────────────────────────
    const validTypes = ['image/png', 'image/jpeg', 'image/gif', 'image/bmp', 'image/tiff', 'image/webp'];
    const maxFileSize = 50 * 1024 * 1024;

    function handleFiles(fileList: FileList | null | undefined) {
      if (!fileList || fileList.length === 0) return;

      const newFiles = Array.from(fileList).filter(f => validTypes.includes(f.type) && f.size <= maxFileSize);
      if (newFiles.length === 0) return;

      files = [...files, ...newFiles].slice(0, 20);
      showState('settings');
      renderFileList();
    }

    function getFileExt(name: string): string {
      const ext = name.split('.').pop()?.toUpperCase() || '?';
      return ext === 'JPEG' ? 'JPG' : ext;
    }

    function truncate(str: string, max: number): string {
      if (str.length <= max) return str;
      const ext = str.split('.').pop() || '';
      return str.substring(0, max - ext.length - 3) + '...' + ext;
    }

    function renderFileList() {
      if (!imageTableBody) return;
      const countEl = document.getElementById('wcListCount');
      if (countEl) countEl.textContent = `${files.length} image${files.length > 1 ? 's' : ''}`;

      imageTableBody.innerHTML = files.map((f, i) => `
        <div class="wc-table-row">
          <span class="wc-col-name" title="${f.name}">${f.name}</span>
          <span class="wc-col-format">${getFileExt(f.name)}</span>
          <span class="wc-col-size">${formatSize(f.size)}</span>
          <button type="button" class="wc-image-remove" data-index="${i}" title="Retirer">&times;</button>
        </div>
      `).join('');

      imageTableBody.querySelectorAll('.wc-image-remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt((btn as HTMLElement).dataset.index || '0');
          files.splice(idx, 1);
          if (files.length === 0) {
            resetTool();
          } else {
            renderFileList();
          }
        });
      });
    }

    // ── Core compression ────────────────────────────────────────────────
    function compressToWebP(file: File, q: number, mw: number): Promise<{ originalName: string; newName: string; originalSize: number; newSize: number; blob: Blob; thumb: string; savings: number }> {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let w = img.naturalWidth;
          let h = img.naturalHeight;

          if (mw > 0 && w > mw) {
            h = Math.round((h * mw) / w);
            w = mw;
          }

          canvas.width = w;
          canvas.height = h;

          const ctx = canvas.getContext('2d');
          if (!ctx) { reject(new Error('Canvas non supporté')); return; }
          ctx.drawImage(img, 0, 0, w, h);

          canvas.toBlob((blob) => {
            URL.revokeObjectURL(img.src);
            if (!blob) { reject(new Error('Compression WebP non supportée par ce navigateur')); return; }

            const originalName = file.name;
            const newName = file.name.replace(/\.[^/.]+$/, '') + '.webp';
            const savings = Math.round((1 - blob.size / file.size) * 100);

            resolve({
              originalName,
              newName,
              originalSize: file.size,
              newSize: blob.size,
              blob,
              thumb: URL.createObjectURL(blob),
              savings,
            });
          }, 'image/webp', q / 100);
        };

        img.onerror = () => {
          URL.revokeObjectURL(img.src);
          reject(new Error(`Impossible de charger : ${file.name}`));
        };

        img.src = URL.createObjectURL(file);
      });
    }

    // ── Compress all ────────────────────────────────────────────────────
    compressBtn?.addEventListener('click', async () => {
      if (!compressBtn) return;
      (compressBtn as HTMLButtonElement).disabled = true;
      compressBtn.innerHTML = `
        Compression en cours...
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      `;

      compressionResults = [];

      for (const file of files) {
        try {
          const result = await compressToWebP(file, quality, maxWidth);
          compressionResults.push(result);
        } catch (err) {
          console.error(err);
        }
      }

      if (compressionResults.length === 0) {
        (compressBtn as HTMLButtonElement).disabled = false;
        compressBtn.innerHTML = `Compresser en WebP <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        return;
      }

      showResults();
    });

    // ── Show results ────────────────────────────────────────────────────
    function showResults() {
      showState('results');

      const totalBefore = compressionResults.reduce((s, r) => s + r.originalSize, 0);
      const totalAfter = compressionResults.reduce((s, r) => s + r.newSize, 0);
      const avgSavings = totalBefore > 0 ? Math.round((1 - totalAfter / totalBefore) * 100) : 0;

      const elSaved = document.getElementById('wcTotalSaved');
      const elBefore = document.getElementById('wcTotalBefore');
      const elAfter = document.getElementById('wcTotalAfter');

      if (elSaved) elSaved.textContent = avgSavings + '%';
      if (elBefore) elBefore.textContent = formatSize(totalBefore);
      if (elAfter) elAfter.textContent = formatSize(totalAfter);

      const resultsCountEl = document.getElementById('wcResultsCount');
      if (resultsCountEl) resultsCountEl.textContent = `${compressionResults.length} image${compressionResults.length > 1 ? 's' : ''} compressée${compressionResults.length > 1 ? 's' : ''}`;

      if (resultsTableBody) {
        resultsTableBody.innerHTML = compressionResults.map(r => {
          const savingsClass = r.savings >= 0 ? 'positive' : 'negative';
          return `
            <div class="wc-table-row wc-table-row--results">
              <span class="wc-col-name" title="${r.newName}">${truncate(r.newName, 28)}</span>
              <span class="wc-col-before">${formatSize(r.originalSize)}</span>
              <span class="wc-col-after">${formatSize(r.newSize)}</span>
              <span class="wc-col-saved ${savingsClass}">${r.savings >= 0 ? '-' : '+'}${Math.abs(r.savings)}%</span>
              <a class="wc-result-download" href="${URL.createObjectURL(r.blob)}" download="${r.newName}" title="Télécharger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
          `;
        }).join('');
      }
    }

    // ── Download all as zip ─────────────────────────────────────────────
    downloadAllBtn?.addEventListener('click', async () => {
      if (compressionResults.length === 0) return;

      if (compressionResults.length === 1) {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(compressionResults[0].blob);
        a.download = compressionResults[0].newName;
        a.click();
        return;
      }

      const btn = downloadAllBtn as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Préparation du zip...';

      try {
        if (!(window as any).JSZip) {
          const script = document.createElement('script');
          script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
          document.head.appendChild(script);
          await new Promise<void>((resolve, reject) => {
            script.onload = () => resolve();
            script.onerror = () => reject(new Error('Impossible de charger JSZip'));
          });
        }

        const zip = new (window as any).JSZip();

        // Deduplicate filenames
        const nameCount: Record<string, number> = {};
        compressionResults.forEach(r => {
          const base = r.newName.replace(/\.webp$/, '');
          nameCount[base] = (nameCount[base] || 0) + 1;
          const suffix = nameCount[base] > 1 ? `-${nameCount[base]}` : '';
          zip.file(`${base}${suffix}.webp`, r.blob);
        });

        const content = await zip.generateAsync({ type: 'blob' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(content);
        a.download = 'images-webp-disayner.zip';
        a.click();
        URL.revokeObjectURL(a.href);
      } catch (err) {
        console.error('Erreur zip:', err);
      }

      btn.disabled = false;
      btn.innerHTML = `
        Télécharger tout (.zip)
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      `;
    });

    // ── Reset ───────────────────────────────────────────────────────────
    function resetTool() {
      compressionResults.forEach(r => URL.revokeObjectURL(r.thumb));
      files = [];
      compressionResults = [];
      quality = 80;
      maxWidth = 0;
      showState('drop');

      if (qualitySlider) qualitySlider.value = '80';
      if (qualityValue) qualityValue.textContent = '80%';
      resizeOptions?.querySelectorAll('.wc-resize-btn').forEach((b, i) => {
        b.classList.toggle('active', i === 0);
      });
      if (compressBtn) {
        (compressBtn as HTMLButtonElement).disabled = false;
        compressBtn.innerHTML = `
          Compresser en WebP
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        `;
      }
    }

    resetBtn?.addEventListener('click', resetTool);
    newBatchBtn?.addEventListener('click', resetTool);
    clearAllBtn?.addEventListener('click', resetTool);

    // ── Fade-in observer ────────────────────────────────────────────────
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.wc-fade-in').forEach(el => observer.observe(el));
  });
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
