---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BgOrbs from '../../components/BgOrbs.astro';

const faqItems = [
  { q: "Combien de mots pour un article SEO ?", a: "Il n'y a pas de nombre magique, mais les articles qui se positionnent en top 3 de Google font en moyenne 1 500 à 2 500 mots. L'important est de couvrir le sujet en profondeur, pas de gonfler artificiellement le nombre de mots.", open: true },
  { q: "Quelle densité de mot-clé viser ?", a: "Entre 1% et 2% pour votre mot-clé principal. En dessous de 0.5%, Google ne comprend pas votre sujet. Au-dessus de 3%, vous risquez une pénalité pour sur-optimisation (keyword stuffing)." },
  { q: "C'est quoi un bon score de lisibilité ?", a: "Pour le web, visez 60-80/100. Des phrases courtes (15-20 mots), des paragraphes aérés et un vocabulaire accessible. Les articles trop complexes ont un taux de rebond plus élevé." },
];

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({ "@type": "Question", "name": item.q, "acceptedAnswer": { "@type": "Answer", "text": item.a } }))
};
const webAppSchema = {
  "@context": "https://schema.org", "@type": "WebApplication",
  "name": "Compteur de mots SEO — DISAYNER",
  "description": "Comptez les mots, caractères et phrases de votre texte. Analysez la densité de mots-clés, le temps de lecture et la lisibilité.",
  "url": "https://disayner.com/outils/compteur-mots-seo",
  "applicationCategory": "UtilitiesApplication", "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  "provider": { "@type": "ProfessionalService", "name": "DISAYNER", "url": "https://disayner.com" }
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://disayner.com/" },
    { "@type": "ListItem", "position": 2, "name": "Outils SEO", "item": "https://disayner.com/outils" },
    { "@type": "ListItem", "position": 3, "name": "Compteur de mots SEO", "item": "https://disayner.com/outils/compteur-mots-seo" },
  ]
};
---

<Layout
  title="Compteur de mots SEO gratuit — Analysez votre contenu | DISAYNER"
  description="Comptez les mots, caractères et phrases de votre texte. Analysez la densité de mots-clés, le temps de lecture et la lisibilité. Gratuit et instantané."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Navbar />
  <main id="main-content">

    <!-- HERO -->
    <section class="cm-hero" aria-label="Compteur de mots SEO">
      <BgOrbs orbs={[
        { type: 'filled', x: '85%', y: '25%', size: '220px', dur: '14s' },
        { type: 'ring',   x: '8%',  y: '70%', size: '160px', dur: '18s' },
      ]} />
      <div class="cm-hero-inner">
        <nav class="cm-breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a><span aria-hidden="true">/</span>
          <a href="/outils">Outils SEO</a><span aria-hidden="true">/</span>
          <span aria-current="page">Compteur de mots SEO</span>
        </nav>
        <p class="cm-eyebrow">Outil gratuit</p>
        <h1 class="cm-hero-title">Compteur de mots <em class="font-serif">SEO</em></h1>
        <p class="cm-hero-sub">Analysez votre contenu en temps réel : nombre de mots, densité de mots-clés, temps de lecture et score de lisibilité.</p>
        <div class="cm-badges" role="list" aria-label="Garanties">
          <span class="cm-badge" role="listitem"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Analyse en temps réel</span>
          <span class="cm-badge-dot" aria-hidden="true">&middot;</span>
          <span class="cm-badge" role="listitem"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Aucun envoi de données</span>
          <span class="cm-badge-dot" aria-hidden="true">&middot;</span>
          <span class="cm-badge" role="listitem"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Gratuit &amp; sans inscription</span>
        </div>
      </div>
    </section>

    <!-- TOOL -->
    <section class="cm-section cm-tool-section" aria-label="Compteur de mots">
      <div class="cm-container">
        <div class="cm-app">
          <textarea id="cmTextInput" rows="12" placeholder="Collez votre texte ici pour l'analyser..."></textarea>
          <div class="cm-keyword-row">
            <label for="cmKeyword">Mot-clé cible (optionnel)</label>
            <input type="text" id="cmKeyword" placeholder="ex: robot lave-vitre" />
            <p class="cm-setting-hint">Entrez votre mot-clé principal pour calculer sa densité dans le texte.</p>
          </div>

          <!-- Stats -->
          <div class="cm-stats-grid" id="cmStats">
            <div class="cm-stat"><span class="cm-stat-num" id="cmWords">0</span><span class="cm-stat-label">Mots</span></div>
            <div class="cm-stat"><span class="cm-stat-num" id="cmChars">0</span><span class="cm-stat-label">Caractères</span></div>
            <div class="cm-stat"><span class="cm-stat-num" id="cmSentences">0</span><span class="cm-stat-label">Phrases</span></div>
            <div class="cm-stat"><span class="cm-stat-num" id="cmParagraphs">0</span><span class="cm-stat-label">Paragraphes</span></div>
          </div>

          <div class="cm-stats-secondary">
            <div class="cm-stat-s"><span class="cm-stat-s-num" id="cmReadTime">0 min</span><span class="cm-stat-s-label">Temps de lecture</span></div>
            <div class="cm-stat-s"><span class="cm-stat-s-num" id="cmSpeakTime">0 min</span><span class="cm-stat-s-label">Temps de parole</span></div>
            <div class="cm-stat-s"><span class="cm-stat-s-num" id="cmCharsNoSpace">0</span><span class="cm-stat-s-label">Caractères (sans espaces)</span></div>
          </div>

          <!-- Keyword density -->
          <div class="cm-keyword-result" id="cmKeywordResult" style="display:none">
            <h3>Densité du mot-clé</h3>
            <div class="cm-kw-grid">
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmKwOccurrences">0</span><span class="cm-kw-label">Occurrences</span></div>
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmKwDensity">0%</span><span class="cm-kw-label">Densité</span></div>
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmKwVerdict">—</span><span class="cm-kw-label">Recommandation</span></div>
            </div>
          </div>

          <!-- Readability -->
          <div class="cm-readability" id="cmReadability" style="display:none">
            <h3>Lisibilité</h3>
            <div class="cm-kw-grid">
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmReadScore">0</span><span class="cm-kw-label">Score /100</span></div>
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmReadLevel">—</span><span class="cm-kw-label">Niveau</span></div>
              <div class="cm-kw-item"><span class="cm-kw-val" id="cmAvgSentence">0</span><span class="cm-kw-label">Mots/phrase</span></div>
            </div>
          </div>

          <!-- Top words -->
          <div class="cm-top-words" id="cmTopWords" style="display:none">
            <h3>Top 10 des mots les plus fréquents</h3>
            <table class="cm-words-table">
              <thead><tr><th>Rang</th><th>Mot</th><th>Occ.</th><th>Densité</th></tr></thead>
              <tbody id="cmWordsBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="cm-section cm-faq" aria-label="Questions fréquentes">
      <div class="cm-container cm-faq-inner">
        <div class="cm-section-header section-header-anim">
          <p class="cm-eyebrow">FAQ</p>
          <h2>Questions fréquentes sur le <em class="font-serif">compteur de mots</em>.</h2>
        </div>
        <div class="cm-faq-list" role="list">
          {faqItems.map((item, i) => (
            <details class="cm-faq-item cm-fade-in" open={item.open} style={`transition-delay:${i * 0.04}s`} role="listitem">
              <summary class="cm-faq-question"><span>{item.q}</span><span class="cm-faq-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span></summary>
              <div class="cm-faq-answer"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cm-cta-section" aria-label="Accompagnement SEO">
      <div class="cm-cta-dotgrid" aria-hidden="true"></div>
      <div class="cm-cta-shape cm-cta-shape-1" aria-hidden="true"></div>
      <div class="cm-cta-shape cm-cta-shape-2" aria-hidden="true"></div>
      <div class="cm-cta-inner">
        <p class="cm-cta-tag">Stratégie de contenus</p>
        <h2 class="cm-cta-title">Besoin d'une stratégie de <em class="font-serif">contenus SEO</em>&nbsp;?</h2>
        <p class="cm-cta-sub">Nos prestations incluent la recherche de mots-clés, le plan éditorial et la rédaction optimisée.</p>
        <div class="cm-cta-actions">
          <a href="/seo" class="cm-btn-white">Découvrir nos prestations SEO <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          <a href="/contact" class="cm-btn-ghost">Nous contacter</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .cm-container { max-width: 1300px; margin: 0 auto; padding: 0 2rem; }
  .cm-section { padding: 100px 0; position: relative; overflow: hidden; }
  .cm-eyebrow { display: block; font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 1rem; }
  .cm-section-header { max-width: 680px; margin: 0 auto 4rem; text-align: center; }
  .cm-section-header h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--color-text-primary); letter-spacing: -0.03em; line-height: 1.12; margin-bottom: 1rem; }
  .cm-section-header h2 em { font-style: italic; color: var(--color-accent); }
  .cm-fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .cm-fade-in.visible { opacity: 1; transform: none; }

  .cm-hero { position: relative; display: flex; align-items: center; justify-content: center; padding: 9rem 2rem 4rem; overflow: hidden; background: var(--color-background); text-align: center; }
  .cm-hero-inner { position: relative; z-index: 1; max-width: 780px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
  .cm-breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary); margin-bottom: 0.5rem; }
  .cm-breadcrumb a { color: var(--color-text-secondary); text-decoration: none; transition: color 0.2s ease; }
  .cm-breadcrumb a:hover { color: var(--color-accent); }
  .cm-breadcrumb span[aria-current] { color: var(--color-text-primary); font-weight: 600; }
  .cm-hero-title { font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; color: var(--color-text-primary); letter-spacing: -0.04em; line-height: 1.08; }
  .cm-hero-title em { font-style: italic; color: var(--color-accent); font-weight: 400; font-size: 1.05em; }
  .cm-hero-sub { font-size: clamp(1rem, 1.8vw, 1.125rem); color: var(--color-text-secondary); line-height: 1.7; max-width: 600px; }
  .cm-badges { display: flex; align-items: center; flex-wrap: wrap; justify-content: center; gap: 0.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border); }
  .cm-badge { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.8125rem; font-weight: 500; color: var(--color-text-secondary); }
  .cm-badge svg { color: var(--color-accent); }
  .cm-badge-dot { color: var(--color-border); font-size: 1.25rem; line-height: 1; }

  /* Tool */
  .cm-tool-section { padding-top: 2rem; background: var(--color-background); }
  .cm-app { max-width: 800px; margin: 0 auto; }
  .cm-app textarea { width: 100%; padding: 16px; border: 2px solid var(--color-border); border-radius: 16px; font-family: inherit; font-size: 15px; line-height: 1.7; color: var(--color-text-primary); background: white; resize: vertical; transition: border-color 0.3s ease; }
  .cm-app textarea:focus { outline: none; border-color: var(--color-accent); }
  .cm-keyword-row { margin-top: 16px; }
  .cm-keyword-row label { display: block; font-size: 14px; font-weight: 600; color: var(--color-text-primary); margin-bottom: 6px; }
  .cm-keyword-row input { width: 100%; padding: 10px 14px; border: 1px solid var(--color-border); border-radius: 10px; font-size: 14px; font-family: inherit; color: var(--color-text-primary); }
  .cm-keyword-row input:focus { outline: none; border-color: var(--color-accent); }
  .cm-setting-hint { font-size: 12px; color: var(--color-text-secondary); margin-top: 4px; }

  .cm-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 24px; }
  .cm-stat { background: white; border: 1px solid var(--color-border); border-radius: 14px; padding: 20px; text-align: center; }
  .cm-stat-num { display: block; font-size: 2rem; font-weight: 800; color: var(--color-accent); line-height: 1.1; }
  .cm-stat-label { display: block; font-size: 12px; color: var(--color-text-secondary); margin-top: 4px; font-weight: 500; }

  .cm-stats-secondary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 12px; }
  .cm-stat-s { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 14px; text-align: center; }
  .cm-stat-s-num { display: block; font-size: 1.125rem; font-weight: 700; color: var(--color-text-primary); }
  .cm-stat-s-label { display: block; font-size: 11px; color: var(--color-text-secondary); margin-top: 2px; }

  .cm-keyword-result, .cm-readability { background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 20px; margin-top: 16px; }
  .cm-keyword-result h3, .cm-readability h3, .cm-top-words h3 { font-size: 0.9375rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 14px; }
  .cm-kw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .cm-kw-item { text-align: center; }
  .cm-kw-val { display: block; font-size: 1.375rem; font-weight: 800; color: var(--color-accent); }
  .cm-kw-label { display: block; font-size: 11px; color: var(--color-text-secondary); margin-top: 2px; }

  .cm-top-words { background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 20px; margin-top: 16px; }
  .cm-words-table { width: 100%; border-collapse: collapse; }
  .cm-words-table th { font-size: 11px; font-weight: 700; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.06em; text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--color-border); }
  .cm-words-table td { font-size: 14px; padding: 8px 12px; border-bottom: 1px solid var(--color-border); color: var(--color-text-primary); }
  .cm-words-table tr:last-child td { border-bottom: none; }

  /* FAQ */
  .cm-faq { background: var(--color-background); }
  .cm-faq-inner { max-width: 780px; margin: 0 auto; }
  .cm-faq-list { display: flex; flex-direction: column; border: 1px solid var(--color-border); border-radius: 16px; overflow: hidden; background: white; }
  .cm-faq-item { border-bottom: 1px solid var(--color-border); }
  .cm-faq-item:last-child { border-bottom: none; }
  .cm-faq-question { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 1.5rem; cursor: pointer; font-size: 1rem; font-weight: 600; color: var(--color-text-primary); list-style: none; transition: background 0.2s ease; user-select: none; }
  .cm-faq-question::-webkit-details-marker { display: none; }
  .cm-faq-question:hover { background: rgba(37,99,235,0.03); }
  .cm-faq-icon { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: var(--color-accent-soft); color: var(--color-accent); display: flex; align-items: center; justify-content: center; transition: transform 0.3s ease, background 0.2s ease; }
  details[open] .cm-faq-icon { transform: rotate(45deg); background: var(--color-accent); color: white; }
  .cm-faq-answer { padding: 0 1.5rem 1.25rem; }
  .cm-faq-answer p { font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.75; }

  /* CTA */
  .cm-cta-section { position: relative; background: linear-gradient(135deg, #1D4ED8 0%, #2563EB 55%, #3B82F6 100%); padding: 7rem 2rem; min-height: 52vh; display: flex; align-items: center; justify-content: center; overflow: hidden; text-align: center; }
  .cm-cta-dotgrid { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 28px 28px; pointer-events: none; z-index: 0; }
  .cm-cta-shape { position: absolute; border-radius: 50%; pointer-events: none; }
  .cm-cta-shape-1 { width: 500px; height: 500px; background: rgba(255,255,255,0.05); top: -150px; right: -100px; animation: cm-float 12s ease-in-out infinite; }
  .cm-cta-shape-2 { width: 300px; height: 300px; background: rgba(255,255,255,0.04); bottom: -80px; left: -60px; animation: cm-float 15s ease-in-out infinite reverse; }
  @keyframes cm-float { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-30px) scale(1.05); } }
  .cm-cta-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .cm-cta-tag { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.6); }
  .cm-cta-title { font-size: clamp(2.25rem, 5.5vw, 4rem); font-weight: 700; color: white; letter-spacing: -0.03em; line-height: 1.1; }
  .cm-cta-title em { font-style: italic; font-family: var(--font-serif); font-weight: 400; }
  .cm-cta-sub { font-size: 1.0625rem; color: rgba(255,255,255,0.75); line-height: 1.65; }
  .cm-cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }
  .cm-btn-white { display: inline-flex; align-items: center; gap: 0.5rem; background: white; color: var(--color-accent); padding: 1rem 2rem; border-radius: 100px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .cm-btn-white:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
  .cm-btn-ghost { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: rgba(255,255,255,0.9); padding: 1rem 2rem; border-radius: 100px; font-weight: 600; font-size: 1rem; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.3); transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease; }
  .cm-btn-ghost:hover { border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.08); transform: translateY(-2px); }

  @media (max-width: 900px) { .cm-section { padding: 64px 0; } .cm-hero { padding: 8rem 1.25rem 3rem; } }
  @media (max-width: 640px) { .cm-container { padding: 0 1.25rem; } .cm-stats-grid { grid-template-columns: repeat(2, 1fr); } .cm-stats-secondary { grid-template-columns: 1fr; } .cm-kw-grid { grid-template-columns: 1fr; } .cm-cta-actions { flex-direction: column; align-items: center; } }
  @media (prefers-reduced-motion: reduce) { .cm-fade-in { opacity: 1; transform: none; transition: none; } .cm-cta-shape-1, .cm-cta-shape-2 { animation: none; } }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const textInput = document.getElementById('cmTextInput') as HTMLTextAreaElement;
  const keywordInput = document.getElementById('cmKeyword') as HTMLInputElement;

  const stopWords = new Set(['le','la','les','de','du','des','un','une','et','en','à','pour','sur','dans','avec','par','est','qui','que','ce','se','son','sa','ses','au','aux','ne','pas','plus','très','tout','nous','vous','ils','cette','ces','ont','sont','leur','été','même','aussi','bien','mais','ou','car','donc','ni','l','d','n','s','c','j','qu','il','elle','on','je','tu','y','a','ai','ma','ta','mon','ton','me','te','si','ça','être','avoir','fait','faire','dit','va','peut','faut','comme','quand','tout','tous','toute','toutes']);

  function analyze() {
    const text = textInput?.value || '';
    const keyword = keywordInput?.value?.trim().toLowerCase() || '';

    // Basic counts
    const words = text.trim() ? text.trim().split(/\s+/) : [];
    const wordCount = words.length;
    const charCount = text.length;
    const charNoSpace = text.replace(/\s/g, '').length;
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
    const sentenceCount = text.trim() ? sentences.length : 0;
    const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim().length > 0);
    const paragraphCount = text.trim() ? Math.max(paragraphs.length, text.trim() ? 1 : 0) : 0;

    // Times
    const readMinutes = Math.floor(wordCount / 238);
    const readSeconds = Math.round((wordCount / 238 - readMinutes) * 60);
    const speakMinutes = Math.floor(wordCount / 150);
    const speakSeconds = Math.round((wordCount / 150 - speakMinutes) * 60);

    // Update DOM
    (document.getElementById('cmWords') as HTMLElement).textContent = wordCount.toLocaleString('fr-FR');
    (document.getElementById('cmChars') as HTMLElement).textContent = charCount.toLocaleString('fr-FR');
    (document.getElementById('cmSentences') as HTMLElement).textContent = String(sentenceCount);
    (document.getElementById('cmParagraphs') as HTMLElement).textContent = String(paragraphCount);
    (document.getElementById('cmReadTime') as HTMLElement).textContent = wordCount === 0 ? '0 min' : `${readMinutes} min ${readSeconds < 10 ? '0' : ''}${readSeconds} sec`;
    (document.getElementById('cmSpeakTime') as HTMLElement).textContent = wordCount === 0 ? '0 min' : `${speakMinutes} min ${speakSeconds < 10 ? '0' : ''}${speakSeconds} sec`;
    (document.getElementById('cmCharsNoSpace') as HTMLElement).textContent = charNoSpace.toLocaleString('fr-FR');

    // Keyword density
    const kwResult = document.getElementById('cmKeywordResult');
    if (keyword && wordCount > 0) {
      const regex = new RegExp(keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
      const matches = text.match(regex);
      const occurrences = matches ? matches.length : 0;
      const density = (occurrences / wordCount) * 100;

      let verdict = '';
      let color = '';
      if (density < 0.5) { verdict = '⚠️ Trop faible'; color = '#d97706'; }
      else if (density < 1) { verdict = '✓ Acceptable'; color = '#16a34a'; }
      else if (density <= 2) { verdict = '✅ Idéal'; color = '#16a34a'; }
      else if (density <= 3) { verdict = '⚠️ Élevée'; color = '#d97706'; }
      else { verdict = '❌ Sur-optimisé'; color = '#dc2626'; }

      (document.getElementById('cmKwOccurrences') as HTMLElement).textContent = String(occurrences);
      const densityEl = document.getElementById('cmKwDensity') as HTMLElement;
      densityEl.textContent = density.toFixed(1) + '%';
      densityEl.style.color = color;
      (document.getElementById('cmKwVerdict') as HTMLElement).textContent = verdict;
      kwResult!.style.display = 'block';
    } else {
      kwResult!.style.display = 'none';
    }

    // Readability
    const readabilityPanel = document.getElementById('cmReadability');
    if (wordCount >= 10) {
      const avgSentenceLen = sentenceCount > 0 ? wordCount / sentenceCount : wordCount;
      const avgWordLen = charNoSpace / Math.max(wordCount, 1);

      // Simple readability: shorter sentences + shorter words = higher score
      let score = Math.round(100 - (avgSentenceLen - 15) * 2.5 - (avgWordLen - 4.5) * 10);
      score = Math.min(100, Math.max(0, score));

      let level = '';
      if (score >= 80) level = 'Très facile';
      else if (score >= 60) level = 'Facile à lire';
      else if (score >= 40) level = 'Modéré';
      else level = 'Complexe';

      (document.getElementById('cmReadScore') as HTMLElement).textContent = String(score);
      (document.getElementById('cmReadLevel') as HTMLElement).textContent = level;
      (document.getElementById('cmAvgSentence') as HTMLElement).textContent = avgSentenceLen.toFixed(1);
      readabilityPanel!.style.display = 'block';
    } else {
      readabilityPanel!.style.display = 'none';
    }

    // Top words
    const topWordsPanel = document.getElementById('cmTopWords');
    const tbody = document.getElementById('cmWordsBody');
    if (wordCount >= 5 && tbody) {
      const freq: Record<string, number> = {};
      words.forEach(w => {
        const clean = w.toLowerCase().replace(/[^a-zàâäéèêëïîôùûüÿçœæ'-]/g, '');
        if (clean.length >= 3 && !stopWords.has(clean)) {
          freq[clean] = (freq[clean] || 0) + 1;
        }
      });

      const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 10);
      tbody.innerHTML = sorted.map(([word, count], i) => `<tr><td>${i + 1}</td><td style="font-weight:600">${word}</td><td>${count}</td><td>${((count / wordCount) * 100).toFixed(1)}%</td></tr>`).join('');
      topWordsPanel!.style.display = sorted.length > 0 ? 'block' : 'none';
    } else {
      topWordsPanel!.style.display = 'none';
    }
  }

  textInput?.addEventListener('input', analyze);
  keywordInput?.addEventListener('input', analyze);

  // Fade-in
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.cm-fade-in').forEach(el => observer.observe(el));
});
</script>
