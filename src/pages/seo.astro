---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import BgWords from '../components/BgWords.astro';
import BgOrbs from '../components/BgOrbs.astro';
import BgDots from '../components/BgDots.astro';

const seoServices = [
  {
    iconPath: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
    title: 'Audit SEO complet',
    desc: "Analyse approfondie de votre site : technique, contenu, structure, backlinks, concurrence. Un état des lieux précis avec des recommandations priorisées.",
    deliverables: ['Rapport détaillé', 'Quick wins', "Plan d'action"],
  },
  {
    iconPath: `<path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>`,
    title: 'Optimisation technique',
    desc: "Vitesse de chargement, indexation, balisage, Core Web Vitals, sitemap, robots.txt, schema JSON-LD. On rend votre site techniquement irréprochable.",
    deliverables: ['Performance', 'Indexation', 'Données structurées'],
  },
  {
    iconPath: `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>`,
    title: 'Stratégie de contenus',
    desc: "Recherche de mots-clés, plan éditorial, rédaction optimisée, maillage interne. Des contenus qui se positionnent et qui convertissent.",
    deliverables: ['Mots-clés', 'Plan éditorial', 'Rédaction SEO'],
  },
  {
    iconPath: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
    title: 'SEO local',
    desc: "Google Business Profile, cohérence NAP, pages zones géographiques, avis clients. Indispensable si votre activité dépend d'une zone de chalandise.",
    deliverables: ['Google Business', 'Pages locales', 'Citations'],
  },
  {
    iconPath: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,
    title: 'Netlinking & autorité',
    desc: "Acquisition de backlinks de qualité, analyse du profil de liens, détection de liens toxiques. On renforce l'autorité de votre domaine.",
    deliverables: ['Backlinks', 'Domain Authority', 'Désaveu'],
    isNew: false,
  },
  {
    iconPath: `<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>`,
    title: 'GEO — Visibilité IA',
    desc: "Optimisation pour les moteurs de recherche IA : ChatGPT, Perplexity, Google AI Mode. Positionnez votre marque dans les réponses générées par l'IA.",
    deliverables: ['AI citations', 'Autorité topique', 'Suivi GEO'],
    isNew: true,
  },
];

const soRankFeatures = [
  {
    iconPath: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    title: 'Audits automatisés & priorisés',
    desc: "Chaque recommandation est transformée en tâche actionnable, classée par impact.",
  },
  {
    iconPath: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
    title: 'Tracking Google + IA',
    desc: "Suivez vos positions sur Google ET votre visibilité sur ChatGPT, Perplexity, Google AI Mode.",
  },
  {
    iconPath: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
    title: 'Analyse concurrentielle temps réel',
    desc: "Alertes automatiques quand vos concurrents publient du contenu ou gagnent des backlinks.",
  },
  {
    iconPath: `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>`,
    title: 'Génération de contenus SEO',
    desc: "Articles optimisés pour Google et les moteurs IA, générés et publiables directement.",
  },
  {
    iconPath: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/>`,
    title: 'Rapports clients white-label',
    desc: "Des rapports clairs et professionnels envoyés automatiquement chaque mois.",
  },
];

const processSteps = [
  { num: '01', title: 'Audit & diagnostic', desc: "On passe votre site au crible : technique, contenu, concurrence, backlinks. On identifie les freins et les opportunités.", livrable: "Rapport d'audit complet + recommandations priorisées", duration: '3-5 jours' },
  { num: '02', title: 'Stratégie & plan d\'action', desc: "On définit les objectifs, les mots-clés cibles, le calendrier éditorial et les KPIs. Tout est cadré avant d'agir.", livrable: 'Plan SEO 6-12 mois + tableau de bord', duration: '1 semaine' },
  { num: '03', title: 'Optimisations techniques', desc: "On corrige les problèmes techniques : vitesse, indexation, balisage, structure Hn, schema JSON-LD, maillage interne.", livrable: 'Site techniquement optimisé + checklist validée', duration: '1-2 semaines' },
  { num: '04', title: 'Contenus & netlinking', desc: "On crée et optimise les contenus, on met en place la stratégie de liens. Chaque action est mesurée.", livrable: 'Contenus publiés + backlinks acquis', duration: 'En continu' },
  { num: '05', title: 'Suivi & reporting', desc: "Chaque mois : rapport de performance, analyse des évolutions, ajustements stratégiques. Vous avez une visibilité totale.", livrable: 'Rapport mensuel + call de suivi', duration: 'Mensuel' },
];

const caseStudies = [
  { client: 'Love at Me', type: 'E-commerce Shopify', desc: "SEO multilingue sur ~560 pages. Optimisation meta, JSON-LD, hreflang.", result: '+180% de trafic organique en 4 mois', accent: '#7C3AED' },
  { client: 'Miroiterie VITOR', type: 'WordPress · Artisan local', desc: "SEO local + Google Ads. Structure, contenus, Google Business Profile.", result: '1ère page Google sur les mots-clés cibles en 3 mois', accent: '#2563EB' },
  { client: 'Griffe Event Solutions', type: 'WordPress · Événementiel', desc: "Audit SEO complet + plan d'action. Quick wins + stratégie long terme.", result: '+120% de demandes de devis via le site', accent: '#059669' },
];

const faqItems = [
  { q: "Combien de temps faut-il pour voir des résultats en SEO ?", a: "Le SEO est un investissement moyen-long terme. Les premiers signaux apparaissent généralement sous 4 à 8 semaines (améliorations techniques, indexation). Des résultats significatifs en termes de trafic et de positionnement se construisent sur 3 à 6 mois. La durée dépend de votre secteur, de la concurrence et de l'état initial de votre site.", open: true },
  { q: "Quelle est la différence entre SEO et SEA (Google Ads) ?", a: "Le SEA (publicité) vous donne de la visibilité immédiate mais payante : dès que vous arrêtez de payer, vous disparaissez. Le SEO construit une visibilité organique durable — votre site se positionne naturellement sur Google. Les deux sont complémentaires : le SEA pour le court terme, le SEO pour le long terme." },
  { q: "Est-ce que vous garantissez la première position sur Google ?", a: "Non. Personne ne peut garantir une position précise — Google évalue plus de 200 facteurs de classement. Ce qu'on garantit : une méthodologie structurée, des actions concrètes, un suivi transparent et des résultats mesurables. Méfiez-vous de quiconque vous promet la position #1." },
  { q: "J'ai déjà un site, faut-il le refaire pour travailler le SEO ?", a: "Pas forcément. Dans beaucoup de cas, on peut optimiser votre site existant sans refonte : structure, contenus, balisage, performance, maillage interne. Une refonte n'est nécessaire que si votre site est techniquement obsolète ou bloque la progression SEO." },
  { q: "C'est quoi le GEO (Generative Engine Optimization) ?", a: "Le GEO, c'est l'optimisation pour les moteurs de recherche IA — ChatGPT, Perplexity, Google AI Mode. Ces plateformes citent des sources web dans leurs réponses. Le GEO vise à ce que votre site soit choisi comme source fiable par ces IA. C'est le futur du référencement, et on l'intègre déjà dans notre approche." },
  { q: "Comment se déroule le suivi mensuel ?", a: "Chaque mois, vous recevez un rapport détaillé : évolution des positions, trafic organique, actions réalisées, recommandations pour le mois suivant. On planifie un call de 30 minutes pour le parcourir ensemble et ajuster la stratégie si nécessaire." },
  { q: "Travaillez-vous avec tous les CMS ?", a: "Oui. WordPress, Shopify, Webflow, Wix, PrestaShop, sites sur-mesure — on intervient sur tous les CMS. Les optimisations techniques s'adaptent à chaque plateforme." },
  { q: "Quel budget prévoir pour une prestation SEO ?", a: "Le budget dépend de l'ampleur du projet : nombre de pages, niveau de concurrence, objectifs de positionnement, besoin en contenus. Chaque prestation est chiffrée sur-mesure après un audit initial. On vous envoie un devis détaillé avant tout engagement." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Référencement SEO & GEO",
  "provider": {
    "@type": "ProfessionalService",
    "name": "DISAYNER",
    "url": "https://disayner.com",
    "areaServed": "FR",
    "address": { "@type": "PostalAddress", "addressRegion": "Haute-Savoie", "addressCountry": "FR" }
  },
  "description": "Prestation SEO complète : audit technique, stratégie de contenus, netlinking, SEO local et visibilité IA (GEO). En partenariat avec SoRank.",
  "serviceType": ["Audit SEO", "Optimisation technique", "Stratégie de contenus", "SEO local", "Netlinking", "GEO - Visibilité IA"]
};
---

<Layout
  title="Référencement SEO & GEO — Positionnement Google & visibilité IA | DISAYNER"
  description="Prestation SEO complète : audit, optimisation technique, contenus, netlinking et visibilité IA (GEO). En partenariat avec SoRank. Résultats mesurables. Devis gratuit."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S1 — HERO                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="sp-hero" aria-label="Référencement SEO & GEO">
      <BgWords words={[
        { text: 'SEO',     x: '-4%', y: '14%', rot: '-12deg', size: '9vw' },
        { text: 'GOOGLE',  x: '62%', y: '6%',  rot: '8deg',   size: '6vw' },
        { text: 'RANKING', x: '5%',  y: '70%', rot: '-5deg',  size: '6vw' },
        { text: 'TRAFIC',  x: '68%', y: '76%', rot: '12deg',  size: '7vw' },
      ]} />
      <BgOrbs orbs={[
        { type: 'filled', x: '85%', y: '20%', size: '300px', dur: '14s' },
        { type: 'ring',   x: '10%', y: '80%', size: '200px', dur: '18s' },
        { type: 'ring',   x: '50%', y: '10%', size: '150px', dur: '12s' },
      ]} />

      <div class="sp-hero-inner">
        <!-- Left: Text -->
        <div class="sp-hero-text">
          <p class="sp-eyebrow">Référencement SEO</p>
          <h1 class="sp-hero-title">
            Rendez votre site <em class="font-serif">visible</em><br class="sp-br-lg" />là où vos clients vous cherchent.
          </h1>
          <p class="sp-hero-sub">
            Stratégie SEO sur-mesure, optimisation technique, contenus performants et suivi de résultats. On positionne votre site sur Google — et sur les moteurs IA.
          </p>
          <div class="sp-hero-ctas">
            <a href="/contact" class="btn-primary">
              Demander un audit gratuit
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#resultats" class="btn-outline">Voir nos résultats</a>
          </div>
          <div class="sp-badges" role="list" aria-label="Points forts">
            <span class="sp-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              +200% trafic moyen
            </span>
            <span class="sp-badge-dot" aria-hidden="true">·</span>
            <span class="sp-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Partenaire SoRank
            </span>
            <span class="sp-badge-dot" aria-hidden="true">·</span>
            <span class="sp-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              SEO + GEO (IA)
            </span>
            <span class="sp-badge-dot" aria-hidden="true">·</span>
            <span class="sp-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Suivi mensuel
            </span>
          </div>
        </div>

        <!-- Right: Chart visual -->
        <div class="sp-hero-visual" aria-hidden="true">
          <div class="sp-chart-card">
            <div class="sp-chart-header">
              <span class="sp-chart-title">Trafic organique</span>
              <span class="sp-chart-period">12 derniers mois</span>
            </div>
            <div class="sp-chart-badge">+200% <span>trafic</span></div>
            <div class="sp-chart-wrap">
              <svg viewBox="0 0 380 120" class="sp-chart-svg" role="img" aria-label="Courbe de croissance du trafic organique">
                <defs>
                  <linearGradient id="spSeoGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#2563EB" stop-opacity="0.15"/>
                    <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <!-- Grid lines -->
                <line x1="0" y1="30"  x2="380" y2="30"  stroke="#EEEEEA" stroke-width="1"/>
                <line x1="0" y1="60"  x2="380" y2="60"  stroke="#EEEEEA" stroke-width="1"/>
                <line x1="0" y1="90"  x2="380" y2="90"  stroke="#EEEEEA" stroke-width="1"/>
                <!-- Fill -->
                <path class="sp-chart-fill" d="M0,105 C40,102 70,95 120,82 S190,58 240,40 S310,18 380,8 V120 H0 Z" fill="url(#spSeoGrad)"/>
                <!-- Line -->
                <path class="sp-chart-line" d="M0,105 C40,102 70,95 120,82 S190,58 240,40 S310,18 380,8" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round"/>
                <!-- Data points -->
                <circle cx="120" cy="82" r="5" fill="#2563EB"/>
                <circle cx="120" cy="82" r="2.5" fill="white"/>
                <circle cx="240" cy="40" r="5" fill="#2563EB"/>
                <circle cx="240" cy="40" r="2.5" fill="white"/>
                <circle cx="380" cy="8"  r="6" fill="#2563EB" class="sp-pulse-dot"/>
                <circle cx="380" cy="8"  r="3" fill="white"/>
              </svg>
            </div>
            <div class="sp-chart-labels">
              <span>Jan</span><span>Mar</span><span>Mai</span><span>Juil</span><span>Sep</span><span>Nov</span>
            </div>
            <!-- Mini stats row -->
            <div class="sp-chart-stats">
              <div class="sp-chart-stat">
                <span class="sp-chart-stat-val">+47</span>
                <span class="sp-chart-stat-lbl">Positions gagnées</span>
              </div>
              <div class="sp-chart-stat-sep"></div>
              <div class="sp-chart-stat">
                <span class="sp-chart-stat-val">3,2×</span>
                <span class="sp-chart-stat-lbl">Taux de clics</span>
              </div>
              <div class="sp-chart-stat-sep"></div>
              <div class="sp-chart-stat">
                <span class="sp-chart-stat-val">12</span>
                <span class="sp-chart-stat-lbl">Citations IA</span>
              </div>
            </div>
          </div>
          <!-- SoRank badge -->
          <div class="sp-sorank-float">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Propulsé par <strong>SoRank</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S2 — LE PROBLÈME                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="sp-section sp-problem" aria-label="L'importance du SEO">
      <div class="sp-container">
        <div class="sp-section-header section-header-anim">
          <p class="sp-eyebrow">Le constat</p>
          <h2>Un beau site sans SEO, c'est une <em class="font-serif">vitrine dans une ruelle</em>.</h2>
          <p class="sp-section-sub sp-problem-intro">
            90% des expériences en ligne commencent par une recherche Google. Si votre site n'apparaît pas dans les premiers résultats, vos concurrents captent vos clients à votre place. Le SEO n'est pas un bonus — c'est la base de votre acquisition digitale.
          </p>
        </div>

        <div class="sp-stats-row">
          <div class="sp-stat-block sp-fade-in">
            <span class="sp-stat-num" data-value="90" data-suffix="%">0%</span>
            <p class="sp-stat-label">des expériences commencent sur un moteur de recherche</p>
          </div>
          <div class="sp-stat-block sp-fade-in" style="transition-delay:0.1s">
            <span class="sp-stat-num" data-value="75" data-suffix="%">0%</span>
            <p class="sp-stat-label">des utilisateurs ne dépassent jamais la page 1 de Google</p>
          </div>
          <div class="sp-stat-block sp-fade-in" style="transition-delay:0.2s">
            <span class="sp-stat-num" data-value="0.63" data-suffix="%" data-decimal="true">0%</span>
            <p class="sp-stat-label">des clics vont au-delà de la première page de résultats</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S3 — NOS SERVICES SEO                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="sp-section sp-services" aria-label="Nos prestations SEO">
      <div class="sp-container">
        <div class="sp-section-header section-header-anim">
          <p class="sp-eyebrow">Nos prestations</p>
          <h2>Une approche SEO <em class="font-serif">complète et structurée</em>.</h2>
          <p class="sp-section-sub">Du diagnostic à l'exécution, chaque action est priorisée pour maximiser votre retour sur investissement.</p>
        </div>

        <div class="sp-services-grid">
          {seoServices.map((svc, i) => (
            <article class="sp-svc-card sp-fade-in" style={`transition-delay:${i * 0.08}s`} aria-label={`Service : ${svc.title}`}>
              <div class="sp-svc-header">
                <div class="sp-svc-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svc.iconPath} />
                </div>
                {svc.isNew && <span class="sp-new-badge">Nouveau</span>}
              </div>
              <h3 class="sp-svc-title">{svc.title}</h3>
              <p class="sp-svc-desc">{svc.desc}</p>
              <div class="sp-svc-deliverables">
                {svc.deliverables.map(d => <span class="sp-tag">{d}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S4 — SORANK PARTNERSHIP                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="sp-section sp-sorank" aria-label="Partenariat SoRank">
      <BgDots pulseCount={5} variant="accent" />
      <div class="sp-container sp-sorank-inner" style="position:relative;z-index:1;">
        <!-- Left: Dashboard mockup -->
        <div class="sp-sorank-visual sp-fade-in" aria-hidden="true">
          <div class="sp-dashboard">
            <div class="sp-dashboard-header">
              <div class="sp-dashboard-logo">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span>SoRank</span>
              </div>
              <div class="sp-dashboard-dots">
                <span></span><span></span><span></span>
              </div>
            </div>
            <!-- KPI row -->
            <div class="sp-dashboard-kpis">
              <div class="sp-kpi">
                <span class="sp-kpi-val">42</span>
                <span class="sp-kpi-lbl">Domain Authority</span>
                <span class="sp-kpi-trend sp-kpi-trend--up">↑ +5</span>
              </div>
              <div class="sp-kpi">
                <span class="sp-kpi-val">127</span>
                <span class="sp-kpi-lbl">Mots-clés suivis</span>
                <span class="sp-kpi-trend sp-kpi-trend--up">↑ +18</span>
              </div>
              <div class="sp-kpi sp-kpi--accent">
                <span class="sp-kpi-val">14</span>
                <span class="sp-kpi-lbl">Citations IA</span>
                <span class="sp-kpi-trend sp-kpi-trend--up">↑ +6</span>
              </div>
