    font-weight: 400;
    font-size: 1.05em;
    letter-spacing: -0.02em;
  }

  .sp-hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 540px;
  }

  .sp-hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  .sp-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .sp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .sp-badge svg { color: var(--color-accent); }
  .sp-badge-dot { color: var(--color-border); font-size: 1.25rem; line-height: 1; }
  .sp-br-lg { display: block; }

  /* Chart card */
  .sp-hero-visual { position: relative; }

  .sp-chart-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08);
  }

  .sp-chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .sp-chart-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .sp-chart-period {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .sp-chart-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
  }

  .sp-chart-badge span {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .sp-chart-wrap { position: relative; margin-bottom: 0.5rem; }

  .sp-chart-svg { width: 100%; display: block; }

  .sp-chart-fill { opacity: 0; animation: sp-fill-in 1.5s ease-out 0.4s forwards; }
  .sp-chart-line {
    stroke-dasharray: 520;
    stroke-dashoffset: 520;
    animation: sp-line-draw 1.5s ease-out 0.4s forwards;
  }

  @keyframes sp-line-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes sp-fill-in {
    to { opacity: 1; }
  }

  .sp-pulse-dot { animation: sp-pulse 2s ease-in-out infinite 2s; }

  @keyframes sp-pulse {
    0%, 100% { r: 6; opacity: 1; }
    50% { r: 9; opacity: 0.7; }
  }

  .sp-chart-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding: 0 2px;
  }

  .sp-chart-stats {
    display: flex;
    align-items: center;
    gap: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .sp-chart-stat { flex: 1; text-align: center; }

  .sp-chart-stat-val {
    display: block;
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.03em;
  }

  .sp-chart-stat-lbl {
    display: block;
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
    margin-top: 0.15rem;
  }

  .sp-chart-stat-sep {
    width: 1px;
    height: 32px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* SoRank floating badge */
  .sp-sorank-float {
    position: absolute;
    bottom: -12px;
    left: 24px;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: white;
    border: 1px solid rgba(37,99,235,0.2);
    border-radius: 100px;
    padding: 0.4rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    animation: sp-badge-float 4s ease-in-out infinite;
  }

  .sp-sorank-float strong { color: var(--color-accent); font-weight: 700; }

  @keyframes sp-badge-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* ─── S2: PROBLEM ─────────────────────────────────────────────────────── */
  .sp-problem {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .sp-problem-intro {
    margin-top: 1rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .sp-stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    margin-top: 3rem;
  }

  .sp-stat-block {
    padding: 2.5rem 2rem;
    text-align: center;
    border-right: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .sp-stat-block:last-child { border-right: none; }
  .sp-stat-block:hover { background: rgba(37,99,235,0.02); }

  .sp-stat-num {
    display: block;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .sp-stat-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ─── S3: SERVICES ────────────────────────────────────────────────────── */
  .sp-services { background: var(--color-background); }

  .sp-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .sp-svc-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .sp-svc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .sp-svc-card:hover { transform: translateY(-6px); box-shadow: 0 14px 40px rgba(0,0,0,0.08); border-color: rgba(37,99,235,0.2); }
  .sp-svc-card:hover::before { transform: scaleX(1); }

  .sp-svc-header { display: flex; align-items: center; justify-content: space-between; }

  .sp-svc-icon {
    width: 52px;
    height: 52px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-svc-title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text-primary); letter-spacing: -0.02em; }

  .sp-svc-desc { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.65; flex: 1; }

  .sp-svc-deliverables { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  /* ─── S4: SORANK ──────────────────────────────────────────────────────── */
  .sp-sorank {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .sp-sorank-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .sp-sorank-badge-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37,99,235,0.2);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .sp-sorank-intro {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .sp-sorank-features { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 2rem; }

  .sp-sorank-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: 10px;
    transition: background 0.2s ease;
  }

  .sp-sorank-feature:hover { background: rgba(37,99,235,0.04); }

  .sp-sorank-feat-icon {
    width: 36px;
    height: 36px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-sorank-feat-title { display: block; font-size: 0.9375rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 0.2rem; }

  .sp-sorank-feat-desc { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.55; }

  .sp-sorank-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .sp-sorank-link:hover { opacity: 0.7; text-decoration: underline; }

  /* Dashboard mockup */
  .sp-dashboard {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.07);
  }

  .sp-dashboard-header {
    padding: 12px 16px;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sp-dashboard-logo {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
  }

  .sp-dashboard-dots { display: flex; gap: 4px; }
  .sp-dashboard-dots span { width: 8px; height: 8px; border-radius: 50%; background: var(--color-border); }

  .sp-dashboard-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-bottom: 1px solid var(--color-border);
  }

  .sp-kpi {
    padding: 12px;
    border-right: 1px solid var(--color-border);
    text-align: center;
  }

  .sp-kpi:last-child { border-right: none; }
  .sp-kpi--accent { background: rgba(37,99,235,0.03); }

  .sp-kpi-val { display: block; font-size: 1.375rem; font-weight: 800; color: var(--color-accent); letter-spacing: -0.03em; line-height: 1.2; }
  .sp-kpi-lbl { display: block; font-size: 0.6rem; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 2px; }
  .sp-kpi-trend { display: inline-block; font-size: 0.6875rem; font-weight: 700; margin-top: 3px; }
  .sp-kpi-trend--up { color: #16a34a; }

  .sp-dashboard-chart { padding: 12px 16px; border-bottom: 1px solid var(--color-border); }
  .sp-dc-label { font-size: 0.6875rem; font-weight: 600; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }

  .sp-dashboard-tasks { padding: 12px 16px; }

  .sp-task {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .sp-task:last-child { border-bottom: none; }
  .sp-task--done { color: var(--color-text-primary); }
  .sp-task--done span:nth-child(2) { text-decoration: line-through; opacity: 0.5; }

  .sp-task-check {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #22c55e;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    flex-shrink: 0;
    font-weight: 700;
  }

  .sp-task-check--empty { background: transparent; border: 1.5px solid var(--color-border); }

  .sp-task-impact {
    margin-left: auto;
    font-size: 0.625rem;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .sp-task-impact--high { background: rgba(239,68,68,0.1); color: #dc2626; }
  .sp-task-impact--medium { background: rgba(234,179,8,0.1); color: #b45309; }

  /* ─── S5: PROCESS ─────────────────────────────────────────────────────── */
  .sp-process { background: var(--color-background); }

  .sp-timeline {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
    padding-left: 3rem;
  }

  .sp-timeline-line {
    position: absolute;
    left: 15px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: var(--color-border);
    border-radius: 1px;
  }

  .sp-step { display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start; position: relative; }
  .sp-step:last-child { margin-bottom: 0; }

  .sp-step-circle {
    position: absolute;
    left: -3rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    flex-shrink: 0;
    z-index: 1;
    margin-top: 4px;
  }

  .sp-step-card {
    flex: 1;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.375rem 1.5rem;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .sp-step-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.06); border-color: rgba(37,99,235,0.25); }

  .sp-step-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; }

  .sp-step-title { font-size: 1rem; font-weight: 700; color: var(--color-text-primary); letter-spacing: -0.01em; }

  .sp-step-duration {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border: 1px solid rgba(37,99,235,0.15);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sp-step-desc { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.65; margin-bottom: 0.75rem; }

  .sp-step-livrable {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-weight: 500;
    padding-top: 0.625rem;
    border-top: 1px solid var(--color-border);
  }

  .sp-step-livrable svg { flex-shrink: 0; margin-top: 1px; }

  /* ─── S6: SEO vs GEO ──────────────────────────────────────────────────── */
  .sp-geo { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }

  .sp-geo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

  .sp-geo-col {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2rem;
  }

  .sp-geo-col--accent {
    background: var(--color-accent-soft);
    border-color: rgba(37,99,235,0.2);
  }

  .sp-geo-col-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .sp-geo-col-header h3 { font-size: 1.0625rem; font-weight: 700; color: var(--color-text-primary); }

  .sp-geo-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-geo-icon--google { background: var(--color-surface); color: var(--color-text-secondary); }
  .sp-geo-icon--ia { background: rgba(37,99,235,0.12); color: var(--color-accent); }

  .sp-geo-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }

  .sp-geo-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .sp-geo-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(37,99,235,0.1);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    margin-top: 1px;
  }

  .sp-geo-conclusion {
    margin-top: 2.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .sp-geo-conclusion p {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 700px;
  }

  /* ─── S7: RESULTS ─────────────────────────────────────────────────────── */
  .sp-results { background: var(--color-background); }

  .sp-metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .sp-metric {
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-right: 1px solid var(--color-border);
    transition: background 0.2s ease;
  }

  .sp-metric:last-child { border-right: none; }
  .sp-metric:hover { background: rgba(37,99,235,0.02); }

  .sp-metric-num {
    display: block;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.625rem;
  }

  .sp-metric-label { font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.4; font-weight: 500; }

  .sp-cases { display: flex; flex-direction: column; gap: 1rem; }

  .sp-case-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .sp-case-card:hover { transform: translateX(4px); box-shadow: 0 6px 24px rgba(0,0,0,0.06); }

  .sp-case-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }

  .sp-case-info { flex: 1; }

  .sp-case-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.375rem; flex-wrap: wrap; }

  .sp-case-client { font-size: 1rem; font-weight: 700; color: var(--color-text-primary); }

  .sp-case-type { font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-surface); border: 1px solid var(--color-border); padding: 0.2rem 0.6rem; border-radius: 100px; }

  .sp-case-desc { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 0.375rem; }

  .sp-case-result { font-size: 0.875rem; font-weight: 700; }

  /* ─── S8: FOR WHOM ────────────────────────────────────────────────────── */
  .sp-forwhom { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }

  .sp-forwhom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }

  .sp-forwhom-col { background: white; border: 1px solid var(--color-border); border-radius: 20px; padding: 2rem; }

  .sp-forwhom-title { font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1.25rem; padding-bottom: 0.875rem; border-bottom: 1px solid var(--color-border); }

  .sp-forwhom-title--yes { color: #16a34a; }
  .sp-forwhom-title--no { color: var(--color-text-secondary); }

  .sp-forwhom-list { list-style: none; display: flex; flex-direction: column; gap: 0.875rem; }

  .sp-forwhom-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .sp-forwhom-item--no { opacity: 0.75; }

  .sp-fw-icon {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .sp-fw-icon--yes { background: rgba(34,197,94,0.12); }
  .sp-fw-icon--no  { background: rgba(239,68,68,0.1); }

  .sp-inline-link { color: var(--color-accent); text-decoration: underline; font-weight: 500; }

  /* ─── S10: FAQ ────────────────────────────────────────────────────────── */
  .sp-faq { background: var(--color-background); }

  .sp-faq-inner { max-width: 780px; margin: 0 auto; }

  .sp-faq-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    background: white;
