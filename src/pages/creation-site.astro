---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import BgWords from '../components/BgWords.astro';
import BgDots from '../components/BgDots.astro';
import { caseStudies as allCaseStudies } from '../content/case-studies/data';

const siteProjects = allCaseStudies.filter(cs => cs.categories.includes('site-vitrine')).slice(0, 3);

const categoryAccents: Record<string, string> = {
  'site-vitrine': '#2563EB',
  'seo':          '#7C3AED',
  'e-commerce':   '#059669',
  'landing-page': '#F59E0B',
};

const siteTypes = [
  {
    iconPath: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    title: 'Site vitrine',
    desc: "Votre carte de visite digitale. Un site élégant et performant qui présente votre activité, vos services et génère des prises de contact qualifiées.",
    features: ['Design sur-mesure & responsive', 'Pages services, à propos, contact', 'Base SEO optimisée dès le départ', 'Formulaire de contact connecté'],
    tags: ['WordPress', 'Webflow', 'Sur-mesure'],
  },
  {
    iconPath: `<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>`,
    title: 'E-commerce',
    desc: "Vendez en ligne avec une boutique performante, sécurisée et pensée pour maximiser vos conversions. De la fiche produit au tunnel d'achat.",
    features: ['Catalogue produits optimisé', "Tunnel d'achat fluide", 'Paiement sécurisé (Stripe, PayPal)', 'Gestion des stocks & commandes'],
    tags: ['Shopify', 'WooCommerce'],
  },
  {
    iconPath: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`,
    title: 'Landing page',
    desc: "Une page unique, focalisée sur un seul objectif : convertir. Idéale pour vos campagnes publicitaires, lancements ou offres spéciales.",
    features: ['Un seul objectif, zéro distraction', 'Optimisée pour la conversion', 'A/B testing ready', 'Intégration tracking & analytics'],
    tags: ['Sur-mesure', 'Webflow'],
  },
];

const differentiators = [
  {
    iconPath: `<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>`,
    title: 'Design premium, pas du template',
    desc: 'Chaque site est conçu de zéro. Pas de thème acheté, pas de copier-coller. Votre site est unique.',
  },
  {
    iconPath: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
    title: 'SEO intégré nativement',
    desc: 'La structure, les balises, la performance : le référencement est pensé dès la conception, pas ajouté après coup.',
  },
  {
    iconPath: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    title: 'Performance maximale',
    desc: 'Score Lighthouse 95+. Temps de chargement optimisé, images compressées, code propre.',
  },
  {
    iconPath: `<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>`,
    title: 'Responsive pixel-perfect',
    desc: 'Votre site est impeccable sur desktop, tablette et mobile. Chaque breakpoint est testé et ajusté.',
  },
  {
    iconPath: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Accompagnement complet',
    desc: "De la stratégie à la mise en ligne, un seul interlocuteur qui comprend vos enjeux business.",
  },
];

const processSteps = [
  { num: '01', title: 'Appel découverte (offert)', desc: "30 minutes pour comprendre votre activité, vos objectifs et vos contraintes. On évalue ensemble si le projet a du sens.", duration: '30 min · Gratuit' },
  { num: '02', title: 'Proposition & devis', desc: "On vous envoie une proposition détaillée : périmètre, planning, livrables et tarif. Tout est clair avant de commencer.", duration: '48-72h' },
  { num: '03', title: 'Maquettes & direction artistique', desc: "Wireframes puis maquettes graphiques de votre site. Vous validez le design avant qu'on écrive la moindre ligne de code.", duration: '1-2 semaines' },
  { num: '04', title: 'Développement & intégration', desc: "On construit votre site : intégration responsive, animations, formulaires, CMS. Chaque page est testée sur tous les devices.", duration: '2-4 semaines' },
  { num: '05', title: 'Recette & optimisations', desc: "Phase de tests : performance, SEO, accessibilité, responsive. On corrige, on ajuste, on peaufine jusqu'à la perfection.", duration: '3-5 jours' },
  { num: '06', title: 'Mise en ligne & formation', desc: "Votre site est en ligne. On vous forme à l'utiliser, on configure le tracking et on reste disponible pour la suite.", duration: '1-2 jours' },
];

const technologies = [
  { letter: 'W', color: '#21759B', title: 'WordPress', desc: 'Le CMS le plus populaire au monde. Flexible, extensible, idéal pour les sites vitrines et blogs professionnels.', ideal: ['Sites vitrines', 'Blogs', 'Multilingue'] },
  { letter: 'S', color: '#96BF48', title: 'Shopify', desc: "La plateforme e-commerce de référence. Fiable, sécurisée, avec un écosystème d'apps puissant.", ideal: ['Boutiques en ligne', 'Dropshipping', 'International'] },
  { letter: 'W', color: '#4353FF', title: 'Webflow', desc: 'Design et développement en un. Parfait pour les sites premium qui nécessitent une liberté créative totale.', ideal: ['Sites premium', 'Landing pages', 'Animations'] },
  { letter: 'W', color: '#7F54B3', title: 'WooCommerce', desc: "L'extension e-commerce de WordPress. Flexible et personnalisable pour les boutiques sur-mesure.", ideal: ['E-commerce WordPress', 'Produits personnalisés'] },
  { letter: 'E', color: '#FF6900', title: 'Elementor', desc: 'Le page builder WordPress le plus puissant. Édition visuelle intuitive et contrôle total du design.', ideal: ['Sites vitrines', 'Pages complexes'] },
  { letter: '<>', color: '#1A1A19', title: 'Sur-mesure', desc: 'Pour les projets qui nécessitent performance et flexibilité maximale. Code propre, zéro dépendance inutile.', ideal: ['Landing pages', 'Sites ultra-rapides', 'Projets spécifiques'] },
];

const includesColumns = [
  {
    title: 'Design & développement',
    items: ['Design sur-mesure (pas de template)', 'Maquettes graphiques avant développement', 'Intégration responsive (mobile, tablette, desktop)', 'Animations et micro-interactions', 'Formulaire de contact fonctionnel', 'Intégration CMS (gestion autonome du contenu)'],
  },
  {
    title: 'SEO & performance',
    items: ['Structure SEO optimisée (balises, Hn, meta)', 'Performance Lighthouse 95+', 'Sitemap XML & robots.txt', 'Schema JSON-LD (données structurées)', 'Compression images & lazy loading', 'Configuration HTTPS & sécurité'],
  },
  {
    title: 'Accompagnement',
    items: ["Formation à la prise en main du site", "Documentation d'utilisation", 'Configuration Google Analytics & Search Console', '30 jours de support post-lancement', 'Hébergement conseillé et configuré', 'Nom de domaine conseillé'],
  },
];


const faqItems = [
  { q: "Combien coûte la création d'un site web ?", a: "Le budget dépend du type de site (vitrine, e-commerce, landing page), du nombre de pages, des fonctionnalités et du CMS choisi. Chaque projet est chiffré sur-mesure après un appel découverte gratuit. Pas de surprise : vous recevez un devis détaillé avant de vous engager.", open: true },
  { q: "Combien de temps faut-il pour créer un site ?", a: "En moyenne, comptez 3 à 6 semaines entre le premier appel et la mise en ligne. Un site vitrine simple peut être livré en 2-3 semaines, un e-commerce en 4-8 semaines. Le planning précis est défini dans la proposition." },
  { q: "Est-ce que je pourrai modifier mon site moi-même ?", a: "Oui. Chaque site est livré avec un CMS (WordPress, Shopify, Webflow) qui vous permet de modifier vos textes, images et contenus en autonomie. Une formation est incluse à la livraison." },
  { q: "Est-ce que le SEO est inclus ?", a: "Oui. La base SEO est intégrée nativement : structure Hn, meta titles & descriptions, sitemap, schema JSON-LD, performance optimisée, images compressées. Pour une stratégie SEO avancée (contenus, maillage, suivi), c'est une prestation complémentaire." },
  { q: "Sur quel CMS sera développé mon site ?", a: "On recommande le CMS le plus adapté à votre activité et vos objectifs. WordPress pour la flexibilité, Shopify pour le e-commerce, Webflow pour le design premium. On en discute ensemble lors de l'appel découverte." },
  { q: "Faut-il que je fournisse les textes et les images ?", a: "Idéalement oui, car vous connaissez votre activité mieux que quiconque. Mais si vous n'avez pas de contenu prêt, on peut vous accompagner : rédaction web, shooting photo, banques d'images premium." },
  { q: "Est-ce que le site sera responsive (adapté mobile) ?", a: "C'est non négociable. Chaque site est conçu mobile-first et testé sur tous les appareils. Plus de 60% du trafic web est mobile, et votre site doit être impeccable partout." },
  { q: "Que se passe-t-il après la mise en ligne ?", a: "Vous bénéficiez de 30 jours de support inclus pour les ajustements post-lancement. Ensuite, on propose des forfaits de maintenance pour les mises à jour, la sécurité et l'évolution de votre site." },
  { q: "Je suis en dehors de la Haute-Savoie, on peut travailler ensemble ?", a: "Absolument. 100% de nos projets se font à distance. Visio, email, téléphone : on s'adapte à votre rythme. Nos clients sont partout en France et en Belgique." },
  { q: "Est-ce que vous refaites des sites existants (refonte) ?", a: "Oui. Refonte partielle ou complète, migration de CMS, modernisation du design : on intervient sur des sites existants autant que sur des créations from scratch." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de sites web",
  "provider": {
    "@type": "ProfessionalService",
    "name": "DISAYNER",
    "url": "https://disayner.com",
    "areaServed": "FR",
    "address": { "@type": "PostalAddress", "addressRegion": "Haute-Savoie", "addressCountry": "FR" }
  },
  "description": "Création de sites web premium sur-mesure : sites vitrines, e-commerce, landing pages. Design unique, SEO intégré, performance optimisée.",
  "serviceType": ["Site vitrine", "E-commerce", "Landing page", "Refonte de site web"]
};
---

<Layout
  title="Création de sites web sur-mesure | Sites vitrines, e-commerce & landing pages — DISAYNER"
  description="Création de sites web premium : sites vitrines, e-commerce Shopify, landing pages. Design sur-mesure, SEO intégré, performance maximale. Devis gratuit."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S1 — HERO                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-hero" aria-label="Création de sites web">
      <BgWords words={[
        { text: 'DESIGN',     x: '-4%', y: '12%', rot: '-12deg', size: '8vw' },
        { text: 'WORDPRESS',  x: '62%', y: '5%',  rot: '8deg',   size: '5vw' },
        { text: 'RESPONSIVE', x: '5%',  y: '72%', rot: '-5deg',  size: '6vw' },
        { text: 'PIXEL',      x: '70%', y: '78%', rot: '14deg',  size: '7vw' },
      ]} />

      <div class="cs-hero-inner">
        <!-- Left: Text -->
        <div class="cs-hero-text">
          <p class="cs-eyebrow">Création de sites web</p>
          <h1 class="cs-hero-title">
            Un site web conçu pour <em class="font-serif">convertir</em>,<br class="cs-br-lg" />pas juste pour exister.
          </h1>
          <p class="cs-hero-sub">
            Sites vitrines, e-commerce, landing pages : chaque projet est pensé sur-mesure pour refléter votre marque et transformer vos visiteurs en clients.
          </p>
          <div class="cs-hero-ctas">
            <a href="/contact" class="btn-primary">
              Demander un devis gratuit
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/realisations" class="btn-outline">Voir nos réalisations</a>
          </div>
          <div class="cs-badges" role="list" aria-label="Points forts">
            <span class="cs-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              +50 projets livrés
            </span>
            <span class="cs-badge-dot" aria-hidden="true">·</span>
            <span class="cs-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Score Lighthouse 95+
            </span>
            <span class="cs-badge-dot" aria-hidden="true">·</span>
            <span class="cs-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              SEO intégré
            </span>
            <span class="cs-badge-dot" aria-hidden="true">·</span>
            <span class="cs-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              100% responsive
            </span>
          </div>
        </div>

        <!-- Right: Browser mockup visual -->
        <div class="cs-hero-visual" aria-hidden="true">
          <div class="cs-browser">
            <div class="cs-browser-chrome">
              <span class="cs-dot" style="background:#FF5F57"></span>
              <span class="cs-dot" style="background:#FEBC2E"></span>
              <span class="cs-dot" style="background:#28C840"></span>
              <div class="cs-url-bar">disayner.com</div>
            </div>
            <div class="cs-browser-body">
              <!-- Fake website inside browser -->
              <div class="cs-site-nav">
                <div class="cs-site-logo"></div>
                <div class="cs-site-links">
                  <div class="cs-site-link"></div>
                  <div class="cs-site-link"></div>
                  <div class="cs-site-link"></div>
                  <div class="cs-site-btn"></div>
                </div>
              </div>
              <div class="cs-site-hero">
                <div class="cs-site-eyebrow"></div>
                <div class="cs-site-h1"></div>
                <div class="cs-site-h1 cs-site-h1--narrow"></div>
                <div class="cs-site-sub"></div>
                <div class="cs-site-sub cs-site-sub--short"></div>
                <div class="cs-site-ctarow">
                  <div class="cs-site-cta-primary"></div>
                  <div class="cs-site-cta-outline"></div>
                </div>
              </div>
              <div class="cs-site-cards">
                <div class="cs-site-card">
                  <div class="cs-site-card-icon"></div>
                  <div class="cs-site-card-line"></div>
                  <div class="cs-site-card-line cs-site-card-line--short"></div>
                </div>
                <div class="cs-site-card cs-site-card--accent">
                  <div class="cs-site-card-icon cs-site-card-icon--accent"></div>
                  <div class="cs-site-card-line"></div>
                  <div class="cs-site-card-line cs-site-card-line--short"></div>
                </div>
                <div class="cs-site-card">
                  <div class="cs-site-card-icon"></div>
                  <div class="cs-site-card-line"></div>
                  <div class="cs-site-card-line cs-site-card-line--short"></div>
                </div>
              </div>
            </div>
          </div>
          <!-- Floating badge -->
          <div class="cs-hero-badge-float">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Lighthouse<strong> 98</strong></span>
          </div>
          <div class="cs-hero-badge-float cs-hero-badge-float--2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>SEO <strong>optimisé</strong></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S2 — TYPES DE SITES                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-types" aria-label="Types de sites web">
      <div class="cs-container">
        <div class="cs-section-header section-header-anim">
          <p class="cs-eyebrow">Nos expertises</p>
          <h2>Un site adapté à <em class="font-serif">chaque besoin</em>.</h2>
          <p class="cs-section-sub">Quel que soit votre projet, nous avons la solution technique et créative pour le concrétiser.</p>
        </div>

        <div class="cs-types-grid">
          {siteTypes.map((type, i) => (
            <article class="cs-type-card cs-fade-in" style={`transition-delay:${i * 0.1}s`} aria-label={`Type de site : ${type.title}`}>
              <div class="cs-type-icon-wrap" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={type.iconPath} />
              </div>
              <h3 class="cs-type-title">{type.title}</h3>
              <p class="cs-type-desc">{type.desc}</p>
              <ul class="cs-type-features" role="list">
                {type.features.map(f => (
                  <li class="cs-type-feature">
                    <span class="cs-check-circle" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    {f}
                  </li>
                ))}
              </ul>
              <div class="cs-type-tags">
                {type.tags.map(t => <span class="cs-tag">{t}</span>)}
              </div>
              <a href="/contact" class="cs-type-cta">En savoir plus →</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S3 — DIFFÉRENCIATEURS                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-diff" aria-label="Pourquoi choisir Disayner">
      <div class="cs-container cs-diff-inner">
        <!-- Left: differentiators -->
        <div class="cs-diff-list">
          <div class="cs-section-header-left section-header-anim">
            <p class="cs-eyebrow">Nos engagements</p>
            <h2>Pourquoi choisir <em class="font-serif">Disayner</em><br />pour votre site.</h2>
          </div>
          <div class="cs-diff-items">
            {differentiators.map((d, i) => (
              <div class="cs-diff-item cs-fade-in" style={`transition-delay:${i * 0.08}s`}>
                <div class="cs-diff-icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={d.iconPath} />
                </div>
                <div>
                  <strong class="cs-diff-title">{d.title}</strong>
                  <p class="cs-diff-desc">{d.desc}</p>
                </div>
              </div>
            ))}
          </div>
          <a href="/contact" class="btn-primary cs-diff-cta">
            Démarrer mon projet
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Right: visual -->
        <div class="cs-diff-visual" aria-hidden="true">
          <div class="cs-diff-mockup">
            <div class="cs-score-card">
              <p class="cs-score-label">Performance</p>
              <div class="cs-score-ring">
                <svg viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(37,99,235,0.1)" stroke-width="8"/>
                  <circle cx="50" cy="50" r="42" fill="none" stroke="#2563EB" stroke-width="8" stroke-linecap="round" stroke-dasharray="263.9" stroke-dashoffset="18" transform="rotate(-90 50 50)"/>
                </svg>
                <span class="cs-score-val">98</span>
              </div>
              <div class="cs-score-checks">
                <div class="cs-score-row"><span class="cs-score-dot cs-score-dot--green"></span><span>First Contentful Paint</span><strong>0.8s</strong></div>
                <div class="cs-score-row"><span class="cs-score-dot cs-score-dot--green"></span><span>Largest Contentful Paint</span><strong>1.2s</strong></div>
                <div class="cs-score-row"><span class="cs-score-dot cs-score-dot--green"></span><span>Total Blocking Time</span><strong>0ms</strong></div>
                <div class="cs-score-row"><span class="cs-score-dot cs-score-dot--green"></span><span>Cumulative Layout Shift</span><strong>0</strong></div>
              </div>
            </div>
            <div class="cs-seo-card">
              <p class="cs-score-label">Référencement SEO</p>
              <div class="cs-seo-bars">
                <div class="cs-seo-row"><span>Position Google</span><div class="cs-seo-bar" style="--pct:90%"></div><strong>#1</strong></div>
                <div class="cs-seo-row"><span>Trafic organique</span><div class="cs-seo-bar" style="--pct:75%"></div><strong>+200%</strong></div>
                <div class="cs-seo-row"><span>Taux de conversion</span><div class="cs-seo-bar" style="--pct:60%"></div><strong>4.2%</strong></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S4 — PROCESS                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
