---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllArticles, getArticleBySlug, getArticlesByCategory, getCategoryBySlug } from '../../content/blog/data';
import { marked } from 'marked';

export async function getStaticPaths() {
  const articles = getAllArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);
if (!article) return Astro.redirect('/blog');

const category = getCategoryBySlug(article.category);
const catColor = category?.color ?? '#2563EB';

// Load markdown content
const markdownFiles = import.meta.glob('/src/content/blog/articles/*.md', { query: '?raw', import: 'default', eager: true }) as Record<string, string>;
const rawContent = markdownFiles[`/src/content/blog/articles/${article.contentFile}.md`] ?? '';

// Configure marked
marked.setOptions({ gfm: true });

// Render markdown to HTML
const htmlContent = await marked.parse(rawContent);

// Extract H2 headings for TOC
const tocItems: { id: string; text: string }[] = [];
const headingRegex = /<h2[^>]*>(.*?)<\/h2>/gi;
let match: RegExpExecArray | null;
let tocIndex = 0;
let processedHtml = htmlContent;

while ((match = headingRegex.exec(htmlContent)) !== null) {
  tocIndex++;
  const id = `section-${tocIndex}`;
  const text = match[1].replace(/<[^>]*>/g, '');
  tocItems.push({ id, text });
  processedHtml = processedHtml.replace(match[0], `<h2 id="${id}">${match[1]}</h2>`);
}

// Related articles (same category, exclude current, limit 2)
const relatedArticles = getArticlesByCategory(article.category)
  .filter((a) => a.slug !== article.slug)
  .slice(0, 2);

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// JSON-LD schemas
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": article.metaDescription,
  "datePublished": article.publishDate,
  "dateModified": article.updatedDate || article.publishDate,
  "author": {
    "@type": "Person",
    "name": "Célio",
    "url": "https://disayner.com",
  },
  "publisher": {
    "@type": "Organization",
    "name": "DISAYNER",
    "url": "https://disayner.com",
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://disayner.com/blog/${article.slug}`,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://disayner.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://disayner.com/blog" },
    { "@type": "ListItem", "position": 3, "name": article.categoryName, "item": `https://disayner.com/blog/categorie/${article.category}` },
    { "@type": "ListItem", "position": 4, "name": article.title, "item": `https://disayner.com/blog/${article.slug}` },
  ],
};
---

<Layout
  title={article.metaTitle}
  description={article.metaDescription}
  ogImage={article.ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BREADCRUMB                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <nav class="article-breadcrumb" aria-label="Fil d'Ariane">
      <div class="article-breadcrumb-inner">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/blog">Blog</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href={`/blog/categorie/${article.category}`}>{article.categoryName}</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current" aria-current="page">{article.title}</span>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ARTICLE HEADER                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <header class="article-header" aria-label="En-tête de l'article">
      <div class="article-header-inner">
        <div class="article-header-meta">
          <span
            class="article-badge"
            style={`color:${catColor}; background:${catColor}12; border-color:${catColor}30;`}
          >
            {article.categoryName}
          </span>
          <span class="article-meta-sep">&middot;</span>
          <span class="article-date">{formatDate(article.publishDate)}</span>
          <span class="article-meta-sep">&middot;</span>
          <span class="article-reading">{article.readingTime} de lecture</span>
        </div>

        <h1 class="article-title">{article.title}</h1>

        {article.tags.length > 0 && (
          <div class="article-tags">
            {article.tags.map((tag) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- HERO IMAGE                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    {article.ogImage && (
      <div class="article-hero-img">
        <img
          src={article.ogImage}
          alt={article.title}
          width="1200"
          height="675"
          loading="eager"
          class="article-hero-photo"
        />
      </div>
    )}

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ARTICLE CONTENT + TOC                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="article-layout">
      <div class="article-layout-inner">

        <!-- TOC sidebar (desktop) -->
        {tocItems.length > 0 && (
          <aside class="toc-sidebar" aria-label="Sommaire de l'article">
            <p class="toc-title">Sommaire</p>
            <nav id="toc">
              {tocItems.map((item) => (
                <a href={`#${item.id}`} class="toc-link">{item.text}</a>
              ))}
            </nav>
          </aside>
        )}

        <!-- Article body -->
        <div class="article-body">
          <!-- TOC mobile (collapsible) -->
          {tocItems.length > 0 && (
            <details class="toc-mobile">
              <summary class="toc-mobile-summary">Sommaire</summary>
              <nav class="toc-mobile-nav">
                {tocItems.map((item) => (
                  <a href={`#${item.id}`} class="toc-link">{item.text}</a>
                ))}
              </nav>
            </details>
          )}

          <!-- Prose content -->
          <div class="blog-prose" set:html={processedHtml} />
        </div>

      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- AUTHOR BOX                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="author-section" aria-label="À propos de l'auteur">
      <div class="author-inner">
        <div class="author-box">
          <div class="author-avatar">C</div>
          <div class="author-info">
            <p class="author-name">Célio</p>
            <p class="author-role">Fondateur, DISAYNER</p>
            <p class="author-bio">Web designer, développeur & consultant SEO. J'aide les entreprises à construire une présence web performante et durable.</p>
            <a href="/contact" class="author-link hover-underline">Me contacter &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- RELATED ARTICLES                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    {relatedArticles.length > 0 && (
      <section class="related-section" aria-label="Articles similaires">
        <div class="related-inner">
          <h2 class="related-title">Articles similaires</h2>
          <div class="related-grid">
            {relatedArticles.map((rel) => {
              const relColor = getCategoryBySlug(rel.category)?.color ?? '#2563EB';
              return (
                <article class="related-card">
                  <a href={`/blog/${rel.slug}`} class="related-card-link" style={`--card-accent:${relColor};`}>
                    <div class="related-card-header">
                      <span
                        class="article-badge article-badge--sm"
                        style={`color:${relColor}; background:${relColor}12; border-color:${relColor}30;`}
                      >
                        {rel.categoryName}
                      </span>
                      <span class="related-card-date">{formatDate(rel.publishDate)}</span>
                    </div>
                    <h3 class="related-card-title">{rel.title}</h3>
                    <p class="related-card-excerpt">{rel.excerpt}</p>
                    <div class="related-card-footer">
                      <span class="related-card-reading">{rel.readingTime} de lecture</span>
                      <span class="related-card-cta">Lire &rarr;</span>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CTA                                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="article-cta-section" aria-label="Passer à l'action">
      <div class="article-cta-inner">
        <p class="article-cta-eyebrow">Besoin d'un accompagnement ?</p>
        <h2 class="article-cta-title">
          Passez de la théorie<br />
          <em class="font-serif">à l'action.</em>
        </h2>
        <p class="article-cta-sub">
          Un échange de 30 minutes pour comprendre votre besoin.<br />
          Sans engagement, sans pression.
        </p>
        <a href="/contact" class="article-cta-btn">
          Démarrer un projet
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <p class="article-cta-reassurance">Réponse sous 24h · 100% sur mesure · Basé en Haute-Savoie</p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Breadcrumb ── */
  .article-breadcrumb {
    padding: 6.5rem 2rem 0;
    background: var(--color-background);
  }

  .article-breadcrumb-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .article-breadcrumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .article-breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb-sep {
    opacity: 0.35;
    margin: 0 0.1rem;
  }

  .breadcrumb-current {
    color: var(--color-text-primary);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 400px;
  }

  /* ── Article header ── */
  .article-header {
    padding: 2.5rem 2rem 0;
    background: var(--color-background);
  }

  .article-header-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .article-header-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .article-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 100px;
    border: 1px solid;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .article-badge--sm {
    font-size: 0.6875rem;
    padding: 3px 10px;
  }

  .article-date,
  .article-reading {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .article-meta-sep {
    opacity: 0.35;
    color: var(--color-text-secondary);
  }

  .article-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    max-width: 860px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 0.5rem;
  }

  .article-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text-secondary);
  }

  /* ── Article layout (TOC + content) ── */
  .article-hero-img {
    padding: 1.5rem 2rem 0;
    background: var(--color-background);
  }

  .article-hero-photo {
    display: block;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    border-radius: 16px;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .article-layout {
    padding: 3rem 2rem 4rem;
    background: var(--color-background);
  }

  .article-layout-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── TOC sidebar (desktop) ── */
  .toc-sidebar {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
  }

  .toc-title {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin-bottom: 12px;
  }

  .toc-link {
    display: block;
    padding: 6px 12px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
    margin-bottom: 2px;
    line-height: 1.4;
  }

  .toc-link:hover,
  .toc-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 0 6px 6px 0;
  }

  /* ── TOC mobile ── */
  .toc-mobile {
    display: none;
    margin-bottom: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .toc-mobile-summary {
    padding: 14px 20px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
  }

  .toc-mobile-summary::-webkit-details-marker { display: none; }

  .toc-mobile-summary::before {
    content: "▸ ";
    margin-right: 4px;
  }

  .toc-mobile[open] .toc-mobile-summary::before {
    content: "▾ ";
  }

  .toc-mobile-nav {
    padding: 0 20px 14px;
  }

  .toc-mobile-nav .toc-link {
    font-size: 0.875rem;
    padding: 8px 12px;
  }

  /* ── Article body / prose ── */
  .article-body {
    max-width: 720px;
    min-width: 0;
  }

  .blog-prose {
    font-size: 17px;
    line-height: 1.8;
    color: var(--color-text-primary);
  }

  .blog-prose :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .blog-prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .blog-prose :global(p) {
    margin-bottom: 20px;
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .blog-prose :global(li) {
    margin-bottom: 8px;
  }

  .blog-prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .blog-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .blog-prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .blog-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 16px 24px;
    margin: 24px 0;
    background: var(--color-surface);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .blog-prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .blog-prose :global(code) {
    background: var(--color-surface);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 14px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    border: 1px solid var(--color-border);
  }

  .blog-prose :global(pre) {
    background: var(--color-text-primary);
    color: var(--color-border);
    padding: 20px 24px;
    border-radius: 12px;
    overflow-x: auto;
    margin: 24px 0;
    font-size: 14px;
    line-height: 1.6;
  }

  .blog-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  .blog-prose :global(img) {
    max-width: 100%;
    border-radius: 12px;
    margin: 24px 0;
  }

  .blog-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }

  .blog-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 0.9375rem;
  }

  .blog-prose :global(th),
  .blog-prose :global(td) {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .blog-prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  /* ── Author box ── */
  .author-section {
    padding: 0 2rem 4rem;
    background: var(--color-background);
  }

  .author-inner {
    max-width: 720px;
    margin: 0 auto;
    /* Offset to align with article body in the grid layout */
    margin-left: calc((min(1100px, 100%) - 720px) / 2 + 240px + 3rem);
  }

  .author-box {
    display: flex;
    gap: 20px;
    padding: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-serif);
    flex-shrink: 0;
  }

  .author-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .author-role {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
  }

  .author-bio {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .author-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ── Related articles ── */
  .related-section {
    padding: 4rem 2rem 4rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .related-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .related-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .related-card {
    background: var(--color-background);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.06);
  }

  .related-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    border-left: 3px solid transparent;
    transition: border-color 0.3s ease;
  }

  .related-card:hover .related-card-link {
    border-left-color: var(--card-accent);
  }

  .related-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .related-card-date {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .related-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .related-card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 20px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .related-card-reading {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .related-card-cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  /* ── CTA section ── */
  .article-cta-section {
    position: relative;
    background: linear-gradient(135deg, #1D4ED8 0%, #2563EB 55%, #3B82F6 100%);
    padding: 7rem 2rem;
    overflow: hidden;
  }

  .article-cta-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  .article-cta-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .article-cta-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1rem;
  }

  .article-cta-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .article-cta-title em {
    font-style: italic;
    font-family: var(--font-serif);
  }

  .article-cta-sub {
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    max-width: 500px;
    margin-bottom: 2rem;
  }

  .article-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    color: var(--color-accent);
    padding: 1rem 2rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1rem;
    font-family: var(--font-sans);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 1.5rem;
  }

  .article-cta-btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
  }

  .article-cta-reassurance {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
    margin-top: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .article-breadcrumb { padding: 6rem 1.25rem 0; }
    .article-header { padding: 2rem 1.25rem 0; }
    .article-layout { padding: 2rem 1.25rem 3rem; }
    .author-section { padding: 0 1.25rem 3rem; }
    .related-section { padding: 3rem 1.25rem; }

    .article-layout-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .toc-sidebar { display: none; }
    .toc-mobile { display: block; }

    .author-inner {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 700px) {
    .related-grid { grid-template-columns: 1fr; }

    .breadcrumb-current { max-width: 200px; }
  }

  @media (max-width: 600px) {
    .article-cta-section { padding: 5rem 1.25rem; }

    .author-box { flex-direction: column; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // ── Header entrance
  gsap.from(".article-header-inner > *", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.1,
    ease: "power3.out",
    delay: 0.1,
  });

  // ── TOC active state tracking (Intersection Observer)
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-sidebar .toc-link");
  const sections = document.querySelectorAll<HTMLElement>(".blog-prose h2[id]");

  if (sections.length > 0 && tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute("id");
            tocLinks.forEach((link) => {
              link.classList.toggle("active", link.getAttribute("href") === `#${id}`);
            });
          }
        });
      },
      { rootMargin: "-80px 0px -70% 0px", threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
  }

  // ── Smooth scroll for TOC links
  document.querySelectorAll<HTMLAnchorElement>('.toc-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const id = link.getAttribute('href')?.replace('#', '');
      if (!id) return;
      const target = document.getElementById(id);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `#${id}`);
      }
    });
  });

  // ── CTA entrance
  gsap.from(".article-cta-inner > *", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.08,
    ease: "power2.out",
    clearProps: "transform",
    scrollTrigger: {
      trigger: ".article-cta-section",
      start: "top 70%",
    },
  });
</script>
