<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.mw-fade-in').forEach(el => observer.observe(el));

  // Metric countup (99.9% only)
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  document.querySelectorAll<HTMLElement>('.mw-metric-num[data-value]').forEach((el) => {
    const target = parseFloat(el.dataset.value ?? '0');
    const suffix = el.dataset.suffix ?? '';
    const isDecimal = el.dataset.decimal === 'true';
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2,
      ease: 'power2.out',
      onUpdate() {
        el.textContent = isDecimal ? obj.val.toFixed(1) + suffix : Math.round(obj.val) + suffix;
      },
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    });
  });
</script>
