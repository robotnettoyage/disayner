---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import BgWords from '../components/BgWords.astro';
import BgOrbs from '../components/BgOrbs.astro';
import BgDots from '../components/BgDots.astro';

const faqItems = [
  { q: "Pourquoi mon site a-t-il besoin de maintenance ?", a: "Un site web est un logiciel vivant. Le CMS, les plugins, les dépendances : tout évolue. Sans mises à jour régulières, votre site devient vulnérable aux failles de sécurité, ralentit, et peut finir par tomber en panne. La maintenance prévient ces problèmes avant qu'ils n'arrivent.", open: true },
  { q: "À quelle fréquence intervenez-vous ?", a: "Ça dépend de votre site et de votre CMS. Pour WordPress et WooCommerce, on intervient chaque semaine (mises à jour, vérifications). Pour Shopify et Webflow, le rythme est plutôt mensuel. Le monitoring et les sauvegardes tournent tous les jours, 24/7." },
  { q: "Que se passe-t-il si mon site tombe en panne ?", a: "Notre système de monitoring détecte les pannes en temps réel. On est alerté immédiatement et on intervient dans les plus brefs délais. En parallèle, vos sauvegardes quotidiennes permettent une restauration rapide si nécessaire." },
  { q: "Est-ce que les petites modifications sont incluses ?", a: "Oui. Les modifications mineures courantes sont incluses : changement de texte, remplacement d'image, ajout d'un lien, mise à jour d'une information. Pour des modifications plus conséquentes (nouvelle page, nouvelle fonctionnalité), on établit un devis séparé." },
  { q: "Est-ce que je peux souscrire sans avoir fait mon site chez vous ?", a: "Absolument. On prend en charge la maintenance de sites existants, quel que soit le prestataire qui les a créés. On commence par un diagnostic pour évaluer l'état du site et adapter le forfait." },
  { q: "Comment sont gérées les sauvegardes ?", a: "Les sauvegardes sont automatiques et quotidiennes. On sauvegarde l'intégralité de votre site (fichiers + base de données) sur un serveur séparé et sécurisé. En cas de problème, on peut restaurer votre site en quelques minutes." },
  { q: "Est-ce que la maintenance inclut le SEO ?", a: "La maintenance assure que votre site reste techniquement sain, ce qui est une base pour le SEO (vitesse, sécurité, pas d'erreurs). Mais une stratégie SEO active (contenus, mots-clés, backlinks) est une prestation distincte. On peut bien sûr combiner les deux." },
  { q: "Quel budget prévoir pour la maintenance ?", a: "Le forfait dépend du type de site, du CMS et du niveau de service souhaité. Chaque prestation est chiffrée sur-mesure. On vous envoie une proposition claire après un diagnostic de votre site. Pas de surprise, pas d'engagement caché." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Maintenance web",
  "provider": {
    "@type": "ProfessionalService",
    "name": "DISAYNER",
    "url": "https://disayner.com",
    "areaServed": "FR",
    "address": { "@type": "PostalAddress", "addressRegion": "Haute-Savoie", "addressCountry": "FR" }
  },
  "description": "Maintenance web professionnelle : mises à jour CMS et plugins, sécurité, sauvegardes quotidiennes, monitoring 24/7, optimisation de performance et support technique.",
  "serviceType": ["Mises à jour CMS", "Sécurité web", "Sauvegardes", "Monitoring", "Support technique", "Optimisation performance"]
};
---

<Layout
  title="Maintenance web — Sécurité, mises à jour et performance continue | DISAYNER"
  description="Maintenance web professionnelle : mises à jour, sécurité, sauvegardes quotidiennes, monitoring 24/7 et support réactif. WordPress, Shopify, Webflow. Devis gratuit."
  ogImage="/og-default.png"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://disayner.com/maintenance" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S1 — HERO                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="mw-hero" aria-label="Maintenance web">
      <BgWords words={[
        { text: 'SÉCURITÉ', x: '-5%',  y: '12%', rot: '-12deg', size: '7vw'  },
        { text: 'BACKUP',   x: '66%',  y: '5%',  rot: '8deg',   size: '5vw'  },
        { text: 'UPTIME',   x: '8%',   y: '72%', rot: '-5deg',  size: '6vw'  },
        { text: '24/7',     x: '72%',  y: '78%', rot: '14deg',  size: '8vw'  },
      ]} />
      <BgOrbs orbs={[
        { type: 'filled', x: '85%', y: '15%', size: '280px', dur: '14s' },
        { type: 'ring',   x: '8%',  y: '78%', size: '180px', dur: '18s' },
      ]} />

      <div class="mw-hero-inner">

        <!-- Left: Text -->
        <div class="mw-hero-text">
          <p class="mw-eyebrow">Maintenance web</p>
          <h1 class="mw-hero-title">
            Votre site mérite une attention <em class="font-serif">continue</em>.
          </h1>
          <p class="mw-hero-sub">
            Mises à jour, sécurité, performance, sauvegardes : on s'occupe de tout pour que votre site reste rapide, sécurisé et toujours en ligne. Vous, vous vous concentrez sur votre business.
          </p>
          <div class="mw-hero-ctas">
            <a href="/contact" class="btn-primary">
              Souscrire à la maintenance
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#inclus" class="btn-outline">Voir ce qui est inclus</a>
          </div>
          <div class="mw-badges" role="list" aria-label="Points forts">
            <span class="mw-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Monitoring 24/7
            </span>
            <span class="mw-badge-dot" aria-hidden="true">·</span>
            <span class="mw-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Sauvegardes quotidiennes
            </span>
            <span class="mw-badge-dot" aria-hidden="true">·</span>
            <span class="mw-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Support réactif
            </span>
            <span class="mw-badge-dot" aria-hidden="true">·</span>
            <span class="mw-badge" role="listitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Mises à jour régulières
            </span>
          </div>
        </div>

        <!-- Right: Shield visual -->
        <div class="mw-hero-visual" aria-hidden="true">
          <div class="mw-shield-wrap">
            <!-- Pulsing glow rings -->
            <div class="mw-glow-ring mw-glow-ring-1"></div>
            <div class="mw-glow-ring mw-glow-ring-2"></div>
            <div class="mw-glow-ring mw-glow-ring-3"></div>
            <!-- Central shield -->
            <div class="mw-shield-center">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <!-- Floating orbit icons -->
            <div class="mw-orbit mw-orbit-1">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <div class="mw-orbit mw-orbit-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
              </svg>
            </div>
            <div class="mw-orbit mw-orbit-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
              </svg>
            </div>
            <div class="mw-orbit mw-orbit-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S2 — LE RISQUE                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="mw-section mw-risk" aria-label="Risques d'un site non maintenu">
      <div class="mw-container">
        <div class="mw-section-header section-header-anim">
          <p class="mw-eyebrow">Le constat</p>
          <h2>Un site non maintenu, c'est une <em class="font-serif">bombe à retardement</em>.</h2>
        </div>

        <div class="mw-risk-grid">

          <!-- Card 1 — Failles de sécurité -->
          <div class="mw-risk-card mw-fade-in">
            <div class="mw-risk-icon-wrap" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <h3>Failles de sécurité</h3>
            <p>Un plugin ou un CMS non mis à jour, c'est une porte ouverte aux hackers. 43% des cyberattaques ciblent les petites entreprises.</p>
          </div>

          <!-- Card 2 — Site lent ou en panne -->
          <div class="mw-risk-card mw-fade-in" style="transition-delay:0.08s">
            <div class="mw-risk-icon-wrap" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <h3>Site lent ou en panne</h3>
            <p>Un site qui met plus de 3 secondes à charger perd 53% de ses visiteurs. Une panne non détectée, c'est des clients perdus.</p>
          </div>

          <!-- Card 3 — Perte de données -->
          <div class="mw-risk-card mw-fade-in" style="transition-delay:0.16s">
            <div class="mw-risk-icon-wrap" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="12" x2="2" y2="12"/>
                <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
                <line x1="6" y1="16" x2="6.01" y2="16"/>
                <line x1="10" y1="16" x2="10.01" y2="16"/>
              </svg>
            </div>
            <h3>Perte de données</h3>
            <p>Sans sauvegarde régulière, une erreur humaine, un hack ou un crash serveur peut effacer des mois de travail. Définitivement.</p>
          </div>

          <!-- Card 4 — Chute du référencement -->
          <div class="mw-risk-card mw-fade-in" style="transition-delay:0.24s">
            <div class="mw-risk-icon-wrap" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/>
                <polyline points="17 18 23 18 23 12"/>
              </svg>
            </div>
            <h3>Chute du référencement</h3>
            <p>Google pénalise les sites lents, non sécurisés et avec des erreurs techniques. Votre positionnement SEO peut s'effondrer en quelques semaines.</p>
          </div>

        </div>

        <p class="mw-risk-conclusion mw-fade-in">
          La bonne nouvelle&nbsp;? Tout ça est évitable avec un suivi régulier. C'est exactement ce qu'on fait.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S3 — CE QUI EST INCLUS                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="mw-section mw-inclus" id="inclus" aria-label="Ce qui est inclus dans la maintenance">
      <BgDots pulseCount={6} variant="accent" />
      <div class="mw-container" style="position:relative;z-index:1;">
        <div class="mw-section-header section-header-anim">
          <p class="mw-eyebrow">Nos prestations</p>
          <h2>Une maintenance <em class="font-serif">complète</em>, sans surprise.</h2>
          <p class="mw-section-sub">Chaque forfait est adapté à vos besoins. Voici ce que couvre notre prestation de maintenance.</p>
        </div>

        <div class="mw-features-grid">

          <!-- Col 1 — Sécurité -->
          <div class="mw-feature-col mw-fade-in">
            <p class="mw-feature-col-title">Sécurité</p>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Mises à jour CMS & plugins</strong>
              </div>
              <p class="mw-feature-desc">WordPress, Shopify, Webflow : on maintient votre CMS et toutes ses extensions à jour pour colmater les failles de sécurité.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="9 12 11 14 15 10"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Surveillance de sécurité</strong>
              </div>
              <p class="mw-feature-desc">Scan anti-malware régulier, détection d'intrusions, firewall applicatif. On surveille les menaces avant qu'elles ne deviennent des problèmes.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Certificat SSL (HTTPS)</strong>
              </div>
              <p class="mw-feature-desc">Vérification et renouvellement de votre certificat SSL pour garantir une connexion sécurisée à vos visiteurs.</p>
            </div>
          </div>

          <!-- Col 2 — Performance -->
          <div class="mw-feature-col mw-fade-in" style="transition-delay:0.1s">
            <p class="mw-feature-col-title">Performance</p>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Optimisation des performances</strong>
              </div>
              <p class="mw-feature-desc">Compression d'images, nettoyage de base de données, optimisation du cache, minification CSS/JS. Votre site reste rapide.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Monitoring 24/7</strong>
              </div>
              <p class="mw-feature-desc">Surveillance continue de la disponibilité de votre site. En cas de panne, on est alerté immédiatement et on intervient.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                    <path d="m9 14 2 2 4-4"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Audit technique trimestriel</strong>
              </div>
              <p class="mw-feature-desc">Tous les 3 mois, on passe votre site au crible : Core Web Vitals, erreurs 404, liens cassés, indexation. Rapport détaillé inclus.</p>
            </div>
          </div>

          <!-- Col 3 — Sauvegarde & support -->
          <div class="mw-feature-col mw-fade-in" style="transition-delay:0.2s">
            <p class="mw-feature-col-title">Sauvegarde & support</p>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="9" ry="3"/>
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Sauvegardes automatiques</strong>
              </div>
              <p class="mw-feature-desc">Sauvegardes quotidiennes de votre site et de votre base de données. Restauration possible en quelques clics en cas de problème.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
                    <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
                    <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Support technique prioritaire</strong>
              </div>
              <p class="mw-feature-desc">Un problème&nbsp;? On intervient rapidement. Email, téléphone : un interlocuteur dédié qui connaît votre site.</p>
            </div>

            <div class="mw-feature-item">
              <div class="mw-feature-icon-row">
                <div class="mw-feature-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                </div>
                <strong class="mw-feature-title">Modifications mineures incluses</strong>
              </div>
              <p class="mw-feature-desc">Changement de texte, ajout d'image, mise à jour d'une page : les petites modifications courantes sont incluses dans le forfait.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S4 — COMMENT ÇA MARCHE                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="mw-section mw-process" aria-label="Mise en place de la maintenance">
      <div class="mw-container">
        <div class="mw-section-header section-header-anim">
          <p class="mw-eyebrow">Le process</p>
          <h2>Mettre en place votre maintenance en <em class="font-serif">3 étapes</em>.</h2>
        </div>

        <div class="mw-steps-row">

          <div class="mw-step mw-fade-in">
            <div class="mw-step-num" aria-hidden="true">01</div>
            <h3 class="mw-step-title">Diagnostic</h3>
            <p class="mw-step-desc">On analyse votre site pour identifier les besoins spécifiques de maintenance.</p>
            <span class="mw-step-duration">Durée : 1-2 jours</span>
          </div>

          <div class="mw-step-connector" aria-hidden="true">
