<style>
  /* ─── Layout helpers ──────────────────────────────────────────────────── */
  .mw-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .mw-section {
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .mw-eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .mw-section-header {
    max-width: 680px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .mw-section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .mw-section-header h2 em { font-style: italic; color: var(--color-accent); }

  .mw-section-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .mw-fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .mw-fade-in.visible { opacity: 1; transform: none; }

  /* ─── S1: HERO ────────────────────────────────────────────────────────── */
  .mw-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 9rem 2rem 5rem;
    overflow: hidden;
    background: var(--color-background);
  }

  .mw-hero-inner {
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .mw-hero-text { display: flex; flex-direction: column; gap: 1.75rem; }

  .mw-hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  .mw-hero-title em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
    font-size: 1.05em;
    letter-spacing: -0.02em;
  }

  .mw-hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 540px;
  }

  .mw-hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  .mw-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .mw-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .mw-badge svg { color: var(--color-accent); }
  .mw-badge-dot { color: var(--color-border); font-size: 1.25rem; line-height: 1; }

  /* Shield visual */
  .mw-hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mw-shield-wrap {
    position: relative;
    width: 340px;
    height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mw-glow-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(37, 99, 235, 0.12);
    animation: mw-pulse-ring 4s ease-out infinite;
    pointer-events: none;
  }

  .mw-glow-ring-1 { width: 140px; height: 140px; animation-delay: 0s; }
  .mw-glow-ring-2 { width: 210px; height: 210px; animation-delay: 1.2s; }
  .mw-glow-ring-3 { width: 300px; height: 300px; animation-delay: 2.4s; }

  @keyframes mw-pulse-ring {
    0%   { transform: scale(0.85); opacity: 0.7; }
    100% { transform: scale(1.15); opacity: 0; }
  }

  .mw-shield-center {
    position: relative;
    z-index: 2;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
    border: 1px solid rgba(37, 99, 235, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 60px rgba(37, 99, 235, 0.15), 0 8px 32px rgba(37, 99, 235, 0.08);
  }

  .mw-orbit {
    position: absolute;
    width: 44px;
    height: 44px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06);
    z-index: 3;
  }

  .mw-orbit-1 { top: 8%;   left: 4%;   animation: mw-float-a 6s ease-in-out infinite; }
  .mw-orbit-2 { top: 5%;   right: 6%;  animation: mw-float-b 7.5s ease-in-out infinite; }
  .mw-orbit-3 { bottom: 12%; left: 2%;  animation: mw-float-c 8s ease-in-out infinite; }
  .mw-orbit-4 { bottom: 8%;  right: 4%; animation: mw-float-d 5.5s ease-in-out infinite; }

  @keyframes mw-float-a {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -14px); }
  }
  @keyframes mw-float-b {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-12px, 16px); }
  }
  @keyframes mw-float-c {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(14px, -10px); }
  }
  @keyframes mw-float-d {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-9px, -12px); }
  }

