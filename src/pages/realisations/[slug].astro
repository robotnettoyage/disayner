---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BgWords from '../../components/BgWords.astro';
import BgOrbs from '../../components/BgOrbs.astro';
import { getAllCaseStudies, getCaseStudyBySlug } from '../../content/case-studies/data';
import type { CaseStudy } from '../../content/case-studies/data';

export function getStaticPaths() {
  return getAllCaseStudies().map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;

// 2 other case studies for the "Autres réalisations" section
const otherStudies = getAllCaseStudies()
  .filter((s) => s.slug !== study.slug)
  .slice(0, 2);

// Accent color map by category
const categoryAccents: Record<string, string> = {
  'site-vitrine': '#2563EB',
  'seo':          '#7C3AED',
  'e-commerce':   '#059669',
  'landing-page': '#F59E0B',
  'refonte':      '#2563EB',
  'maintenance':  '#6B6B67',
};

const accent = categoryAccents[study.categories[0]] ?? '#2563EB';

// Visual type for the context section illustration
const isRefonte = study.context.includes('ancien site')
  || study.context.includes('migration')
  || study.context.includes('Wix')
  || study.context.includes('refonte');

const visualType = study.categories.includes('e-commerce')
  ? 'ecommerce'
  : study.categories.includes('seo')
    ? 'seo'
    : isRefonte
      ? 'broken-site'
      : 'blank'; // new projects created from scratch

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": study.metaTitle,
  "description": study.metaDescription,
  "url": `https://disayner.com/realisations/${study.slug}`,
  "author": { "@type": "Organization", "name": "DISAYNER", "url": "https://disayner.com" },
  "publisher": { "@type": "Organization", "name": "DISAYNER", "url": "https://disayner.com" },
  ...(study.heroImage ? { "image": `https://disayner.com${study.heroImage}` } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil",       "item": "https://disayner.com" },
    { "@type": "ListItem", "position": 2, "name": "Réalisations",  "item": "https://disayner.com/realisations" },
    { "@type": "ListItem", "position": 3, "name": study.clientName,"item": `https://disayner.com/realisations/${study.slug}` },
  ],
};
---

<Layout title={study.metaTitle} description={study.metaDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BREADCRUMB                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="cs-breadcrumb-wrapper">
      <nav class="cs-breadcrumb" aria-label="Fil d'Ariane">
        <ol class="cs-breadcrumb-list">
          <li><a href="/" class="hover-underline">Accueil</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/realisations" class="hover-underline">Réalisations</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">{study.clientName}</li>
        </ol>
      </nav>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S1 — HERO                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-detail-hero" aria-label={`Projet ${study.clientName}`}>
      <BgOrbs orbs={[
        { type: 'filled', x: '88%', y: '15%', size: '280px', dur: '11s' },
        { type: 'ring',   x: '5%',  y: '75%', size: '180px', dur: '15s' },
      ]} />

      <div class="cs-detail-hero-inner">

        <!-- Left: content (60%) -->
        <div class="cs-detail-hero-content">
          <div class="cs-detail-meta">
            <span
              class="cs-category-pill"
              style={`color:${accent}; background:${accent}18; border-color:${accent}30;`}
            >
              {study.categoryLabel}
            </span>
            <span class="cs-detail-year">{study.year}</span>
          </div>

          <h1 class="cs-detail-title">{study.clientName}</h1>
          <p class="cs-detail-subtitle">{study.projectType}</p>

          <!-- Quick info row -->
          <div class="cs-detail-info" aria-label="Informations du projet">
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {study.duration}
            </span>
            <span aria-hidden="true">·</span>
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {study.location}
            </span>
          </div>

          <!-- Stack tags -->
          <div class="cs-detail-tags" aria-label="Technologies utilisées">
            {study.tags.map((tag) => (
              <span class="stack-tag">{tag}</span>
            ))}
          </div>

          <!-- CTAs -->
          <div class="cs-detail-ctas">
            <a
              href={study.clientWebsite}
              class="cs-visit-btn"
              rel="nofollow noopener"
              target="_blank"
              style={`color:${accent}; border-color:${accent}40;`}
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Voir le site
            </a>
            <a href="/contact" class="btn-primary">
              Démarrer un projet similaire
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Right: hero image (40%) -->
        <div class="cs-detail-hero-visual">
          {study.heroImage ? (
            <img
              src={study.heroImage}
              alt={`Aperçu du site ${study.clientName}`}
              class="cs-detail-hero-img"
              loading="eager"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
            />
          ) : null}
          <div
            class="cs-detail-hero-placeholder"
            style={`${study.heroImage ? 'display:none;' : ''} background: linear-gradient(135deg, ${accent}22 0%, ${accent}06 100%);`}
            aria-hidden="true"
          >
            <span class="cs-placeholder-letter">{study.clientName.charAt(0)}</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S2 — CONTEXTE                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-context cs-section" aria-label="Contexte du projet">
      <div class="cs-section-inner">
        <div class="cs-context-grid">
          <!-- Left: text -->
          <div class="cs-context-text">
            <div class="cs-section-header section-header-anim">
              <p class="section-label">Le contexte</p>
              <h2>La <em class="font-serif">problématique</em></h2>
            </div>
            <div class="cs-prose" set:html={study.context} />
          </div>

          <!-- Right: animated visual (hidden on mobile) -->
          <div class="cs-context-visual" aria-hidden="true">
            {visualType === 'broken-site' && (
              <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="visual-broken-site">
                <!-- Monitor body -->
                <rect x="20" y="10" width="200" height="140" rx="12" stroke="#E8E8E3" stroke-width="1.5" fill="#FAFAF9"/>
                <!-- Screen -->
                <rect x="30" y="20" width="180" height="110" rx="6" fill="#F5F5F0"/>
                <!-- Glitch lines -->
                <rect x="30" y="45" width="180" height="3" fill="#EF4444" opacity="0.15" class="glitch-line gl-1"/>
                <rect x="30" y="78" width="180" height="2" fill="#EF4444" opacity="0.1" class="glitch-line gl-2"/>
                <rect x="30" y="105" width="180" height="4" fill="#EF4444" opacity="0.12" class="glitch-line gl-3"/>
                <!-- Warning triangle -->
                <g class="warning-icon" transform="translate(95, 45)">
                  <polygon points="25,5 45,40 5,40" stroke="#EF4444" stroke-width="1.5" fill="none" opacity="0.4"/>
                  <text x="25" y="35" text-anchor="middle" font-size="16" fill="#EF4444" opacity="0.4">!</text>
                </g>
                <!-- Broken content lines -->
                <rect x="45" y="90" width="70" height="4" rx="2" fill="#E0E0E0" opacity="0.5"/>
                <rect x="45" y="100" width="45" height="4" rx="2" fill="#E0E0E0" opacity="0.3"/>
                <!-- Monitor stand -->
                <rect x="100" y="150" width="40" height="12" rx="2" fill="#E8E8E3"/>
                <rect x="80" y="162" width="80" height="6" rx="3" fill="#E8E8E3"/>
                <!-- Error dots -->
                <circle cx="60" cy="35" r="4" fill="#EF4444" opacity="0.2" class="error-dot ed-1"/>
                <circle cx="170" cy="65" r="3" fill="#EF4444" opacity="0.15" class="error-dot ed-2"/>
                <circle cx="80" cy="110" r="3.5" fill="#EF4444" opacity="0.18" class="error-dot ed-3"/>
              </svg>
            )}

            {visualType === 'ecommerce' && (
              <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="visual-ecommerce">
                <!-- Declining chart line -->
                <path d="M30,50 Q60,55 90,70 T150,110 T220,150" stroke="#EF4444" stroke-width="2" stroke-linecap="round" opacity="0.2" class="decline-line"/>
                <!-- Gradient fill under declining line -->
                <path d="M30,50 Q60,55 90,70 T150,110 T220,150 V180 H30 Z" fill="#EF4444" opacity="0.04"/>
                <!-- Grid lines -->
                <line x1="30" y1="80" x2="220" y2="80" stroke="#E8E8E3" stroke-width="0.5"/>
                <line x1="30" y1="120" x2="220" y2="120" stroke="#E8E8E3" stroke-width="0.5"/>
                <line x1="30" y1="160" x2="220" y2="160" stroke="#E8E8E3" stroke-width="0.5"/>
                <!-- Shopping cart -->
                <g transform="translate(85, 65)" class="cart-icon">
                  <circle cx="18" cy="55" r="4" stroke="#6B6B67" stroke-width="1.5" fill="none" opacity="0.3"/>
                  <circle cx="42" cy="55" r="4" stroke="#6B6B67" stroke-width="1.5" fill="none" opacity="0.3"/>
                  <path d="M5,5 H12 L20,38 H48 L55,15 H18" stroke="#6B6B67" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="28" y1="18" x2="38" y2="28" stroke="#EF4444" stroke-width="1.5" opacity="0.4"/>
                  <line x1="38" y1="18" x2="28" y2="28" stroke="#EF4444" stroke-width="1.5" opacity="0.4"/>
                </g>
                <!-- Downward arrow -->
                <g class="down-arrow" transform="translate(185, 40)">
                  <line x1="10" y1="0" x2="10" y2="25" stroke="#EF4444" stroke-width="1.5" opacity="0.3"/>
                  <polyline points="4,19 10,25 16,19" stroke="#EF4444" stroke-width="1.5" fill="none" opacity="0.3"/>
                </g>
              </svg>
            )}

            {visualType === 'seo' && (
              <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="visual-seo">
                <!-- Search magnifier -->
                <circle cx="120" cy="85" r="45" stroke="#E8E8E3" stroke-width="1.5" fill="none"/>
                <line x1="152" y1="117" x2="180" y2="145" stroke="#E8E8E3" stroke-width="3" stroke-linecap="round"/>
                <!-- Document inside magnifier (fading) -->
                <g class="hidden-page">
                  <rect x="100" y="60" width="40" height="50" rx="4" stroke="#6B6B67" stroke-width="1" fill="#FAFAF9" opacity="0.3"/>
                  <rect x="108" y="70" width="24" height="3" rx="1.5" fill="#E0E0E0" opacity="0.3"/>
                  <rect x="108" y="78" width="18" height="3" rx="1.5" fill="#E0E0E0" opacity="0.25"/>
                  <rect x="108" y="86" width="21" height="3" rx="1.5" fill="#E0E0E0" opacity="0.2"/>
                  <rect x="108" y="94" width="15" height="3" rx="1.5" fill="#E0E0E0" opacity="0.15"/>
                </g>
                <!-- Question marks floating -->
                <text x="70" y="50" font-size="18" fill="#EF4444" opacity="0.15" class="qmark q1">?</text>
                <text x="175" y="70" font-size="14" fill="#EF4444" opacity="0.12" class="qmark q2">?</text>
                <text x="55" y="130" font-size="12" fill="#EF4444" opacity="0.1" class="qmark q3">?</text>
                <!-- Page 8 label -->
                <text x="120" y="175" text-anchor="middle" font-size="11" fill="#6B6B67" opacity="0.3" class="page-label">Page 8 de Google</text>
              </svg>
            )}

            {visualType === 'blank' && (
              <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="visual-blank">
                <!-- Monitor body -->
                <rect x="20" y="10" width="200" height="140" rx="12" stroke="#E8E8E3" stroke-width="1.5" fill="#1A1A2E"/>
                <!-- Screen -->
                <rect x="30" y="20" width="180" height="110" rx="6" fill="#0F0F1A"/>
                <!-- Blinking cursor -->
                <rect x="50" y="55" width="2" height="18" fill="#2563EB" class="cursor-blink"/>
                <!-- Grid dots -->
                <circle cx="60"  cy="40" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="90"  cy="40" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="120" cy="40" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="150" cy="40" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="180" cy="40" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="60"  cy="65" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="90"  cy="65" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="120" cy="65" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="150" cy="65" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="180" cy="65" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="60"  cy="90" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="90"  cy="90" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="120" cy="90" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="150" cy="90" r="1" fill="#2563EB" opacity="0.1"/>
                <circle cx="180" cy="90" r="1" fill="#2563EB" opacity="0.1"/>
                <!-- Star sparkles -->
                <circle cx="170" cy="35" r="1.5" fill="white" opacity="0.2" class="star s1"/>
                <circle cx="80"  cy="95" r="1"   fill="white" opacity="0.15" class="star s2"/>
                <circle cx="150" cy="75" r="1.2" fill="white" opacity="0.18" class="star s3"/>
                <!-- Monitor stand -->
                <rect x="100" y="150" width="40" height="12" rx="2" fill="#E8E8E3"/>
                <rect x="80"  y="162" width="80" height="6"  rx="3" fill="#E8E8E3"/>
              </svg>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S3 — SOLUTION                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-solution cs-section cs-section--alt" aria-label="Notre solution">
      <div class="cs-section-inner">
        <div class="cs-section-header section-header-anim">
          <p class="section-label">Notre solution</p>
          <h2>Ce que nous <em class="font-serif">avons fait</em></h2>
        </div>

        <div class="cs-solution-body">
          <!-- Solution prose -->
          <div class="cs-prose" set:html={study.solution} />

          <!-- Deliverables list -->
          <div class="cs-deliverables">
            <h3 class="cs-deliverables-title">Livrables</h3>
            <ul class="cs-deliverables-list" role="list">
              {study.deliverables.map((item) => (
                <li class="cs-deliverable-item">
                  <svg
                    class="cs-check-icon"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    style={`color:${accent};`}
                  >
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S4 — RÉSULTATS (conditional)                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    {study.results && study.results.length > 0 && (
      <section class="cs-results cs-section" aria-label="Résultats du projet">
        <div class="cs-section-inner">
          <div class="cs-section-header section-header-anim">
            <p class="section-label">Les résultats</p>
            <h2>Impact <em class="font-serif">mesurable</em></h2>
          </div>

          {study.gallery && study.gallery[0] && study.gallery[0].includes("gsc") && (
            <div class="cs-gsc-screenshot">
              <img
                src={study.gallery[0]}
                alt={`Évolution du trafic organique — Google Search Console — ${study.clientName}`}
                loading="lazy"
              />
              <p class="cs-gsc-caption">Données Google Search Console — Octobre 2025 à Mars 2026</p>
            </div>
          )}

          <div
            class="cs-metrics-grid"
            style={`grid-template-columns: repeat(${study.results.length}, 1fr);`}
          >
            {study.results.map((result) => (
              <div class="cs-metric-item">
                <span class="cs-metric-value" style={`color:${accent};`}>{result.metric}</span>
                <p class="cs-metric-label">{result.label}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S5 — GALERIE (conditional)                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    {study.gallery && study.gallery.length > 0 && (
      <section class="cs-gallery cs-section cs-section--alt" aria-label="Galerie du projet">
        <div class="cs-section-inner">
          <div class="cs-section-header section-header-anim">
            <p class="section-label">Le projet en images</p>
            <h2>Aperçu du <em class="font-serif">projet</em></h2>
          </div>

          <div class="cs-gallery-scroll" id="cs-gallery" role="list">
            {study.gallery.map((src, i) => (
              <button
                class="cs-gallery-item"
                data-src={src}
                data-index={String(i)}
                aria-label={`Voir l'image ${i + 1} en plein écran`}
                role="listitem"
              >
                <img
                  src={src}
                  alt={`${study.clientName} — image ${i + 1}`}
                  loading="lazy"
                  class="cs-gallery-img"
                />
              </button>
            ))}
          </div>

          <!-- Lightbox -->
          <div
            id="cs-lightbox"
            class="cs-lightbox"
            hidden
            aria-modal="true"
            aria-label="Image en plein écran"
            role="dialog"
          >
            <button class="cs-lightbox-close" aria-label="Fermer la galerie">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
            <button class="cs-lightbox-nav cs-lightbox-prev" aria-label="Image précédente">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <img id="cs-lightbox-img" src="" alt="" class="cs-lightbox-img" />
            <button class="cs-lightbox-nav cs-lightbox-next" aria-label="Image suivante">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S6 — TÉMOIGNAGE (conditional)                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    {study.testimonial && (
      <section class="cs-testimonial cs-section" aria-label="Témoignage client">
        <div class="cs-section-inner cs-section-inner--narrow">
          <blockquote class="cs-quote-block">
            <div class="cs-guillemets" aria-hidden="true">"</div>
            <p class="cs-quote-text">{study.testimonial.quote}</p>
            <footer class="cs-quote-footer">
              <div class="cs-quote-avatar" style={`background:${accent}18; color:${accent};`}>
                {study.testimonial.author.charAt(0)}
              </div>
              <div class="cs-quote-info">
                <cite class="cs-quote-author">{study.testimonial.author}</cite>
                <span class="cs-quote-role">{study.testimonial.role}</span>
              </div>
            </footer>
          </blockquote>
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- S7 — CTA (blue gradient)                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="cs-cta-section" aria-label="Démarrer un projet similaire">
      <BgWords variant="light" words={[
        { text: 'PROJET',  x: '5%',  y: '8%',  rot: '-10deg', size: '8vw' },
        { text: 'LANCER',  x: '58%', y: '12%', rot: '12deg',  size: '6vw' },
