    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .cs-other-card {
    display: flex;
    flex-direction: row;
    gap: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    align-items: center;
  }

  .cs-other-card:hover {
    border-color: rgba(37, 99, 235, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .cs-other-thumb {
    width: 110px;
    aspect-ratio: 4 / 3;
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: var(--color-surface);
  }

  .cs-other-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cs-other-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-other-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cs-other-category {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .cs-other-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cs-other-type {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cs-other-cta {
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cs-breadcrumb-wrapper { padding-top: 5rem; }

    .cs-detail-hero { padding: 2.5rem 1.25rem 4rem; }
    .cs-detail-hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .cs-detail-hero-visual { order: -1; max-width: 500px; }

    .cs-section { padding: 4rem 1.25rem; }

    .cs-solution-body { grid-template-columns: 1fr; gap: 2.5rem; }

    .cs-metrics-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      border-radius: 16px;
    }

    .cs-metric-item:nth-child(2) { border-right: none; }
    .cs-metric-item:nth-child(1),
    .cs-metric-item:nth-child(2) { border-bottom: 1px solid var(--color-border); }

    .cs-others { padding: 4rem 1.25rem; }
    .cs-others-grid { grid-template-columns: 1fr; }

    .cs-cta-section { padding: 5rem 1.25rem; }
  }

  @media (max-width: 600px) {
    .cs-detail-title { font-size: 2.25rem; }
    .cs-detail-ctas { flex-direction: column; align-items: flex-start; }

    .cs-metrics-grid { grid-template-columns: 1fr !important; }
    .cs-metric-item { border-right: none !important; border-bottom: 1px solid var(--color-border); }
    .cs-metric-item:last-child { border-bottom: none; }

    .cs-others-title { margin-bottom: 1.5rem; }

    .cs-other-card { flex-direction: column; }
    .cs-other-thumb { width: 100%; aspect-ratio: 16 / 9; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // ── Hero entrance
  gsap.fromTo(".cs-detail-hero-content > *",
    { y: 50, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: "power3.out", delay: 0.2, clearProps: "transform,opacity" }
  );

  gsap.fromTo(".cs-detail-hero-visual",
    { x: 40, opacity: 0 },
    { x: 0, opacity: 1, duration: 0.9, ease: "power3.out", delay: 0.45, clearProps: "transform,opacity" }
  );

  // ── Sections on scroll (guard each — conditional sections may be absent)
  const sectionSelectors = [
    ".cs-context",
    ".cs-solution",
    ".cs-results",
    ".cs-gallery",
    ".cs-testimonial",
    ".cs-others",
  ];

  sectionSelectors.forEach((sel) => {
    const el = document.querySelector(sel);
    if (!el) return;
    const targets = el.querySelectorAll(
      ".cs-section-header, .cs-prose, .cs-metrics-grid, .cs-deliverables, .cs-quote-block, .cs-other-card, .cs-gallery-scroll"
    );
    if (!targets.length) return;
    gsap.fromTo(targets,
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, stagger: 0.08, ease: "power2.out", clearProps: "transform,opacity", scrollTrigger: { trigger: el, start: "top 82%" } }
    );
  });

  // ── CTA entrance
  gsap.fromTo(".cs-cta-inner > *",
    { y: 30, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.08,
      ease: "power2.out",
      clearProps: "transform,opacity",
      scrollTrigger: { trigger: ".cs-cta-section", start: "top 70%" },
    }
  );

  // ── Gallery lightbox
  const galleryItems = document.querySelectorAll<HTMLButtonElement>(".cs-gallery-item");
  const lightbox = document.getElementById("cs-lightbox");
  const lightboxImg = document.getElementById("cs-lightbox-img") as HTMLImageElement | null;
  const closeBtn = lightbox?.querySelector<HTMLButtonElement>(".cs-lightbox-close");
  const prevBtn = lightbox?.querySelector<HTMLButtonElement>(".cs-lightbox-prev");
  const nextBtn = lightbox?.querySelector<HTMLButtonElement>(".cs-lightbox-next");

  const images = Array.from(galleryItems).map((b) => b.getAttribute("data-src") ?? "");
  let currentIndex = 0;

  function openLightbox(index: number) {
    currentIndex = index;
    if (lightboxImg) {
      lightboxImg.src = images[currentIndex];
      lightboxImg.alt = `Image ${currentIndex + 1}`;
    }
    lightbox?.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox?.setAttribute("hidden", "");
    document.body.style.overflow = "";
  }

  galleryItems.forEach((btn, i) => btn.addEventListener("click", () => openLightbox(i)));

  closeBtn?.addEventListener("click", closeLightbox);

  prevBtn?.addEventListener("click", () =>
    openLightbox((currentIndex - 1 + images.length) % images.length)
  );

  nextBtn?.addEventListener("click", () =>
    openLightbox((currentIndex + 1) % images.length)
  );

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (lightbox?.hasAttribute("hidden")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") openLightbox((currentIndex - 1 + images.length) % images.length);
    if (e.key === "ArrowRight") openLightbox((currentIndex + 1) % images.length);
  });
</script>
