---
import Layout from "../layouts/Layout.astro";
import Navbar       from "../components/Navbar.astro";
import Hero         from "../components/Hero.astro";
import LogoBanner   from "../components/LogoBanner.astro";
import Services     from "../components/Services.astro";
import Method       from "../components/Method.astro";
import Projects     from "../components/Projects.astro";
import Metrics      from "../components/Metrics.astro";
import Testimonials from "../components/Testimonials.astro";
import CtaSection   from "../components/CtaSection.astro";
import Footer       from "../components/Footer.astro";
---

<Layout
  title="DISAYNER — Création de sites web premium & SEO | Agence web en Haute-Savoie"
  description="Agence web spécialisée dans la création de sites performants et le référencement SEO. Design premium, résultats mesurables. Basé en Haute-Savoie, France."
>
  <Navbar />
  <main id="main-content">
    <Hero />
    <LogoBanner />
    <Services />
    <Method />
    <Projects />
    <Metrics />
    <Testimonials />
    <CtaSection />
  </main>
  <Footer />
</Layout>
