---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://disayner.com");

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://disayner.com/#business",
      "name": "DISAYNER",
      "description": "Agence web spécialisée dans la création de sites performants et le référencement SEO.",
      "url": "https://disayner.com",
      "email": "contact@disayner.com",
      "areaServed": "France",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Haute-Savoie",
        "addressCountry": "FR"
      },
      "sameAs": [],
      "priceRange": "€€",
      "serviceType": ["Création de sites web", "SEO", "Maintenance web"]
    }
  ]
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical & SEO -->
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="DISAYNER" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      // Centralized GSAP plugin registration — runs once per page,
      // shared across all component scripts via Vite module dedupe.
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      gsap.registerPlugin(ScrollTrigger);
    </script>
  </body>
</html>
